---
// SiteHeader — used on /, /pricing, /work, /contact.
// /grow keeps its own conversion-focused LandingHeader (logo + phone + 1 CTA).
// Mobile: <details>-driven hamburger drawer for zero-JS open/close.

const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  currentPath === path || currentPath === `${path}/` || (path !== '/' && currentPath.startsWith(`${path}/`));

const navLinks: { label: string; href: string }[] = [
  { label: 'Work', href: '/work' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Contact', href: '/contact' },
];
---
<header class="relative z-30 w-full border-b border-line/60 bg-bg/80 backdrop-blur supports-[backdrop-filter]:bg-bg/60">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-4 sm:py-5 flex items-center justify-between gap-3 sm:gap-6">
    <a href="/" class="flex items-center flex-shrink-0" aria-label="Designed to Elevate — home">
      <img
        src="/logo-wordmark-orange.png"
        alt="Designed to Elevate"
        width="320"
        height="96"
        class="h-9 sm:h-10 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7 lg:gap-9 font-display font-medium text-[0.95rem]" aria-label="Primary">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'transition-colors hover:text-accent',
            isActive(link.href) ? 'text-accent' : 'text-text-soft',
          ]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/grow"
        class="hidden sm:inline-flex btn-primary !py-2.5 !px-3.5 sm:!px-4 !text-[0.78rem] sm:!text-[0.85rem] whitespace-nowrap"
      >
        Get Free Audit
        <span aria-hidden="true">↗</span>
      </a>

      <!-- Mobile hamburger (no JS, native <details>) -->
      <details class="md:hidden relative site-menu">
        <summary class="list-none cursor-pointer inline-flex h-10 w-10 items-center justify-center rounded-md border border-line text-text-soft hover:border-accent hover:text-accent transition-colors" aria-label="Open menu">
          <svg class="menu-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg class="menu-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </summary>

        <div class="absolute right-0 top-[calc(100%+0.5rem)] w-[260px] rounded-xl border border-line bg-surface-1 shadow-2xl p-2 z-40">
          <nav aria-label="Mobile">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-3 rounded-lg font-display font-medium text-[0.95rem] transition-colors',
                  isActive(link.href)
                    ? 'text-accent bg-accent/10'
                    : 'text-text-soft hover:text-accent hover:bg-surface-2',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))}
            <a href="tel:7406176488" class="flex items-center gap-2 px-4 py-3 rounded-lg text-text-soft hover:text-accent hover:bg-surface-2 transition-colors font-display font-medium text-[0.95rem]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
              (740) 617-6488
            </a>
            <a href="/grow" class="btn-primary w-full mt-2 !py-3 !text-[0.85rem]">
              Get Free Audit
              <span aria-hidden="true">↗</span>
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  .site-menu summary::-webkit-details-marker { display: none; }
  .site-menu .menu-close { display: none; }
  .site-menu[open] .menu-open { display: none; }
  .site-menu[open] .menu-close { display: block; }
</style>
