---
// SiteFooter — used on /, /pricing, /work, /contact.
// /grow has its own slim footer baked into FinalCTASection.
const year = new Date().getFullYear();
---
<footer class="relative border-t border-line bg-surface-1/40">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-14 sm:py-16">
    <div class="grid gap-10 sm:gap-12 lg:grid-cols-[1.4fr_1fr_1fr_1.1fr]">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center" aria-label="Designed to Elevate — home">
          <img src="/logo-wordmark-orange.png" alt="Designed to Elevate" width="320" height="96" class="h-9 w-auto" />
        </a>
        <p class="mt-5 text-text-soft text-[0.98rem] leading-relaxed max-w-sm">
          Lead systems for local service businesses.
        </p>
        <p class="mt-3 text-text-muted text-[0.88rem]">
          We build the path from Google search to quote request to booked job.
        </p>
      </div>

      <!-- Site -->
      <div>
        <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-text-muted mb-4">Site</div>
        <ul class="space-y-2.5 text-[0.95rem]">
          <li><a href="/" class="text-text-soft hover:text-accent transition-colors">Home</a></li>
          <li><a href="/work" class="text-text-soft hover:text-accent transition-colors">Work</a></li>
          <li><a href="/pricing" class="text-text-soft hover:text-accent transition-colors">Pricing</a></li>
          <li><a href="/contact" class="text-text-soft hover:text-accent transition-colors">Contact</a></li>
          <li><a href="/grow" class="text-accent hover:text-accent-hover transition-colors font-medium">Founding 5 Offer →</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-text-muted mb-4">Legal</div>
        <ul class="space-y-2.5 text-[0.95rem]">
          <li><a href="/privacy" class="text-text-soft hover:text-accent transition-colors">Privacy</a></li>
          <li><a href="/terms" class="text-text-soft hover:text-accent transition-colors">Terms</a></li>
          <li><a href="/refund" class="text-text-soft hover:text-accent transition-colors">Refund</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-text-muted mb-4">Contact</div>
        <ul class="space-y-2.5 text-[0.95rem]">
          <li>
            <a href="tel:7406176488" class="inline-flex items-center gap-2 text-text-soft hover:text-accent transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
              (740) 617-6488
            </a>
          </li>
          <li>
            <a href="mailto:bilsonxnc@gmail.com" class="inline-flex items-center gap-2 text-text-soft hover:text-accent transition-colors break-all">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
              bilsonxnc@gmail.com
            </a>
          </li>
          <li class="inline-flex items-center gap-2 text-text-muted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Zanesville, OH · Remote anywhere
          </li>
        </ul>
      </div>
    </div>

    <hr class="mt-14 border-line" />

    <div class="mt-8 flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-4 text-text-muted text-[0.85rem]">
      <div>© {year} Designed to Elevate. All rights reserved.</div>
      <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">
        Built by an operator, not an agency.
      </div>
    </div>
  </div>
</footer>
