---
const services = [
  {
    title: 'Website Design',
    body: 'Clean, mobile-first websites that load fast, read clearly, and pull visitors toward booking. No theme bloat. No template feel.',
    icon: 'window',
  },
  {
    title: 'Landing Pages',
    body: 'Focused pages built for one service, one ad, or one promo. Stripped of distractions and pointed at a single next step.',
    icon: 'target',
  },
  {
    title: 'Local SEO Structure',
    body: 'Service pages, location pages, headings, metadata, FAQs, internal links — the bones search engines reward and customers trust.',
    icon: 'pin',
  },
  {
    title: 'Lead Generation Systems',
    body: 'Quote forms, booking paths, intake flows, and follow-up. The path from “interested” to “booked” shouldn’t be a guess.',
    icon: 'flow',
  },
  {
    title: 'Website Copywriting',
    body: 'Plain-spoken copy that explains the work, builds trust, and handles the questions every shop hears before someone calls.',
    icon: 'pen',
  },
  {
    title: 'Marketing Strategy',
    body: 'Practical guidance on offers, pricing presentation, customer journey, and where to focus next. No fluff. No fake frameworks.',
    icon: 'compass',
  },
];

function Icon(name: string) {
  // Returns SVG markup string
  const stroke = '#1E48FF';
  const map: Record<string, string> = {
    window: `<rect x="3" y="5" width="18" height="14" rx="2" stroke="${stroke}" stroke-width="1.6"/><path d="M3 9h18" stroke="${stroke}" stroke-width="1.6"/><circle cx="6.2" cy="7.1" r="0.6" fill="${stroke}"/><circle cx="8.4" cy="7.1" r="0.6" fill="${stroke}"/>`,
    target: `<circle cx="12" cy="12" r="8" stroke="${stroke}" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="${stroke}" stroke-width="1.6"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4" stroke="${stroke}" stroke-width="1.6"/>`,
    pin: `<path d="M12 2c4 0 7 3 7 7 0 5.2-7 13-7 13S5 14.2 5 9c0-4 3-7 7-7Z" stroke="${stroke}" stroke-width="1.6"/><circle cx="12" cy="9" r="2.5" stroke="${stroke}" stroke-width="1.6"/>`,
    flow: `<circle cx="5" cy="6" r="2" stroke="${stroke}" stroke-width="1.6"/><circle cx="5" cy="18" r="2" stroke="${stroke}" stroke-width="1.6"/><circle cx="19" cy="12" r="2" stroke="${stroke}" stroke-width="1.6"/><path d="M7 6h6c2 0 4 2 4 6M7 18h6c2 0 4-2 4-6" stroke="${stroke}" stroke-width="1.6"/>`,
    pen: `<path d="M4 20l4-1 11-11-3-3L5 16l-1 4Z" stroke="${stroke}" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 7l3 3" stroke="${stroke}" stroke-width="1.6"/>`,
    compass: `<circle cx="12" cy="12" r="9" stroke="${stroke}" stroke-width="1.6"/><path d="M9 15l2-6 6-2-2 6-6 2Z" stroke="${stroke}" stroke-width="1.6" stroke-linejoin="round"/>`,
  };
  return map[name] || '';
}
---
<section class="services" id="services">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Services</span>
      <h2>What we build for service businesses.</h2>
      <p class="lede">
        Six services. Each one solves a specific gap between a customer searching and a customer booked.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <article class="card elevate reveal service-card" style={`transition-delay:${i * 50}ms;`}>
          <div class="icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" set:html={Icon(s.icon)} />
          </div>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .service-card .icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(30, 72, 255, 0.08);
    border: 1px solid rgba(30, 72, 255, 0.18);
  }
  .service-card h3 { margin-top: 4px; }
</style>
