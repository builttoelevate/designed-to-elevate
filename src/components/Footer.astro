---
const base = import.meta.env.BASE_URL;
---
<footer class="site-footer">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-brand">
        <img src={`${base}logo-wordmark.png`} alt="Designed to Elevate" width="220" height="60" />
        <p class="tagline">More customers. Less chasing.</p>
        <p class="address">
          Designed to Elevate<br/>
          Zanesville, Ohio · Available anywhere in the U.S.
        </p>
      </div>

      <div class="foot-col">
        <h4>Studio</h4>
        <ul>
          <li><a href={`${base}#services`}>Services</a></li>
          <li><a href={`${base}#system`}>The Elevate System</a></li>
          <li><a href={`${base}#process`}>Process</a></li>
          <li><a href={`${base}#projects`}>Projects</a></li>
          <li><a href={`${base}#ways`}>Ways to Work Together</a></li>
        </ul>
      </div>

      <div class="foot-col">
        <h4>Company</h4>
        <ul>
          <li><a href={`${base}#founder`}>Founder</a></li>
          <li><a href={`${base}#faq`}>FAQ</a></li>
          <li><a href={`${base}#contact`}>Contact</a></li>
        </ul>
      </div>

      <div class="foot-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:bilsonxnc@gmail.com">bilsonxnc@gmail.com</a></li>
          <li><a href="tel:+17406176488">740-617-6488</a></li>
          <li><span>Mon–Fri · Zanesville, OH</span></li>
        </ul>
      </div>
    </div>

    <hr class="rule" />

    <div class="foot-bottom">
      <p class="copy">© <span data-year>2026</span> Designed to Elevate. All rights reserved.</p>
      <ul class="legal">
        <li><a href={`${base}privacy`}>Privacy Policy</a></li>
        <li><a href={`${base}terms`}>Terms of Service</a></li>
        <li><a href={`${base}refund`}>Refund Policy</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #07090F;
    border-top: 1px solid var(--line);
    padding: 80px 0 40px;
    position: relative;
  }
  .site-footer::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
    opacity: 0.4;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  .foot-brand img {
    height: 42px;
    width: auto;
    margin-bottom: 18px;
    mix-blend-mode: screen;
  }
  .tagline {
    font-family: var(--font-display);
    color: var(--white);
    font-size: 1.1rem;
    margin-bottom: 18px;
  }
  .address { color: var(--mute); font-size: 0.92rem; line-height: 1.7; }

  .foot-col h4 {
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--mute);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 18px;
  }
  .foot-col ul {
    list-style: none;
    padding: 0; margin: 0;
    display: grid;
    gap: 10px;
  }
  .foot-col a, .foot-col span {
    color: var(--soft);
    font-size: 0.95rem;
  }
  .foot-col a:hover { color: var(--blue-soft); }

  .foot-bottom {
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
  }
  .copy { color: var(--mute); font-size: 0.88rem; margin: 0; }
  .legal {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }
  .legal a {
    color: var(--mute);
    font-size: 0.88rem;
  }
  .legal a:hover { color: var(--white); }

  @media (max-width: 900px) {
    .foot-grid { grid-template-columns: 1fr 1fr; gap: 36px; }
    .foot-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .foot-grid { grid-template-columns: 1fr; }
  }
</style>
