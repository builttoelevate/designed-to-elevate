---
const base = import.meta.env.BASE_URL;
const trustItems = [
  'Auto Detailing',
  'Window Tint',
  'Barbershops',
  'Home Services',
  'Local Service Brands',
];
---
<section class="hero" id="top">
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-inner">
    <img
      class="hero-logo"
      src={`${base}logo-wordmark.png`}
      alt="Designed to Elevate"
      width="1080"
      height="324"
      fetchpriority="high"
      decoding="async"
    />

    <div class="eyebrow"><span class="dot" aria-hidden="true"></span> Marketing for local service businesses</div>

    <h1 class="hero-title">
      More customers.<br/>
      <span class="accent">Less chasing.</span>
    </h1>

    <p class="hero-lede">
      Websites, landing pages, and lead systems built for shops, studios, and home-service crews.
      Designed to Elevate is run by a service-business owner who learned marketing inside his own bay —
      not in a boardroom. Clear offers. Pages that convert. A path from search to booked.
    </p>

    <div class="hero-ctas">
      <a href="#contact" class="btn btn-primary">Request a Quote <span class="arrow" aria-hidden="true">↗</span></a>
      <a href="#services" class="btn btn-ghost">View Services</a>
    </div>

    <ul class="trust-strip" aria-label="Industries served">
      {trustItems.map((t, i) => (
        <li>
          <span class="mark" aria-hidden="true"></span>
          {t}
        </li>
      ))}
    </ul>
  </div>

  <div class="hero-arrow" aria-hidden="true">
    <svg viewBox="0 0 1200 600" preserveAspectRatio="none">
      <defs>
        <linearGradient id="arc" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#1E48FF" stop-opacity="0"/>
          <stop offset="55%" stop-color="#1E48FF" stop-opacity="0.6"/>
          <stop offset="100%" stop-color="#6F87FF" stop-opacity="0.9"/>
        </linearGradient>
      </defs>
      <path d="M -50 560 Q 400 420 700 280 T 1250 60" fill="none" stroke="url(#arc)" stroke-width="2"/>
      <path d="M -50 580 Q 400 440 700 300 T 1250 80" fill="none" stroke="url(#arc)" stroke-width="1" opacity="0.5"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(72px, 9vw, 130px);
    padding-bottom: clamp(80px, 10vw, 150px);
    isolation: isolate;
  }
  .hero-glow {
    position: absolute;
    top: -200px; right: -200px;
    width: 720px; height: 720px;
    background: radial-gradient(circle, rgba(30,72,255,0.22) 0%, transparent 60%);
    filter: blur(20px);
    z-index: 0;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 980px;
  }

  .hero-logo {
    width: clamp(280px, 56vw, 640px);
    height: auto;
    margin: 0 0 36px -2%;
    display: block;
    filter: drop-shadow(0 10px 40px rgba(30, 72, 255, 0.25));
    animation: heroLogoIn .9s var(--ease) both;
  }
  @keyframes heroLogoIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 700px) {
    .hero-logo { margin-left: 0; }
  }

  .hero-title {
    margin-top: 22px;
    font-size: clamp(2.6rem, 7.4vw, 5.2rem);
    line-height: 0.98;
  }
  .hero-title .accent {
    background: linear-gradient(120deg, #6F87FF 0%, #1E48FF 60%, #FFFFFF 110%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shimmer 6s linear infinite;
  }
  @keyframes shimmer {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  .hero-lede {
    margin-top: 26px;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    color: var(--soft);
    max-width: 64ch;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    margin-top: 38px;
    flex-wrap: wrap;
  }

  .trust-strip {
    list-style: none;
    margin: 56px 0 0;
    padding: 18px 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(17,21,30,0.6);
    backdrop-filter: blur(8px);
  }
  .trust-strip li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--soft);
  }

  .hero-arrow {
    position: absolute;
    inset: auto 0 0 0;
    height: 60%;
    z-index: 1;
    pointer-events: none;
    opacity: 0.7;
  }
  .hero-arrow svg { width: 100%; height: 100%; }

  @media (max-width: 700px) {
    .trust-strip { gap: 18px; padding: 16px 18px; }
    .trust-strip li { font-size: 0.78rem; }
  }
</style>
