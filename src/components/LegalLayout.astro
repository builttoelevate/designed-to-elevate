---
import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHeader from './landing/LandingHeader.astro';

interface Props {
  title: string;
  description: string;
  pathname: string;
  effective?: string;
  intro?: string;
}

const { title, description, pathname, effective = 'April 2026', intro } = Astro.props;
---
<LandingLayout title={`${title} — Designed to Elevate`} description={description} pathname={pathname}>
  <LandingHeader />
  <main>
    <!-- Legal head -->
    <section class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-3xl px-5 sm:px-8 pt-12 sm:pt-20 pb-12">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Legal</span>
        <h1 class="mt-5 text-[2.4rem] sm:text-[3.2rem] leading-[1.04] font-bold tracking-tight">{title}</h1>
        <p class="mt-3 text-text-muted text-[0.85rem] font-display tracking-wider uppercase">Effective: {effective}</p>
        {intro && <p class="mt-6 text-text-soft text-[1.05rem] leading-relaxed max-w-2xl">{intro}</p>}

        <div class="mt-7 rounded-xl border border-dashed border-accent/40 bg-accent/5 px-5 py-4 text-[0.92rem] text-text-soft leading-relaxed" role="note">
          <strong class="text-accent font-display font-semibold">Placeholder.</strong>
          This page exists so the link works and so the site meets payment-processor review requirements. The founder will replace this with the final policy text.
        </div>
      </div>
    </section>

    <!-- Legal body -->
    <section class="relative">
      <div class="mx-auto max-w-3xl px-5 sm:px-8 py-14 sm:py-20 legal-body">
        <slot />
      </div>
    </section>

    <!-- Slim footer -->
    <footer class="border-t border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-10 flex flex-col sm:flex-row items-center sm:items-end justify-between gap-6">
        <a href="/" class="flex items-center" aria-label="Designed to Elevate">
          <img
            src="/logo-wordmark-orange.png"
            alt="Designed to Elevate"
            width="320"
            height="96"
            class="h-9 w-auto"
          />
        </a>
        <div class="text-[0.85rem] text-text-muted text-center sm:text-right">
          <div>© 2026 Designed to Elevate. All rights reserved.</div>
          <div class="mt-1 flex flex-wrap gap-4 justify-center sm:justify-end">
            <a href="tel:7406176488" class="hover:text-accent transition-colors">(740) 617-6488</a>
            <a href="/privacy" class="hover:text-text transition-colors">Privacy</a>
            <a href="/terms" class="hover:text-text transition-colors">Terms</a>
            <a href="/refund" class="hover:text-text transition-colors">Refund</a>
          </div>
        </div>
      </div>
    </footer>
  </main>
</LandingLayout>

<style>
  .legal-body :global(h2) {
    font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 40px 0 14px;
    letter-spacing: -0.01em;
  }
  .legal-body :global(h2:first-child) { margin-top: 0; }
  .legal-body :global(p) {
    color: var(--color-text-soft);
    margin: 0 0 14px;
    line-height: 1.78;
  }
  .legal-body :global(ul) {
    color: var(--color-text-soft);
    padding-left: 22px;
    margin: 0 0 18px;
    line-height: 1.78;
  }
  .legal-body :global(li) { margin-bottom: 8px; }
  .legal-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(255, 107, 26, 0.4);
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s ease;
  }
  .legal-body :global(a:hover) { text-decoration-color: var(--color-accent); }
  .legal-body :global(strong) { color: var(--color-text); font-weight: 600; }
</style>
