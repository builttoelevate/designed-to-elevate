---
// UpgradeAuditForm — 5-field audit-request form per the brief.
// Section id="apply" so the LandingLayout sticky-CTA IntersectionObserver
// and skip-link both work without modification.
//
// Submission is handled by the [data-audit-form] script in LandingLayout —
// posts multipart FormData to Web3Forms. Same web3forms access_key as
// /grow so leads land in the same inbox.
const squareOptions = [
  'Yes — we use Square today',
  'No — we use something else',
  'Not sure / mixed setup',
];
---
<!-- AUDIT FORM SECTION -->
<section id="apply" class="relative overflow-hidden bg-surface-1/60 border-y border-line">
  <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
  <div class="accent-glow absolute -top-40 -left-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8 py-24 sm:py-32">
    <div class="grid lg:grid-cols-[1fr_1.05fr] gap-10 lg:gap-16">
      <!-- Left: offer copy -->
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Free Review</span>
        <h2 class="mt-5 text-[2.2rem] sm:text-[3rem] leading-[1.05] font-bold">
          Get a <span class="text-accent">10-Minute Website Review</span> — Free.
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed max-w-xl">
          Drop your site below. I'll review it and send you 3 specific changes to make it look more premium, feel easier to use, and make booking smoother.
        </p>

        <!-- What you get -->
        <div class="mt-7 card p-6">
          <div class="font-display font-semibold text-[0.78rem] uppercase tracking-[0.18em] text-accent mb-4">
            Your free review includes
          </div>
          <ul class="space-y-3">
            {[
              'One thing hurting trust',
              'One thing making booking harder',
              'One opportunity to make the site feel more premium',
            ].map((item) => (
              <li class="flex items-start gap-3 text-[0.98rem] text-text leading-snug">
                <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent text-bg flex-shrink-0" aria-hidden="true">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="mt-5 text-[0.88rem] text-text-muted leading-relaxed">
            No hard pitch. No weird pressure. Just useful.
          </p>
        </div>

        <!-- Phone-first option -->
        <div class="mt-6 flex items-start gap-3 rounded-xl border border-accent/30 bg-accent/5 p-4">
          <span class="mt-0.5 inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-bg flex-shrink-0" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          </span>
          <div>
            <div class="font-display font-semibold text-[0.95rem] text-text">Prefer to talk?</div>
            <p class="text-[0.92rem] text-text-soft mt-0.5">
              Call or text Bill at
              <button type="button" data-call-text class="text-accent font-semibold underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors whitespace-nowrap">(740) 617-6488</button>
            </p>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <form
          data-audit-form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="card p-6 sm:p-8 space-y-5"
          novalidate
        >
          <input type="hidden" name="access_key" value="1272e2dd-abff-4804-a541-beb2bd0be075" />
          <input type="hidden" name="subject" value="New Website Review Request — /upgrade · designedtoelevate.co" />
          <input type="hidden" name="source" value="/upgrade landing page" />
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Name <span class="text-accent">*</span></span>
              <input required name="name" type="text" autocomplete="name" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Your name" />
            </label>
            <label class="block">
              <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Business name <span class="text-accent">*</span></span>
              <input required name="business" type="text" autocomplete="organization" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Your shop or studio" />
            </label>
          </div>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Website URL <span class="text-accent">*</span></span>
            <input required name="website" type="url" autocomplete="url" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="https://yourshop.com" />
          </label>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Best way to reach you <span class="text-accent">*</span></span>
            <input required name="contact" type="text" autocomplete="email" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Email or phone" />
          </label>

          <fieldset class="block">
            <legend class="block font-display font-medium text-[0.82rem] text-text-soft mb-2.5">Are you using Square? <span class="text-accent">*</span></legend>
            <div class="space-y-2">
              {squareOptions.map((opt, i) => (
                <label class="flex items-start gap-3 cursor-pointer rounded-md border border-line bg-surface-2 px-3.5 py-2.5 hover:border-accent/60 transition-colors has-[:checked]:border-accent has-[:checked]:bg-accent/5">
                  <input
                    required
                    type="radio"
                    name="uses_square"
                    value={opt}
                    class="mt-0.5 h-4 w-4 accent-[#FF6B1A] flex-shrink-0"
                    checked={i === 0 ? false : undefined}
                  />
                  <span class="text-[0.95rem] text-text leading-snug">{opt}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <button type="submit" class="btn-primary w-full !py-3.5">
            Get My Free Review
            <span aria-hidden="true">↗</span>
          </button>

          <p
            data-audit-status
            class="hidden text-[0.92rem] text-accent font-display font-medium items-center gap-2"
            role="status"
            aria-live="polite"
          ></p>

          <p class="text-[0.78rem] text-text-muted leading-relaxed">
            Bill personally reviews every site and responds within 24 hours. No spam. No list-selling.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- /AUDIT FORM SECTION -->
