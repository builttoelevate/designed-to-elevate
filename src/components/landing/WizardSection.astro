---
// WizardSection — six-card grid preceded by a "partial leads" callout.
// Reuses the three Fitchin wizard screenshots (step-1, step-3, step-6)
// in the same layered triple-card layout from the prior page, plus the
// "$674.10 — Quote requested" float chip.
const features = [
  { title: 'Guides the customer', body: 'Step-by-step questions tailored to your services. Customers feel helped, not interrogated.' },
  { title: 'Shows real pricing', body: 'Tiered packages, add-ons, and conditional logic mean the customer sees a real number — not "we\'ll get back to you with a quote."' },
  { title: 'Mobile-first by default', body: 'Most service-business traffic is phone-first. The wizard is built for thumb taps — not a desktop form shrunk to fit a phone. Customers complete quotes from the parking lot.' },
  { title: 'Anchors the value', body: 'Good/better/best presentation lets the customer compare your tiers against each other instead of against the cheapest shop in town.' },
  { title: 'Sells the upgrades', body: "Add-ons appear in the flow at the moment they're easiest to say yes to — not after the fact." },
  { title: 'Connects to the next step', body: 'Each quote ends with the action the customer is most likely to take — call, text, or booking.' },
];
---
<!-- WIZARD SECTION -->
<section id="wizard" class="relative border-b border-line bg-surface-1/40">
  <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-24 sm:py-32">
    <div class="grid lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-16 items-start">
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The Wizard</span>
        <h2 class="mt-5 text-[2.1rem] sm:text-[2.9rem] leading-[1.05] font-bold">
          What Changes When the Quote Form Becomes a <span class="text-accent">Sales Tool</span>
        </h2>

        <!-- Partial-lead callout — visually distinct from the cards below -->
        <div class="mt-8 relative overflow-hidden rounded-2xl border-2 border-accent/50 bg-gradient-to-br from-accent/15 via-accent/5 to-transparent p-6 sm:p-7">
          <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full bg-accent/20 blur-3xl" aria-hidden="true"></div>
          <div class="relative">
            <div class="font-display font-bold text-[0.74rem] sm:text-[0.78rem] uppercase tracking-[0.2em] text-accent">
              Even Unfinished Quotes Become Leads
            </div>
            <p class="mt-3 text-[0.98rem] sm:text-[1.02rem] text-text leading-relaxed">
              Most contact forms only save a lead when the customer reaches the final "Submit" button. The Wizard captures contact info <span class="text-accent font-semibold">before the final step</span> — so a customer who bails on step 3 still shows up in your dashboard as a follow-up opportunity. That's follow-up opportunity your old contact form never showed you.
            </p>
          </div>
        </div>

        <div class="mt-8 grid sm:grid-cols-2 gap-4">
          {features.map((f) => (
            <div class="rounded-xl border border-line bg-surface-2 p-5">
              <div class="flex items-center gap-2.5 mb-2">
                <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                <h3 class="font-display font-semibold text-[1rem] text-text">{f.title}</h3>
              </div>
              <p class="text-[0.88rem] text-text-soft leading-relaxed">{f.body}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href="#apply" class="btn-primary">
            Apply for a Wizard Build
            <span aria-hidden="true">↗</span>
          </a>
          <a href="#offers" class="btn-ghost">
            See the Offers
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>

      <!-- Right: real Fitchin wizard screenshots, layered to tell the
           guide → upsell → close story (Step 1 → upsell tiers → final quote). -->
      <div class="relative" aria-hidden="true">
        <div class="absolute -inset-4 bg-gradient-to-br from-accent/40 via-accent/10 to-transparent rounded-[2rem] blur-3xl opacity-50" aria-hidden="true"></div>

        <div class="relative aspect-[5/6] sm:aspect-[5/5.5]">
          <div class="absolute top-0 left-0 w-[58%] aspect-[10/13] rotate-[-4deg] origin-bottom-right rounded-[1.6rem] overflow-hidden border border-line shadow-2xl bg-surface-2">
            <img
              src="/wizard/step-1-service.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="absolute top-[6%] right-0 w-[64%] aspect-[10/13] rotate-[3deg] rounded-[1.6rem] overflow-hidden border border-accent/40 shadow-[0_30px_80px_-20px_rgba(255,107,26,0.45)] bg-surface-2">
            <img
              src="/wizard/step-3-pick-film.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="absolute bottom-0 left-[6%] w-[60%] aspect-[10/13] rotate-[-2deg] rounded-[1.6rem] overflow-hidden border border-line shadow-2xl bg-surface-2">
            <img
              src="/wizard/step-6-final-quote.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="absolute bottom-[6%] right-[2%] card px-3.5 py-2.5 flex items-center gap-3 rotate-[3deg]">
            <div class="h-8 w-8 rounded-full bg-accent grid place-items-center text-bg font-display font-bold text-[0.85rem]">$</div>
            <div class="leading-tight">
              <div class="font-display font-semibold text-[0.78rem] text-text">Quote: $674.10</div>
              <div class="text-[0.65rem] text-text-muted">Quote requested · just now</div>
            </div>
          </div>
        </div>

        <p class="mt-4 text-center text-[0.7rem] uppercase tracking-[0.18em] text-text-muted/70">
          Real Fitchin wizard · live at fitchinautodetail.com
        </p>
      </div>
    </div>
  </div>
</section>
<!-- /WIZARD SECTION -->
