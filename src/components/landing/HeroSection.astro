---
const miniBullets = [
  'Websites That Convert',
  'Quote Forms That Upsell',
  'Google Visibility That Grows',
];
---
<!-- HERO SECTION -->
<section id="top" class="relative overflow-hidden border-b border-line">
  <div class="grid-bg absolute inset-0 z-0 opacity-60" aria-hidden="true"></div>
  <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-10 sm:pt-16 pb-20 sm:pb-28">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
      <!-- LEFT: copy -->
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Local Growth System</span>

        <h1 class="mt-5 text-[2.4rem] sm:text-[3.1rem] lg:text-[3.6rem] leading-[1.02] font-bold text-text">
          Get More Local Leads From Your Website, Google Listing, and
          <span class="text-accent">Quote Process</span>
        </h1>

        <p class="mt-6 max-w-[58ch] text-[1.05rem] sm:text-[1.12rem] leading-[1.6] text-text-soft">
          Designed to Elevate helps local service businesses turn online searches into calls,
          quote requests, and booked jobs with conversion-focused websites, Google Business
          Profile optimization, custom quote forms, Google Ads landing pages, and SEO.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#audit-form" class="btn-primary">
            Get My Free Growth Audit
            <span aria-hidden="true">↗</span>
          </a>
          <a href="#live-showcase" class="btn-ghost">See It Working</a>
        </div>

        <p class="mt-6 text-sm text-text-muted">
          Built from real local business experience, not agency theory.
        </p>

        <ul class="mt-7 grid sm:grid-cols-3 gap-3 max-w-2xl">
          {miniBullets.map((b) => (
            <li class="flex items-center gap-2.5 text-[0.95rem] text-text-soft">
              <span aria-hidden="true" class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/15 text-accent text-[0.7rem]">✓</span>
              <span class="font-display font-medium">{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: composite mockup placeholder -->
      <div class="relative" aria-hidden="true">
        <div class="relative aspect-[4/4.2] sm:aspect-[5/4.5] overflow-hidden">
          <!-- Website preview card -->
          <div class="absolute top-0 left-0 right-6 sm:right-12 card overflow-hidden rotate-[-1.5deg]">
            <div class="flex items-center gap-1.5 px-3 py-2.5 border-b border-line bg-surface-2">
              <span class="h-2.5 w-2.5 rounded-full bg-line-2"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-line-2"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-line-2"></span>
              <span class="ml-3 text-[0.7rem] text-text-muted font-display tracking-wider">yourshop.com</span>
            </div>
            <div class="px-4 py-5">
              <div class="h-2 w-2/3 rounded bg-text-muted/40 mb-2"></div>
              <div class="h-2 w-1/2 rounded bg-text-muted/25 mb-4"></div>
              <div class="h-20 rounded-md bg-gradient-to-br from-accent/30 to-accent/10 border border-line mb-3"></div>
              <div class="grid grid-cols-3 gap-2">
                <div class="h-8 rounded bg-surface-3"></div>
                <div class="h-8 rounded bg-surface-3"></div>
                <div class="h-8 rounded bg-surface-3"></div>
              </div>
            </div>
          </div>

          <!-- Google Business Profile card -->
          <div class="absolute top-[34%] left-2 right-12 sm:right-20 card overflow-hidden p-4 rotate-[1.5deg]">
            <div class="flex items-center gap-3">
              <div class="h-11 w-11 rounded-lg bg-gradient-to-br from-accent to-accent-deep grid place-items-center text-bg font-display font-bold">
                G
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-[0.85rem] font-display font-semibold text-text truncate">Your Local Business</div>
                <div class="flex items-center gap-1 text-[0.7rem] text-text-muted">
                  <span class="text-accent">★★★★★</span>
                  <span>4.9 · 287 reviews</span>
                </div>
              </div>
              <span class="text-[0.65rem] tracking-wider uppercase font-display text-accent">Open</span>
            </div>
            <div class="mt-3 grid grid-cols-3 gap-2 text-center">
              <div class="rounded bg-surface-3 py-2">
                <div class="text-[0.65rem] text-text-muted">Call</div>
              </div>
              <div class="rounded bg-surface-3 py-2">
                <div class="text-[0.65rem] text-text-muted">Directions</div>
              </div>
              <div class="rounded bg-accent/15 py-2">
                <div class="text-[0.65rem] text-accent font-semibold">Book</div>
              </div>
            </div>
          </div>

          <!-- Quote wizard preview — real Fitchin screenshot.
               Aspect-[5/4] keeps the card a flat, landscape shape so the
               full screenshot doesn't overflow. object-cover + object-top
               crops to the most informative portion (headline + first tier). -->
          <div class="absolute bottom-12 right-0 left-12 sm:left-20 aspect-[5/4] rounded-2xl overflow-hidden border border-accent/40 shadow-[0_20px_60px_-15px_rgba(255,107,26,0.4)] rotate-[-1deg] bg-surface-2">
            <img
              src="/wizard/step-3-pick-film.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="eager"
              decoding="async"
            />
          </div>

          <!-- Lead notification chip -->
          <div class="absolute bottom-0 left-0 card px-4 py-3 flex items-center gap-3 max-w-[260px] rotate-[2deg] shadow-xl">
            <div class="h-9 w-9 rounded-full bg-accent grid place-items-center text-bg font-display font-bold">!</div>
            <div class="leading-tight">
              <div class="text-[0.75rem] font-display font-semibold text-text">New quote request</div>
              <div class="text-[0.7rem] text-text-muted">Window Tint · $674.10 · just now</div>
            </div>
          </div>
        </div>
        <p class="mt-4 text-center text-[0.7rem] uppercase tracking-[0.18em] text-text-muted/60">
          Composite mockup · real screenshots in Phase 2
        </p>
      </div>
    </div>
  </div>
</section>
<!-- /HERO SECTION -->
