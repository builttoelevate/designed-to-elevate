---
const miniBullets = [
  'Websites That Convert',
  'Quote Forms That Upsell',
  'Google Visibility That Grows',
];
---
<!-- HERO SECTION -->
<section id="top" class="relative overflow-hidden border-b border-line">
  <div class="grid-bg absolute inset-0 z-0 opacity-60" aria-hidden="true"></div>
  <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-10 sm:pt-16 pb-20 sm:pb-28">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
      <!-- LEFT: copy -->
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Local Growth System</span>

        <h1 class="mt-5 text-[2.4rem] sm:text-[3.1rem] lg:text-[3.6rem] leading-[1.02] font-bold text-text">
          Get More Local Leads From Your Website, Google Listing, and
          <span class="text-accent">Quote System</span>
        </h1>

        <p class="mt-6 max-w-[58ch] text-[1.05rem] sm:text-[1.12rem] leading-[1.6] text-text-soft">
          Designed to Elevate helps local service businesses turn Google searches into calls,
          quote requests, and booked jobs with better websites, stronger Google visibility,
          and smarter quote systems.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3">
          <a href="#audit-form" data-hero-cta class="btn-primary">
            Get My Free Growth Audit
            <span aria-hidden="true">↗</span>
          </a>
          <a
            href="#signature-quote"
            class="hidden sm:inline-flex items-center gap-1.5 font-display font-medium text-[0.95rem] text-text-soft underline decoration-line-2 decoration-1 underline-offset-4 hover:text-accent hover:decoration-accent transition-colors"
          >
            See it working
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <p class="mt-6 text-sm text-text-muted">
          Built from real local business experience, not agency theory.
        </p>

        <ul class="mt-7 grid sm:grid-cols-3 gap-3 max-w-2xl">
          {miniBullets.map((b) => (
            <li class="flex items-center gap-2.5 text-[0.95rem] text-text-soft">
              <span aria-hidden="true" class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/15 text-accent text-[0.7rem]">✓</span>
              <span class="font-display font-medium">{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- RIGHT: real Fitchin wizard screenshot (single, no synthetic mockups) -->
      <div class="relative" aria-hidden="true">
        <div class="absolute -inset-6 bg-gradient-to-br from-accent/30 via-accent/5 to-transparent rounded-[2rem] blur-3xl opacity-60" aria-hidden="true"></div>
        <div class="relative aspect-[5/6] sm:aspect-[10/11] rounded-[1.6rem] overflow-hidden border border-accent/40 shadow-[0_30px_80px_-20px_rgba(255,107,26,0.5)] bg-surface-2">
          <img
            src="/wizard/step-3-pick-film.png"
            alt="Live screenshot of the Fitchin Tint & Detail quote wizard"
            class="absolute inset-0 w-full h-full object-cover object-top"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>
<!-- /HERO SECTION -->
