---
---
<!-- HERO SECTION -->
<section id="top" class="relative overflow-hidden border-b border-line">
  <div class="grid-bg absolute inset-0 z-0 opacity-60" aria-hidden="true"></div>
  <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-10 sm:pt-16 pb-20 sm:pb-28">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
      <!-- LEFT: copy -->
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Custom Quote &amp; Booking Systems for Service Businesses</span>

        <h1 class="mt-5 text-[2.4rem] sm:text-[3.1rem] lg:text-[3.5rem] leading-[1.04] font-bold text-text">
          Replace Your Contact Form With a
          <span class="text-accent">Quote &amp; Booking System</span>
          That Helps Sell, Schedule, and Manage the Job
        </h1>

        <p class="mt-6 max-w-[58ch] text-[1.05rem] sm:text-[1.12rem] leading-[1.6] text-text-soft">
          We build custom quote and booking systems for local service businesses — with
          <span class="text-text font-medium">package logic</span>,
          <span class="text-text font-medium">partial-lead capture</span>,
          <span class="text-text font-medium">auto text/email</span>, a
          <span class="text-text font-medium">lead dashboard</span>,
          <span class="text-text font-medium">scheduling tools</span>, and a landing page wrapped around the moment a customer is ready to act.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3">
          <a href="#apply" data-hero-cta class="btn-primary">
            Apply for a Wizard Build
            <span aria-hidden="true">↗</span>
          </a>
          <a
            href="#offers"
            class="hidden sm:inline-flex items-center gap-1.5 font-display font-medium text-[0.95rem] text-text-soft underline decoration-line-2 decoration-1 underline-offset-4 hover:text-accent hover:decoration-accent transition-colors"
          >
            Start the 14-Day Sprint
            <span aria-hidden="true">↓</span>
          </a>
        </div>

        <!-- Live trust marker -->
        <a href="https://fitchinautodetail.com" target="_blank" rel="noopener noreferrer" class="mt-8 group inline-flex items-start gap-3 max-w-2xl rounded-xl border border-accent/40 bg-accent/5 px-4 py-3.5 hover:bg-accent/10 transition-colors">
          <span class="mt-1 flex h-2.5 w-2.5 flex-shrink-0" aria-hidden="true">
            <span class="absolute inline-flex h-2.5 w-2.5 rounded-full bg-accent opacity-60 animate-ping"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent"></span>
          </span>
          <p class="text-[0.92rem] text-text leading-snug">
            <span class="font-display font-semibold text-accent uppercase tracking-[0.14em] text-[0.72rem] block mb-1">Live in production</span>
            Fitchin Automotive Detailing &amp; Window Tinting · Coshocton, OH
            <span class="text-accent group-hover:translate-x-0.5 inline-block transition-transform" aria-hidden="true">→</span>
          </p>
        </a>

        <!-- Tint routing line -->
        <div class="mt-4 flex items-start gap-3 max-w-2xl rounded-xl border border-line bg-surface-1/60 px-4 py-3.5">
          <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-accent text-bg flex-shrink-0" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </span>
          <p class="text-[0.9rem] text-text-soft leading-snug">
            <span class="text-text font-medium">Own a window tint shop?</span> Ask about
            <a href="https://tintshoplaunch.com" target="_blank" rel="noopener noreferrer" class="text-accent font-medium underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors">TintShopLaunch</a>
            — our tint-specific quote system, purpose-built for your category.
          </p>
        </div>
      </div>

      <!-- RIGHT: real Fitchin wizard screenshot.
           NOTE: The new copy calls for a side-by-side phone-wizard +
           laptop-dashboard mockup. The dashboard screenshot is not yet
           in /public — keeping the existing phone-only visual until
           dashboard-leads.png lands. -->
      <div class="relative" aria-hidden="true">
        <div class="relative mx-auto w-full max-w-[320px] sm:max-w-[340px]">
          <div class="absolute -inset-6 bg-gradient-to-br from-accent/30 via-accent/5 to-transparent rounded-[2rem] blur-3xl opacity-60" aria-hidden="true"></div>
          <div class="relative aspect-[847/1857] rounded-[1.6rem] overflow-hidden border border-accent/40 shadow-[0_30px_80px_-20px_rgba(255,107,26,0.5)] bg-surface-2 rotate-[-2deg]">
            <img
              src="/wizard/step-3-pick-film-full.png"
              alt="Live screenshot of the Fitchin quote wizard showing three tint film tiers"
              class="absolute inset-0 w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- /HERO SECTION -->
