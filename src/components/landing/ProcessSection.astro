---
// ProcessSection — How It Works (the agency's workflow).
// Each step has a custom orange line illustration in /public/icons/
// (apply / audit / build / launch). The illustrations are part of
// the brand asset set and replace the prior generic Lucide SVGs.
const steps = [
  {
    n: '01',
    icon: '/icons/apply.png',
    iconAlt: '',
    title: 'Apply',
    body: 'Tell us about your business and pick the package that fits — or let us recommend the right one.',
  },
  {
    n: '02',
    icon: '/icons/audit.png',
    iconAlt: '',
    title: 'Free Lead Leak Audit',
    body: 'We review your website, Google presence, quote flow, and lead path. You get a clear report whether you hire us or not.',
  },
  {
    n: '03',
    icon: '/icons/build.png',
    iconAlt: '',
    title: 'Build',
    body: "Once you're in as a founding client, we ship in 7–30 days depending on the package.",
  },
  {
    n: '04',
    icon: '/icons/launch.png',
    iconAlt: '',
    title: 'Launch & Improve',
    body: 'We launch, track performance, and keep optimizing the customer path.',
  },
];
---
<!-- PROCESS / HOW IT WORKS -->
<section class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Process</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        How It Works
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        Four steps from "I'm interested" to "the path is working."
      </p>
    </div>

    <ol class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((s) => (
        <li class="card p-6 relative flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <span class="font-display text-[0.78rem] tracking-[0.2em] text-accent pt-1">{s.n}</span>
            <div class="h-16 w-16 sm:h-20 sm:w-20 rounded-xl bg-accent/10 border border-accent/30 grid place-items-center flex-shrink-0">
              <img
                src={s.icon}
                alt={s.iconAlt}
                width="1254"
                height="1254"
                loading="lazy"
                decoding="async"
                class="h-12 w-12 sm:h-14 sm:w-14 object-contain"
                aria-hidden="true"
              />
            </div>
          </div>
          <h3 class="font-display font-semibold text-[1.1rem] text-text mb-2">{s.title}</h3>
          <p class="text-[0.92rem] text-text-soft leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>

    <div class="mt-12 flex flex-wrap gap-3">
      <a href="#audit-form" class="btn-primary">
        Claim My Founding 5 Spot
        <span aria-hidden="true">↗</span>
      </a>
      <a href="tel:7406176488" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call or Text Bill
      </a>
    </div>
  </div>
</section>
<!-- /PROCESS SECTION -->
