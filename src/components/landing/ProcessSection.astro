---
const steps = [
  {
    n: '01',
    icon: 'eye',
    title: 'Free Growth Audit',
    body: 'We review your website, Google presence, quote process, and lead path.',
  },
  {
    n: '02',
    icon: 'map',
    title: 'Strategy Plan',
    body: 'We map out what needs fixed first and what will make the biggest impact.',
  },
  {
    n: '03',
    icon: 'hammer',
    title: 'Build the System',
    body: 'We design and build the pages, forms, and conversion pieces your business needs.',
  },
  {
    n: '04',
    icon: 'rocket',
    title: 'Launch & Improve',
    body: 'We launch, review performance, and keep improving the customer path.',
  },
];
---
<!-- PROCESS SECTION -->
<section class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Process</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        How It Works
      </h2>
    </div>

    <ol class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((s) => (
        <li class="card p-6 relative">
          <div class="flex items-center justify-between mb-4">
            <span class="font-display text-[0.78rem] tracking-[0.2em] text-accent">{s.n}</span>
            <div class="h-9 w-9 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
              {s.icon === 'eye' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              )}
              {s.icon === 'map' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m3 6 6-2 6 2 6-2v14l-6 2-6-2-6 2Z"/><path d="M9 4v16M15 6v16"/></svg>
              )}
              {s.icon === 'hammer' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8 8a2 2 0 0 1-3-3l8-8"/><path d="M17.6 6.4 22 2l-1.4 4.4-2.4 2.4-3-3z"/></svg>
              )}
              {s.icon === 'rocket' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.7-.83.69-2.1-.05-2.85a2.07 2.07 0 0 0-2.95-.15z"/><path d="M9 12c-1-2 0-7 8-9 1 4-3 8-3 8"/><path d="M14 4c2 1 4 3 5 5"/><path d="m9 12 6 6"/></svg>
              )}
            </div>
          </div>
          <h3 class="font-display font-semibold text-[1.1rem] text-text mb-2">{s.title}</h3>
          <p class="text-[0.92rem] text-text-soft leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>

    <div class="mt-12">
      <a href="#audit-form" class="btn-primary">
        Start With a Free Audit
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>
<!-- /PROCESS SECTION -->
