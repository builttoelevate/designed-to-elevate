---
const steps = [
  {
    n: '01',
    icon: 'hand',
    title: 'Apply',
    body: 'Tell us about your business and pick the package that fits — or let us recommend the right one.',
  },
  {
    n: '02',
    icon: 'eye',
    title: 'Free Lead Leak Audit',
    body: 'We review your website, Google presence, quote flow, and lead path. You get a clear report whether you hire us or not.',
  },
  {
    n: '03',
    icon: 'hammer',
    title: 'Build',
    body: "Once you're in as a founding client, we ship in 7–30 days depending on the package.",
  },
  {
    n: '04',
    icon: 'rocket',
    title: 'Launch & Improve',
    body: 'We launch, track performance, and keep optimizing the customer path.',
  },
];
---
<!-- PROCESS / HOW IT WORKS -->
<section class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Process</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        How It Works
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        Four steps from "I'm interested" to "the path is working."
      </p>
    </div>

    <ol class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((s) => (
        <li class="card p-6 relative">
          <div class="flex items-center justify-between mb-4">
            <span class="font-display text-[0.78rem] tracking-[0.2em] text-accent">{s.n}</span>
            <div class="h-9 w-9 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
              {s.icon === 'hand' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-4 0v5"/><path d="M14 10V4a2 2 0 0 0-4 0v6"/><path d="M10 10.5V6a2 2 0 0 0-4 0v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-1.5-5.5-4L4 16"/></svg>
              )}
              {s.icon === 'eye' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              )}
              {s.icon === 'hammer' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8 8a2 2 0 0 1-3-3l8-8"/><path d="M17.6 6.4 22 2l-1.4 4.4-2.4 2.4-3-3z"/></svg>
              )}
              {s.icon === 'rocket' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.7-.83.69-2.1-.05-2.85a2.07 2.07 0 0 0-2.95-.15z"/><path d="M9 12c-1-2 0-7 8-9 1 4-3 8-3 8"/><path d="M14 4c2 1 4 3 5 5"/><path d="m9 12 6 6"/></svg>
              )}
            </div>
          </div>
          <h3 class="font-display font-semibold text-[1.1rem] text-text mb-2">{s.title}</h3>
          <p class="text-[0.92rem] text-text-soft leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>

    <div class="mt-12 flex flex-wrap gap-3">
      <a href="#audit-form" class="btn-primary">
        Claim My Founding 5 Spot
        <span aria-hidden="true">↗</span>
      </a>
      <a href="tel:7406176488" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call or Text Bill
      </a>
    </div>
  </div>
</section>
<!-- /PROCESS SECTION -->
