---
// ProcessSection — How a Wizard Build Goes.
// Reuses the four /icons/ illustrations (apply, audit, build, launch);
// "audit" maps naturally to Step 02 (Scope Call).
const steps = [
  {
    n: '01',
    icon: '/icons/apply.png',
    title: 'Apply',
    body: 'Tell us about your business, your services, and how you currently quote and book work.',
  },
  {
    n: '02',
    icon: '/icons/audit.png',
    title: 'Scope Call',
    body: '30 minutes to walk through your pricing logic, packages, and the exact questions a customer should be asked.',
  },
  {
    n: '03',
    icon: '/icons/build.png',
    title: 'Build',
    body: '21–30 days to design, build, and wire up the wizard, landing page, tracking, and lead path.',
  },
  {
    n: '04',
    icon: '/icons/launch.png',
    title: 'Launch & Iterate',
    body: "We launch, walk you through the dashboard in a 30-minute training call, watch the first quotes come through, and adjust pricing rules and copy based on what's actually converting.",
  },
];
---
<!-- PROCESS SECTION -->
<section id="process" class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Process</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        How a Wizard Build Goes
      </h2>
    </div>

    <!-- Pre-step prep note -->
    <div class="mt-8 max-w-3xl rounded-xl border border-line bg-surface-1/60 p-5">
      <div class="font-display font-semibold text-[0.74rem] uppercase tracking-[0.18em] text-accent mb-2">
        Before you apply
      </div>
      <p class="text-[0.95rem] text-text-soft leading-relaxed">
        A 5-minute prep makes the scope call faster: rough list of your services, current pricing, and a couple of typical jobs. We'll take it from there.
      </p>
    </div>

    <ol class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((s) => (
        <li class="card p-6 relative flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <span class="font-display text-[0.78rem] tracking-[0.2em] text-accent pt-1">{s.n}</span>
            <div class="h-16 w-16 sm:h-20 sm:w-20 rounded-xl bg-accent/10 border border-accent/30 grid place-items-center flex-shrink-0">
              <img
                src={s.icon}
                alt=""
                width="1254"
                height="1254"
                loading="lazy"
                decoding="async"
                class="h-12 w-12 sm:h-14 sm:w-14 object-contain"
                aria-hidden="true"
              />
            </div>
          </div>
          <h3 class="font-display font-semibold text-[1.1rem] text-text mb-2">{s.title}</h3>
          <p class="text-[0.92rem] text-text-soft leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>

    <div class="mt-12 flex flex-wrap gap-3">
      <a href="#apply" class="btn-primary">
        Apply for a Wizard Build
        <span aria-hidden="true">↗</span>
      </a>
      <a href="tel:7406176488" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call or Text Bill
      </a>
    </div>
  </div>
</section>
<!-- /PROCESS SECTION -->
