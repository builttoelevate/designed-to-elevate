---
// Reuses /customer-journey.png from the prior /grow page as the macro
// "visitor → booked job" diagram above the four wizard-stage cards.
const steps = [
  {
    num: '01',
    title: 'Build Trust',
    body: 'The page quickly answers what you do, who you help, and why they should choose you over the next shop.',
    icon: 'shield',
  },
  {
    num: '02',
    title: 'Guide the Choice',
    body: 'Instead of one vague button, customers see real packages, options, and add-ons.',
    icon: 'list',
  },
  {
    num: '03',
    title: 'Capture the Lead',
    body: 'The flow can capture contact info before the final step, so unfinished quotes still become follow-up opportunities.',
    icon: 'doc-check',
  },
  {
    num: '04',
    title: 'Move Them to Action',
    body: 'The flow points the ready buyer toward a call, text, or booking before the moment passes.',
    icon: 'cal-check',
  },
];
---
<!-- SYSTEM SECTION -->
<section id="system" class="relative border-b border-line bg-surface-1/40">
  <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8 py-24 sm:py-32">
    <div class="max-w-3xl mx-auto text-center">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The System</span>
      <h2 class="mt-7 text-[2.2rem] sm:text-[3rem] lg:text-[3.4rem] leading-[1.05] font-bold tracking-tight">
        From Visitor to <span class="text-accent">Quote Request</span> to <span class="text-accent">Booked Job</span>
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed">
        We build the page and the flow around how customers actually decide.
      </p>
    </div>

    <!-- Macro journey diagram (desktop only — labels too small on mobile). -->
    <div class="hidden md:block mt-14 mx-auto max-w-5xl">
      <img
        src="/customer-journey.png"
        alt="Customer journey diagram: the path from search to booked job"
        width="1696"
        height="624"
        loading="lazy"
        decoding="async"
        class="w-full h-auto"
      />
    </div>

    <ol class="mt-12 sm:mt-14 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((s) => (
        <li class="card p-6 sm:p-7 flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <span class="font-display text-[0.78rem] tracking-[0.2em] text-accent">{s.num}</span>
            <div class="h-10 w-10 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
              {s.icon === 'shield' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              )}
              {s.icon === 'list' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1.2" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.2" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.2" fill="currentColor" stroke="none"/></svg>
              )}
              {s.icon === 'doc-check' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 15 11 17 15 13"/></svg>
              )}
              {s.icon === 'cal-check' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/><polyline points="9 16 11 18 15 14"/></svg>
              )}
            </div>
          </div>
          <h3 class="font-display font-semibold text-[1.1rem] text-text">{s.title}</h3>
          <p class="text-[0.95rem] text-text-soft leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>

    <p class="mt-12 mx-auto max-w-2xl text-center text-text-soft text-[1rem] sm:text-[1.05rem] leading-relaxed">
      This isn't a prettier website. It's a <span class="text-accent font-medium">cleaner path from interest to action</span>.
    </p>
  </div>
</section>
<!-- /SYSTEM SECTION -->
