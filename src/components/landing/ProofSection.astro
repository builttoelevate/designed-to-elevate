---
// ProofSection — replaces LiveSiteShowcase on the new /grow.
// Reuses /showcase-phones.png (intro hero), /showcase/fitchin-mobile.png,
// and /showcase/modern-classic-mobile.png from the prior page.
const projects = [
  {
    label: 'Auto Detail · Window Tint',
    name: 'Fitchin Automotive Detailing & Window Tinting',
    url: 'https://fitchinautodetail.com',
    image: '/showcase/fitchin-mobile.png',
    summary:
      'Custom quote system built around vehicle type, tint coverage, package tiers, and add-on options.',
    bullets: [
      '378-vehicle pricing logic',
      'Tiered package structure',
      'Quote flow built around customer decisions',
      'Designed for mobile traffic and paid ads',
    ],
  },
  {
    label: 'Barbershop',
    name: 'Modern Classic Barbershop & Shave Parlor',
    url: 'https://mdrnclassic.com',
    image: '/showcase/modern-classic-mobile.png',
    summary:
      'Booking-focused brand hub built around service clarity, trust, and an easier path to scheduling.',
    bullets: [
      'Service-first page structure',
      'Mobile booking path',
      'Premium local brand presentation',
      'Built around customer action, not appearance',
    ],
  },
];
---
<!-- PROOF SECTION -->
<section id="proof" class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="grid lg:grid-cols-[1.05fr_1fr] gap-10 lg:gap-14 items-center">
      <div class="max-w-3xl">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Proof</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          See It Working in Real Local Businesses
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
          Two live projects built around the same principle: make the customer path clearer, easier, and more action-focused. Tap either to open the live site.
        </p>
      </div>

      <!-- Hero phones — Fitchin + Modern Classic mockups -->
      <div class="relative mx-auto w-full max-w-[360px] sm:max-w-[420px]">
        <div class="absolute -inset-6 bg-gradient-to-br from-accent/30 via-accent/5 to-transparent rounded-[2rem] blur-3xl opacity-60" aria-hidden="true"></div>
        <img
          src="/showcase-phones.png"
          alt="Two phones side by side displaying the live Fitchin Tint & Detail and Modern Classic Barbershop websites."
          width="768"
          height="1381"
          loading="lazy"
          decoding="async"
          class="relative w-full h-auto"
        />
      </div>
    </div>

    <div class="mt-14 sm:mt-16 grid md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <article class="card card-hover overflow-hidden flex flex-col">
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="relative block aspect-[9/16] bg-surface-2 overflow-hidden border-b border-line group/shot"
            aria-label={`Open ${p.name} in a new tab`}
          >
            <img
              src={p.image}
              alt={`${p.name} — mobile site preview`}
              class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover/shot:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
            <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-bg/80 backdrop-blur px-2.5 py-1 text-[0.65rem] font-display tracking-wider uppercase text-text-soft border border-line">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              Live · Mobile
            </span>
          </a>

          <div class="p-7 flex-1 flex flex-col">
            <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{p.label}</div>
            <h3 class="mt-2 font-display font-semibold text-[1.2rem] text-text leading-snug">{p.name}</h3>

            <p class="mt-4 text-[0.95rem] text-text-soft leading-relaxed">{p.summary}</p>

            <ul class="mt-5 space-y-2.5">
              {p.bullets.map((b) => (
                <li class="flex items-start gap-3 text-[0.9rem] text-text-soft leading-snug">
                  <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <div class="mt-7 pt-5 border-t border-line">
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost w-full"
              >
                Visit Live Site
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
<!-- /PROOF SECTION -->
