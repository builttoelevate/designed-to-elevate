---
const steps = [
  {
    n: '01',
    title: 'Get Found',
    body: 'Google Business Profile, SEO, and ads help local customers discover you.',
  },
  {
    n: '02',
    title: 'Build Trust',
    body: 'Reviews, service pages, photos, and clear messaging help them feel confident.',
  },
  {
    n: '03',
    title: 'Convert Visitor',
    body: 'Strong CTAs, landing pages, and forms guide them toward action.',
  },
  {
    n: '04',
    title: 'Increase Lead Value',
    body: 'Quote tools, packages, and add-ons help customers choose better options.',
  },
];
---
<!-- GROWTH SYSTEM / MONEY LINE -->
<section class="relative border-b border-line bg-surface-1/40">
  <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8 py-24 sm:py-32 text-center">
    <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The System</span>
    <h2 class="mt-7 text-[2.2rem] sm:text-[3.2rem] lg:text-[3.8rem] leading-[1.05] font-bold tracking-tight max-w-5xl mx-auto">
      We build the path from
      <span class="text-accent">Google search</span>
      to
      <span class="text-accent">quote request</span>
      to
      <span class="text-accent">booked job</span>.
    </h2>

    <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-3 relative">
      <!-- connector line for large screens -->
      <div class="hidden lg:block absolute top-9 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent" aria-hidden="true"></div>

      {steps.map((s) => (
        <div class="relative card p-6 text-left">
          <div class="flex items-center gap-3 mb-3">
            <span class="font-display text-[0.78rem] tracking-[0.2em] text-accent">{s.n}</span>
            <span class="h-px flex-1 bg-line"></span>
          </div>
          <h3 class="font-display font-semibold text-[1.1rem] text-text mb-2">{s.title}</h3>
          <p class="text-[0.92rem] text-text-soft leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
<!-- /GROWTH SYSTEM -->
