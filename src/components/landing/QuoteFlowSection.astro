---
// src/components/landing/QuoteFlowSection.astro
// Guided, multi-step "Build My Quote" flow for /auto-detailing-websites
// (and any other automotive quote-page that mounts this component).
// Submits through LandingLayout's global [data-audit-form] Web3Forms handler.
// Steps: service mix → product-line routing → goals → timeline+budget+contact → estimate.
//
// Pricing lives entirely in PRICING.md (single source of truth). The TIERS table
// and recommendation logic in the inline <script> below pulls from those numbers.

const ACCESS_KEY = '1272e2dd-abff-4804-a541-beb2bd0be075';

const serviceOptions = [
  { value: 'Auto detailing', label: 'Auto detailing', desc: 'Interior + exterior packages' },
  { value: 'Ceramic coating', label: 'Ceramic coating', desc: 'Crystal+, Pro+, Max G+ tiers' },
  { value: 'Window tint', label: 'Window tint', desc: 'Film tiers, per-section pricing' },
  { value: 'Paint protection film', label: 'Paint protection film', desc: 'Partial or full wraps' },
  { value: 'Something else', label: 'Something else', desc: 'Correction, wraps, more' },
];

// Step 2 — product-line routing question. Drives which tier set the shop
// sees on the estimate step. Values must match the keys used by the JS
// recommendation logic ("form" | "website" | "not-sure").
const productLineOptions = [
  {
    value: 'form',
    label: 'Just the quote wizard added to my current site',
    desc: 'Form line · starts at $997 install',
  },
  {
    value: 'website',
    label: 'A new website with the wizard built in',
    desc: 'Website line · starts at $1,497 install',
  },
  {
    value: 'not-sure',
    label: 'Not sure yet — show me both options',
    desc: 'We\'ll show you the most common pick from each line',
  },
];

const goalOptions = [
  { value: 'Price jobs by vehicle', label: 'Price jobs by vehicle', desc: 'Real estimates, not "call me"' },
  { value: "Capture leads that don't call", label: "Capture leads that don't call", desc: 'Partial quotes still land with you' },
  { value: 'Sell ceramic / coating tiers', label: 'Sell ceramic / coating tiers', desc: 'Show the upgrade gap inline' },
  { value: 'Send automatic review requests', label: 'Send automatic review requests', desc: 'SMS Google reviews after each job' },
  { value: 'Take online bookings or deposits', label: 'Take online bookings or deposits', desc: 'Customer self-serves the slot' },
  { value: 'Rank on Google locally', label: 'Rank on Google locally', desc: '"[service] in [town]" searches' },
  { value: 'Work with my booking tool', label: 'Work with my booking tool', desc: 'Square, your scheduler, your POS' },
];

const timelineOptions = [
  { value: 'As soon as possible', label: 'As soon as possible' },
  { value: 'In the next 1–2 months', label: 'In the next 1–2 months' },
  { value: 'Just exploring for now', label: 'Just exploring for now' },
];

// Budget options per product line. Step 4 renders the right set via JS based on
// the Step 2 product-line answer. Each option carries the tier it most closely
// fits so we can flag budget/goal mismatches on Step 5.
// All ranges and tier mappings track PRICING.md exactly.
const budgetSets = {
  form: [
    { value: '$0.5k–$1k', label: '$0.5k–$1k', fitsTier: 'form_t1' },
    { value: '$1k–$2k',   label: '$1k–$2k',   fitsTier: 'form_t2' },
    { value: '$2k–$3k',   label: '$2k–$3k',   fitsTier: 'form_t3' },
    { value: 'Not sure yet', label: 'Not sure yet' },
  ],
  website: [
    { value: '$1k–$2k', label: '$1k–$2k', fitsTier: 'web_t1' },
    { value: '$2k–$3k', label: '$2k–$3k', fitsTier: 'web_t2' },
    { value: '$3k–$5k', label: '$3k–$5k', fitsTier: 'web_t3' },
    { value: 'Not sure yet', label: 'Not sure yet' },
  ],
  // "Not sure" routing shows both Form T2 + Website T2 side-by-side at the end,
  // so the budget set here covers both ladders' midpoints + the wider range.
  'not-sure': [
    { value: '$1k–$2k', label: '$1k–$2k' },
    { value: '$2k–$3k', label: '$2k–$3k' },
    { value: '$3k–$5k', label: '$3k–$5k' },
    { value: 'Not sure yet', label: 'Not sure yet' },
  ],
};
// The Step 4 markup renders one set as the initial paint (Form, matching the
// most common entry). JS swaps it on Step 2 change. The schema lives in JSON
// so the script reads from the same source as the server-rendered fallback.
const budgetSetsJson = JSON.stringify(budgetSets);

// shared class strings
const cardCls = 'group relative flex items-start gap-3 rounded-xl border border-line bg-surface-1/40 p-4 cursor-pointer transition-colors hover:border-accent/50 has-[input:checked]:border-accent has-[input:checked]:bg-accent/10 has-[input:focus-visible]:ring-2 has-[input:focus-visible]:ring-accent/60 has-[input:focus-visible]:ring-offset-2 has-[input:focus-visible]:ring-offset-bg';
const tickCls = 'mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-line text-bg opacity-30 transition-all group-has-[input:checked]:opacity-100 group-has-[input:checked]:bg-accent group-has-[input:checked]:border-accent';
const inputCls = 'w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60';
const check = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
---
<section id="quote" data-quote-flow class="relative z-10 bg-bg border-b border-line scroll-mt-24">
  <div class="mx-auto max-w-3xl px-5 sm:px-8 py-20 sm:py-24">
    <div class="max-w-2xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Build My Estimate</span>
      <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
        Build my ballpark estimate <span class="text-accent">— in about 60 seconds.</span>
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        Same flow we'd build for your shop. Tap through a few questions and you'll see the build tier that fits, with a real price range — then Bill prices it around your exact menu within 24 hours.
      </p>
    </div>

    <div class="card p-6 sm:p-8 mt-10 scroll-mt-4" data-quote-card>
      <noscript>
        <div class="mb-6 rounded-xl border border-accent/40 bg-accent/[0.06] p-4 text-[0.92rem] text-text-soft leading-relaxed">
          This quote builder needs JavaScript turned on. To get a ballpark quote right now, call or text Bill at
          <a href="tel:7406176488" class="text-accent font-medium underline underline-offset-4">(740) 617-6488</a>.
        </div>
      </noscript>
      <div data-steps-wrap>
        <!-- progress -->
        <div class="mb-8">
          <div class="flex items-center justify-between text-[0.8rem] font-display text-text-muted mb-2">
            <span data-step-label aria-live="polite">Step 1 of 5</span>
            <span>About 60 seconds</span>
          </div>
          <div data-progress-track role="progressbar" aria-valuemin="1" aria-valuemax="5" aria-valuenow="1" aria-label="Quote builder progress" class="h-1.5 w-full rounded-full bg-surface-2 overflow-hidden">
            <div data-progress-bar class="h-full bg-accent transition-[width] duration-300" style="width:20%"></div>
          </div>
        </div>

        <form
          data-audit-form
          data-quote-form
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value={ACCESS_KEY} />
          <input type="hidden" name="subject" value="New Detailing Website Quote Request — Designed to Elevate" />
          <input type="hidden" name="source" value="auto-detailing-websites quote flow" />
          <input type="hidden" name="recommended_build" value="" />
          <input type="hidden" name="recommended_tier_id" value="" />
          <input type="hidden" name="budget_fit_note" value="" />
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

          <!-- STEP 1 — services -->
          <div data-step="1">
            <h3 class="font-display font-semibold text-[1.2rem] text-text">Which of these does your shop do?</h3>
            <p class="mt-1.5 text-[0.92rem] text-text-soft">Pick all that apply — the quote engine adapts to what you offer.</p>
            <div class="mt-5 grid sm:grid-cols-2 gap-3">
              {serviceOptions.map((o) => (
                <label class={cardCls}>
                  <input type="checkbox" name="services[]" value={o.value} class="sr-only" />
                  <span class={tickCls} set:html={check} />
                  <span class="min-w-0">
                    <span class="block font-display font-semibold text-[0.95rem] text-text">{o.label}</span>
                    <span class="block text-[0.83rem] text-text-soft leading-snug">{o.desc}</span>
                  </span>
                </label>
              ))}
            </div>
            <p data-error role="alert" class="hidden mt-4 text-[0.85rem] text-[#F87171]">Pick at least one to continue.</p>
            <div class="mt-6 flex justify-end">
              <button type="button" data-next class="btn-primary">Continue <span aria-hidden="true">→</span></button>
            </div>
          </div>

          <!-- STEP 2 — product-line routing.
               This is what drives which tier set the shop sees on Step 5.
               "form" = add wizard to existing site · "website" = build new site too
               · "not-sure" = show both T2s side-by-side. Per checklist §15. -->
          <div data-step="2" class="hidden">
            <h3 class="font-display font-semibold text-[1.2rem] text-text">What do you need from us?</h3>
            <p class="mt-1.5 text-[0.92rem] text-text-soft">This sets which product line we ballpark against.</p>
            <div class="mt-5 grid gap-3">
              {productLineOptions.map((o) => (
                <label class={cardCls}>
                  <input type="radio" name="product_line" value={o.value} class="sr-only" />
                  <span class={tickCls} set:html={check} />
                  <span class="min-w-0">
                    <span class="block font-display font-semibold text-[0.95rem] text-text">{o.label}</span>
                    <span class="block text-[0.83rem] text-text-soft leading-snug">{o.desc}</span>
                  </span>
                </label>
              ))}
            </div>
            <p data-error role="alert" class="hidden mt-4 text-[0.85rem] text-[#F87171]">Pick one to continue.</p>
            <div class="mt-6 flex items-center justify-between gap-3">
              <button type="button" data-back class="btn-ghost"><span aria-hidden="true">←</span> Back</button>
              <button type="button" data-next class="btn-primary">Continue <span aria-hidden="true">→</span></button>
            </div>
          </div>

          <!-- STEP 3 — goals -->
          <div data-step="3" class="hidden">
            <h3 class="font-display font-semibold text-[1.2rem] text-text">What should the site actually do?</h3>
            <p class="mt-1.5 text-[0.92rem] text-text-soft">Pick all that matter — this shapes the build.</p>
            <div class="mt-5 grid sm:grid-cols-2 gap-3">
              {goalOptions.map((o) => (
                <label class={cardCls}>
                  <input type="checkbox" name="goals[]" value={o.value} class="sr-only" />
                  <span class={tickCls} set:html={check} />
                  <span class="min-w-0">
                    <span class="block font-display font-semibold text-[0.95rem] text-text">{o.label}</span>
                    <span class="block text-[0.83rem] text-text-soft leading-snug">{o.desc}</span>
                  </span>
                </label>
              ))}
            </div>
            <p data-error role="alert" class="hidden mt-4 text-[0.85rem] text-[#F87171]">Pick at least one to continue.</p>
            <div class="mt-6 flex items-center justify-between gap-3">
              <button type="button" data-back class="btn-ghost"><span aria-hidden="true">←</span> Back</button>
              <button type="button" data-next class="btn-primary">Continue <span aria-hidden="true">→</span></button>
            </div>
          </div>

          <!-- STEP 4 — timeline + budget + contact.
               Contact lives here (a step BEFORE the estimate reveal) so that when
               the user advances to step 5, we fire a partial-lead submission with
               their contact info — every abandon after this point still lands in
               the dashboard. -->
          <div data-step="4" class="hidden">
            <h3 class="font-display font-semibold text-[1.2rem] text-text">Last few — then your estimate.</h3>
            <p class="mt-1.5 text-[0.92rem] text-text-soft">Timeline, budget, and where to send your detailed quote. Ballparks are fine.</p>

            <div class="mt-5">
              <div class="font-display text-[0.74rem] uppercase tracking-[0.18em] text-accent mb-2">When do you want it live?</div>
              <div class="grid sm:grid-cols-3 gap-3">
                {timelineOptions.map((o) => (
                  <label class={cardCls}>
                    <input type="radio" name="timeline" value={o.value} class="sr-only" />
                    <span class={tickCls} set:html={check} />
                    <span class="block font-display font-semibold text-[0.92rem] text-text">{o.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="mt-6">
              <div class="font-display text-[0.74rem] uppercase tracking-[0.18em] text-accent mb-2" data-budget-label>Budget you're working with?</div>
              <!-- Budget options are rendered by JS from `budgetSets` on Step 4 entry
                   based on the Step 2 product_line choice. The server-side render is
                   the Form-line set as a no-JS fallback. -->
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" data-budget-options>
                {budgetSets.form.map((o) => (
                  <label class={cardCls}>
                    <input type="radio" name="budget" value={o.value} class="sr-only" data-fits-tier={o.fitsTier || ''} />
                    <span class={tickCls} set:html={check} />
                    <span class="block font-display font-semibold text-[0.92rem] text-text">{o.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="mt-7 border-t border-line pt-7">
              <div class="font-display text-[0.74rem] uppercase tracking-[0.18em] text-accent mb-3">Where should Bill send your detailed quote?</div>

              <div class="grid sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Your name <span class="text-accent">*</span></span>
                  <input required name="name" type="text" autocomplete="name" class={inputCls} placeholder="Your name" />
                </label>
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Shop name <span class="text-text-muted text-[0.78rem] font-normal">(optional)</span></span>
                  <input name="business" type="text" autocomplete="organization" class={inputCls} placeholder="Acme Auto Detail" />
                </label>
              </div>
              <div class="mt-4 grid sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Phone <span class="text-accent">*</span></span>
                  <input required name="phone" type="tel" autocomplete="tel" class={inputCls} placeholder="(555) 555-5555" />
                </label>
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Email <span class="text-text-muted text-[0.78rem] font-normal">(optional)</span></span>
                  <input name="email" type="email" autocomplete="email" class={inputCls} placeholder="you@yourshop.com" />
                </label>
              </div>
              <p class="mt-3 text-[0.78rem] text-text-muted leading-relaxed">
                No spam, no list-selling. Bill replies within 24 hours.
              </p>
            </div>

            <p data-error role="alert" class="hidden mt-4 text-[0.85rem] text-[#F87171]">Add your name and phone, and pick a timeline and budget to continue.</p>
            <div class="mt-6 flex items-center justify-between gap-3">
              <button type="button" data-back class="btn-ghost"><span aria-hidden="true">←</span> Back</button>
              <button type="button" data-next class="btn-primary">See my estimate <span aria-hidden="true">→</span></button>
            </div>
          </div>

          <!-- STEP 5 — estimate reveal + final submit.
               Contact has already been captured at step 4 and a partial submission
               has already fired, so even if the user bails here, their info lands
               in the dashboard. The final submit just upgrades that record.
               Two display modes:
                 - SINGLE: one tier card (form or website routing)
                 - DUAL: Form T2 + Website T2 side-by-side (not-sure routing) -->
          <div data-step="5" data-estimate-step class="hidden">

            <!-- SINGLE-tier panel (form OR website routing). Install price only;
                 see PRICING.md INTERNAL for what ships ongoing. -->
            <div data-estimate-single class="rounded-xl border border-accent/40 bg-accent/5 p-5 sm:p-6">
              <div class="flex items-center justify-between gap-2 flex-wrap">
                <div class="font-display text-[0.74rem] uppercase tracking-[0.18em] text-accent">Your ballpark</div>
                <div class="font-display text-[0.7rem] uppercase tracking-[0.16em] text-text-muted" data-rec-line>—</div>
              </div>
              <h3 class="mt-2 font-display font-bold text-[1.3rem] text-text leading-snug">
                Your shop looks like a fit for the <span data-rec-build class="text-accent">Quote Site</span>.
              </h3>
              <div class="mt-2 font-display font-bold text-[1.25rem] text-text">
                <span data-rec-price>Ballpark: $2,497 install — one-time</span>
              </div>
              <p class="mt-1 text-[0.92rem] text-text-soft">
                You own everything. No required monthly.
              </p>
              <p data-rec-blurb class="mt-3 text-text-soft text-[0.95rem] leading-relaxed">
                Everything in T1, plus the full quote wizard built into the site.
              </p>
              <ul data-rec-features class="mt-4 space-y-2 text-[0.92rem] text-text"></ul>

              <!-- Budget-fit note: shown when the budget answer doesn't match the
                   goal-recommended tier. JS swaps in the closest-fit prose. -->
              <div data-budget-fit-note class="hidden mt-4 rounded-lg border border-line bg-bg/40 p-3 text-[0.88rem] text-text-soft leading-relaxed">
                <!-- text injected by JS -->
              </div>

              <p class="mt-4 text-[0.8rem] text-text-muted italic leading-relaxed">
                Ballpark, not a contract. Bill will price the final build around your exact services, menu, add-ons, and quote logic before you commit.
              </p>
            </div>

            <!-- DUAL-tier panel (not-sure routing — shows Form T2 + Website T2).
                 Install only, same as single panel. -->
            <div data-estimate-dual class="hidden">
              <div class="font-display text-[0.74rem] uppercase tracking-[0.18em] text-accent mb-3">Your two most-likely picks</div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div class="rounded-xl border border-line bg-surface-1/40 p-5">
                  <div class="font-display text-[0.7rem] uppercase tracking-[0.16em] text-text-muted">Form line · keep your site</div>
                  <h4 class="mt-1 font-display font-bold text-[1.1rem] text-text">Quote + Reviews</h4>
                  <div class="mt-3 font-display font-bold text-[1.05rem] text-text">$1,497 install — one-time</div>
                  <p class="mt-1 text-[0.88rem] text-text-soft">You own everything. No required monthly.</p>
                  <p class="mt-3 text-[0.9rem] text-text-soft leading-relaxed">
                    The wizard added to your current site, plus automated SMS Google-review requests after each job.
                  </p>
                </div>
                <div class="rounded-xl border border-accent/40 bg-accent/[0.06] p-5">
                  <div class="font-display text-[0.7rem] uppercase tracking-[0.16em] text-accent">Website line · build new</div>
                  <h4 class="mt-1 font-display font-bold text-[1.1rem] text-text">Quote Site</h4>
                  <div class="mt-3 font-display font-bold text-[1.05rem] text-text">$2,497 install — one-time</div>
                  <p class="mt-1 text-[0.88rem] text-text-soft">You own everything. No required monthly.</p>
                  <p class="mt-3 text-[0.9rem] text-text-soft leading-relaxed">
                    Full new site with the wizard built in. The Fitchin starting point.
                  </p>
                </div>
              </div>
              <p class="mt-4 text-[0.86rem] text-text-muted italic leading-relaxed">
                Bill will help you pick the right one on the call — ballparks, not contracts.
              </p>
            </div>

            <p class="mt-6 text-text-soft text-[0.97rem] leading-relaxed">
              Want a real quote, priced to your menu? Hit send and Bill will review your services, goals, and quote-flow needs, then reply within 24 hours with the next best step.
            </p>

            <div class="mt-6 flex items-center justify-between gap-3">
              <button type="button" data-back class="btn-ghost"><span aria-hidden="true">←</span> Back</button>
              <button type="submit" class="btn-primary">Send my detailed quote <span aria-hidden="true">↗</span></button>
            </div>

            <p data-audit-status class="hidden mt-4 text-[0.92rem] text-accent font-display font-medium items-center gap-2" role="status" aria-live="polite"></p>
            <p class="mt-4 text-[0.78rem] text-text-muted leading-relaxed">
              No spam, no list-selling, no long sales calls.
            </p>
          </div>
        </form>
      </div>

      <!-- confirmation (revealed on submit success) -->
      <div data-quote-done class="hidden text-center py-4">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-accent/15 text-accent" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 class="font-display font-bold text-[1.4rem] text-text">Quote request sent.</h3>
        <p class="mt-3 text-text-soft text-[1rem] leading-relaxed max-w-md mx-auto">
          Bill will review your services, goals, and quote flow needs, then reach out within 24 hours with the next best step. If it looks like a fit, he'll price the build around your exact menu and booking process. Want to talk now? Call or text directly.
        </p>
        <a href="tel:7406176488" class="btn-ghost mt-6">Call / Text Bill <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </div>

  <script define:vars={{ budgetSetsJson, cardCls }}>
    (() => {
      const root = document.querySelector('[data-quote-flow]');
      if (!root) return;
      const form = root.querySelector('[data-quote-form]');
      const card = root.querySelector('[data-quote-card]');
      const steps = Array.from(root.querySelectorAll('[data-step]'));
      const bar = root.querySelector('[data-progress-bar]');
      const barTrack = root.querySelector('[data-progress-track]');
      const label = root.querySelector('[data-step-label]');
      const total = steps.length;
      let current = 0;

      // Pricing tiers — pulled from PRICING.md → PUBLIC. Install price only;
      // see PRICING.md → INTERNAL for what ships ongoing.
      const TIERS = {
        form_t1: {
          id: 'form_t1', line: 'form', code: 'T1',
          name: 'Quote',
          setup: '$997',
          blurb: 'The wizard added to your current site. Customer gets a real price, the lead hits your dashboard, you schedule it manually.',
        },
        form_t2: {
          id: 'form_t2', line: 'form', code: 'T2',
          name: 'Quote + Reviews',
          setup: '$1,497',
          blurb: 'Everything in T1, plus automated SMS Google-review requests after every job (skips no-shows).',
        },
        form_t3: {
          id: 'form_t3', line: 'form', code: 'T3',
          name: 'Quote + Booking',
          setup: '$2,497',
          blurb: 'Everything in T2, plus the customer books their own slot online — runs on autopilot.',
        },
        web_t1: {
          id: 'web_t1', line: 'website', code: 'T1',
          name: 'Starter Site',
          setup: '$1,497',
          blurb: 'New custom site + a smart lead-capture form. The foundation — easy to upgrade to the full quote system later.',
        },
        web_t2: {
          id: 'web_t2', line: 'website', code: 'T2',
          name: 'Quote Site',
          setup: '$2,497',
          blurb: 'Everything in T1, plus the full quote wizard built into the site. The Fitchin starting point.',
        },
        web_t3: {
          id: 'web_t3', line: 'website', code: 'T3',
          name: 'The Works',
          setup: '$4,497',
          blurb: 'Everything Fitchin has — T2 plus automated SMS review requests and customer self-service booking. The whole system, on autopilot.',
        },
      };

      const LINE_LABEL = { form: 'Form line · keep your site', website: 'Website line · build new' };
      const budgetSets = JSON.parse(budgetSetsJson);

      // Pick the recommended tier from goals, scoped to the routed product line.
      // Logic mirrors checklist §15.
      const recommendFromGoals = (line, goals) => {
        const has = (g) => goals.includes(g);
        if (line === 'form') {
          if (has('Take online bookings or deposits')) return TIERS.form_t3;
          if (has('Send automatic review requests')) return TIERS.form_t2;
          return TIERS.form_t1;
        }
        // website
        if (has('Take online bookings or deposits')) return TIERS.web_t3;
        const t2Triggers = [
          'Price jobs by vehicle',
          "Capture leads that don't call",
          'Sell ceramic / coating tiers',
          'Send automatic review requests',
        ];
        if (goals.some((g) => t2Triggers.includes(g))) return TIERS.web_t2;
        // Floor the website line at the Quote Site (web_t2): the visitor chose
        // "a new website WITH the wizard built in", so never recommend the
        // Starter Site (web_t1), which has no quote wizard — that would
        // contradict both their Step-2 choice and the whole page's promise.
        return TIERS.web_t2;
      };

      // Translate the user's budget answer into the tier that range fits, by
      // walking the budget set for the routed line and reading data-fits-tier.
      const fitTierFromBudget = (line, budgetValue) => {
        if (!budgetValue || budgetValue === 'Not sure yet') return null;
        const set = budgetSets[line] || [];
        const hit = set.find((b) => b.value === budgetValue);
        return hit && hit.fitsTier ? TIERS[hit.fitsTier] : null;
      };

      // Build the budget-fit note shown inside the estimate panel. Returns ''
      // when goal-recommended tier matches budget-fit tier (or budget is "not sure").
      const budgetFitNote = (recTier, budgetTier) => {
        if (!budgetTier || recTier.id === budgetTier.id) return '';
        // Compare positions on the tier ladder of the routed line.
        const ladder = recTier.line === 'form' ? ['form_t1', 'form_t2', 'form_t3'] : ['web_t1', 'web_t2', 'web_t3'];
        const ri = ladder.indexOf(recTier.id);
        const bi = ladder.indexOf(budgetTier.id);
        if (bi < ri) {
          return 'Heads up: your goals point to the ' + recTier.name + ' tier (' + recTier.setup + '), but your budget range fits the ' + budgetTier.name + ' tier (' + budgetTier.setup + '). Two ways to close that gap — trim the scope to fit the smaller tier, or stretch the budget. Bill will walk through both on the call.';
        }
        return 'Good news: your budget gives you room to upgrade. The ' + budgetTier.name + ' tier (' + budgetTier.setup + ') is one step above the ' + recTier.name + ' fit for your goals — happy to spec what the extra buys you.';
      };

      // Step 4 budget options — render the correct set for the routed line.
      // Called whenever Step 2 changes OR when we enter Step 4.
      const renderBudgetOptions = () => {
        const line = (form.querySelector('[name="product_line"]:checked') || {}).value || 'form';
        const container = root.querySelector('[data-budget-options]');
        if (!container) return;
        const set = budgetSets[line] || budgetSets.form;
        container.innerHTML = '';
        set.forEach((opt) => {
          const lbl = document.createElement('label');
          // Reuse the shared cardCls (same as every server-rendered option group)
          // so the JS-rebuilt budget tiles keep the keyboard focus-visible ring.
          lbl.className = cardCls;
          lbl.innerHTML =
            '<input type="radio" name="budget" value="' + opt.value + '" class="sr-only" data-fits-tier="' + (opt.fitsTier || '') + '" />' +
            '<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-line text-bg opacity-30 transition-all group-has-[input:checked]:opacity-100 group-has-[input:checked]:bg-accent group-has-[input:checked]:border-accent">' +
            '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
            '</span>' +
            '<span class="block font-display font-semibold text-[0.92rem] text-text">' + opt.label + '</span>';
          container.appendChild(lbl);
        });
      };

      // Render Step 5 — either the single-tier panel or the dual-tier ("not-sure") panel.
      const buildEstimate = () => {
        const picked = (name) => Array.from(form.querySelectorAll('[name="' + name + '"]:checked')).map((i) => i.value);
        const goals = picked('goals[]');
        const services = picked('services[]');
        const line = (form.querySelector('[name="product_line"]:checked') || {}).value || 'form';
        const budgetEl = form.querySelector('[name="budget"]:checked');
        const budgetValue = budgetEl ? budgetEl.value : '';

        const single = root.querySelector('[data-estimate-single]');
        const dual = root.querySelector('[data-estimate-dual]');

        if (line === 'not-sure') {
          // Dual: show the canonical T2 from each line side by side.
          if (single) single.classList.add('hidden');
          if (dual) dual.classList.remove('hidden');
          const hidden = form.querySelector('[name="recommended_build"]');
          if (hidden) hidden.value = 'Not sure — showing Form T2 ($1,497 install) and Website T2 ($2,497 install)' + (services.length ? ' · Services: ' + services.join(', ') : '');
          const tierIdField = form.querySelector('[name="recommended_tier_id"]');
          if (tierIdField) tierIdField.value = 'not_sure_dual';
          const fitNoteField = form.querySelector('[name="budget_fit_note"]');
          if (fitNoteField) fitNoteField.value = '';
          return;
        }

        // Single: render the goal-recommended tier from the routed line.
        if (single) single.classList.remove('hidden');
        if (dual) dual.classList.add('hidden');

        const recTier = recommendFromGoals(line, goals);
        const budgetTier = fitTierFromBudget(line, budgetValue);
        const fitNote = budgetFitNote(recTier, budgetTier);

        const setText = (sel, txt) => { const el = root.querySelector(sel); if (el) el.textContent = txt; };
        setText('[data-rec-line]', LINE_LABEL[recTier.line]);
        setText('[data-rec-build]', recTier.name);
        // Install-only ballpark — any ongoing-fee conversation is handled on the call.
        setText('[data-rec-price]', 'Ballpark: ' + recTier.setup + ' install — one-time');
        setText('[data-rec-blurb]', recTier.blurb);

        // Features list = the user's selected goals (with fallback default).
        const ul = root.querySelector('[data-rec-features]');
        if (ul) {
          ul.innerHTML = '';
          (goals.length ? goals : ["Capture leads that don't call"]).forEach((g) => {
            const li = document.createElement('li');
            li.className = 'flex items-start gap-2.5';
            li.innerHTML = '<span class="mt-0.5 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-accent/20 text-accent"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span><span>' + g + '</span>';
            ul.appendChild(li);
          });
        }

        // Budget-fit note: shown only when the budget doesn't match the goal-tier.
        const noteEl = root.querySelector('[data-budget-fit-note]');
        if (noteEl) {
          if (fitNote) {
            noteEl.textContent = fitNote;
            noteEl.classList.remove('hidden');
          } else {
            noteEl.textContent = '';
            noteEl.classList.add('hidden');
          }
        }

        // Hidden fields for the email payload — install price + tier id only.
        // PRICING.md INTERNAL maps the tier id to its ongoing-fee structure for Bill.
        const hidden = form.querySelector('[name="recommended_build"]');
        if (hidden) {
          hidden.value = recTier.line + ' line · ' + recTier.name + ' (' + recTier.code + ') — ' + recTier.setup + ' install' + (services.length ? ' · Services: ' + services.join(', ') : '');
        }
        const tierIdField = form.querySelector('[name="recommended_tier_id"]');
        if (tierIdField) tierIdField.value = recTier.id;
        const fitNoteField = form.querySelector('[name="budget_fit_note"]');
        if (fitNoteField) fitNoteField.value = fitNote;
      };

      // Re-render budget options whenever product line changes (Step 2 answer changes).
      form.querySelectorAll('[name="product_line"]').forEach((r) => {
        r.addEventListener('change', renderBudgetOptions);
      });

      const show = (i, scroll) => {
        steps.forEach((s, idx) => s.classList.toggle('hidden', idx !== i));
        current = i;
        if (bar) bar.style.width = (((i + 1) / total) * 100) + '%';
        if (barTrack) barTrack.setAttribute('aria-valuenow', String(i + 1));
        if (label) label.textContent = 'Step ' + (i + 1) + ' of ' + total;
        // Re-render budget options on entry to the step that contains them, so
        // back-navigation that changes the product line picks up the right set.
        if (steps[i].querySelector('[data-budget-options]')) renderBudgetOptions();
        if (steps[i].hasAttribute('data-estimate-step')) buildEstimate();
        // Per-step funnel analytics — one event per step entry. Safe no-op until
        // a GA4/GTM container consumes the dataLayer.
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'quote_step', step: i + 1, total: total });
        if (scroll) {
          (card || root).scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Move focus into the new step so keyboard users land on the new
          // content and screen readers announce it (focus would otherwise fall
          // to <body> once the previous step's button is hidden). Prefer the
          // first VISIBLE heading; fall back to the step container.
          let target = steps[i];
          steps[i].querySelectorAll('h3').forEach((h) => {
            if (target === steps[i] && h.offsetParent !== null) target = h;
          });
          target.setAttribute('tabindex', '-1');
          target.focus({ preventScroll: true });
        }
      };

      const stepValid = (stepEl) => {
        // Required checkboxes/radios: every named group must have at least one checked.
        const choosers = stepEl.querySelectorAll('input[type="checkbox"], input[type="radio"]');
        const groups = {};
        choosers.forEach((c) => { (groups[c.name] = groups[c.name] || []).push(c); });
        const choosersOk = Object.values(groups).every((g) => g.some((c) => c.checked));

        // Required text/tel inputs (name + phone): must be non-empty and valid.
        const requiredInputs = stepEl.querySelectorAll('input[required]');
        const inputsOk = Array.from(requiredInputs).every((el) => el.value.trim() !== '' && el.checkValidity());

        // Email is optional — only enforce a valid format if one was actually typed.
        const emailEl = stepEl.querySelector('input[type="email"]');
        const emailOk = !emailEl || emailEl.value.trim() === '' || emailEl.checkValidity();

        return choosersOk && inputsOk && emailOk;
      };

      // Partial-lead capture: when the user clears step 4 (which collects contact + timeline + budget),
      // fire a fire-and-forget submission to Web3Forms so the lead lands in the dashboard even if
      // they bail at the estimate reveal. The final submit on step 5 then upgrades the record.
      let partialSentAt = 0;
      const firePartial = () => {
        if (Date.now() - partialSentAt < 30000) return; // de-dupe rapid back/forth
        try {
          const fd = new FormData(form);
          fd.set('subject', '[PARTIAL] Detailing Website Quote — Lead Captured Before Final Step');
          fd.set('lead_state', 'partial');
          fetch('https://api.web3forms.com/submit', { method: 'POST', body: fd }).catch(() => {});
          partialSentAt = Date.now();
          // Funnel analytics — partial lead captured (no-op until a GA4/GTM container loads).
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'quote_partial_lead' });
        } catch (_) { /* silent — never block UX on telemetry */ }
      };

      root.querySelectorAll('[data-next]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const stepEl = steps[current];
          const err = stepEl.querySelector('[data-error]');
          if (!stepValid(stepEl)) { if (err) err.classList.remove('hidden'); return; }
          if (err) err.classList.add('hidden');
          // Fire partial on the transition into the estimate step (i.e., leaving step 4 → step 5).
          // Compute the recommendation FIRST so the [PARTIAL] email already carries
          // the recommended tier/build, not just name+phone. show() re-runs
          // buildEstimate() on entry to step 5 — calling it here too is harmless.
          if (steps[current + 1] && steps[current + 1].hasAttribute('data-estimate-step')) {
            buildEstimate();
            firePartial();
          }
          if (current < total - 1) show(current + 1, true);
        });
      });

      root.querySelectorAll('[data-back]').forEach((btn) => {
        btn.addEventListener('click', () => { if (current > 0) show(current - 1, true); });
      });

      document.addEventListener('audit-form:success', () => {
        const wrap = root.querySelector('[data-steps-wrap]');
        const done = root.querySelector('[data-quote-done]');
        if (wrap) wrap.classList.add('hidden');
        if (done) done.classList.remove('hidden');
        (card || root).scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      show(0, false);
    })();
  </script>
</section>
