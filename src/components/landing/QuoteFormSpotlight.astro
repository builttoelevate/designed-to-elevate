---
const features = [
  { title: 'Package Pricing', body: 'Show tiered packages with clear differences instead of one boring "request a quote" button.' },
  { title: 'Smart Add-Ons', body: 'Upsell ceramic coatings, premium tints, or extra services with a click — not a phone call.' },
  { title: 'Instant Quote Logic', body: 'Customers get a real number on the spot, so they don\'t shop around while waiting.' },
  { title: 'Lead Capture', body: 'Every step captures name, phone, and intent — so even half-finished quotes are leads.' },
  { title: 'Booking Options', body: 'Let customers book the appointment right after the quote, before the moment passes.' },
  { title: 'Custom-Built', body: 'Designed around your services, your packaging, and the questions your business actually needs to ask.' },
];
---
<!-- QUOTE FORM SPOTLIGHT -->
<section class="relative border-b border-line bg-surface-1/40">
  <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-24 sm:py-32">
    <div class="grid lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-16 items-start">
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Signature Tool</span>
        <h2 class="mt-5 text-[2.1rem] sm:text-[2.9rem] leading-[1.05] font-bold">
          Turn Your Quote Form Into a <span class="text-accent">Sales Tool</span>
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed max-w-2xl">
          Most forms collect names and phone numbers. A custom quote tool can guide customers, calculate pricing, show service options, and help upsell higher-value packages.
        </p>

        <div class="mt-10 grid sm:grid-cols-2 gap-4">
          {features.map((f) => (
            <div class="rounded-xl border border-line bg-surface-2 p-5">
              <div class="flex items-center gap-2.5 mb-2">
                <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                <h3 class="font-display font-semibold text-[1rem] text-text">{f.title}</h3>
              </div>
              <p class="text-[0.88rem] text-text-soft leading-relaxed">{f.body}</p>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a href="#audit-form" class="btn-primary">
            I Want a Quote Form Like This
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <!-- Right: real Fitchin wizard screenshots, layered to tell the
           guide → upsell → close story (Step 1 → upsell tiers → final quote) -->
      <div class="relative" aria-hidden="true">
        <div class="absolute -inset-4 bg-gradient-to-br from-accent/40 via-accent/10 to-transparent rounded-[2rem] blur-3xl opacity-50" aria-hidden="true"></div>

        <div class="relative aspect-[5/6] sm:aspect-[5/5.5]">
          <!-- Back card: Step 1 — service selection (the "guide" moment) -->
          <div class="absolute top-0 left-0 w-[58%] aspect-[10/13] rotate-[-4deg] origin-bottom-right rounded-[1.6rem] overflow-hidden border border-line shadow-2xl bg-surface-2">
            <img
              src="/wizard/step-1-service.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Front card: Step 3 — pick tint film (the upsell moment) -->
          <div class="absolute top-[6%] right-0 w-[64%] aspect-[10/13] rotate-[3deg] rounded-[1.6rem] overflow-hidden border border-accent/40 shadow-[0_30px_80px_-20px_rgba(255,107,26,0.45)] bg-surface-2">
            <img
              src="/wizard/step-3-pick-film.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Bottom card: final quote with $ total (the "close" moment) -->
          <div class="absolute bottom-0 left-[6%] w-[60%] aspect-[10/13] rotate-[-2deg] rounded-[1.6rem] overflow-hidden border border-line shadow-2xl bg-surface-2">
            <img
              src="/wizard/step-6-final-quote.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Floating outcome chip -->
          <div class="absolute bottom-[6%] right-[2%] card px-3.5 py-2.5 flex items-center gap-3 rotate-[3deg]">
            <div class="h-8 w-8 rounded-full bg-accent grid place-items-center text-bg font-display font-bold text-[0.85rem]">$</div>
            <div class="leading-tight">
              <div class="font-display font-semibold text-[0.78rem] text-text">Quote: $674.10</div>
              <div class="text-[0.65rem] text-text-muted">Booked online · just now</div>
            </div>
          </div>
        </div>

        <p class="mt-4 text-center text-[0.7rem] uppercase tracking-[0.18em] text-text-muted/70 not-sr-only" aria-hidden="true">
          Real Fitchin wizard · live at fitchin-website.vercel.app
        </p>
      </div>
    </div>
  </div>
</section>
<!-- /QUOTE FORM SPOTLIGHT -->
