---
const services = [
  {
    id: 'service-website',
    icon: 'monitor',
    title: 'Conversion-Focused Websites',
  },
  {
    id: 'service-gbp',
    icon: 'map',
    title: 'Google Business Profile Optimization',
  },
  {
    id: 'service-quote-forms',
    icon: 'quote',
    title: 'Custom Quote Forms',
    featured: true,
  },
  {
    id: 'service-landing-pages',
    icon: 'target',
    title: 'Google Ads Landing Pages',
  },
  {
    id: 'service-seo',
    icon: 'search',
    title: 'Local SEO',
  },
];
---
<!-- CORE SERVICES SECTION -->
<section class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The System</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        The Local Growth System We Build
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        Everything is designed to work together: your website, Google presence, quote process, landing pages, ads, and SEO.
      </p>
    </div>

    <div class="mt-12 grid lg:grid-cols-12 gap-5">
      {services.map((s) => {
        const isFeatured = s.featured === true;
        const cardClasses = isFeatured
          ? 'lg:col-span-12 relative overflow-hidden card card-hover p-7 sm:p-9 ring-2 ring-accent/40 border-accent/30 bg-gradient-to-br from-accent/12 via-surface-1 to-surface-2'
          : 'lg:col-span-6 card card-hover p-7';
        return (
          <article id={s.id} class={cardClasses}>
            {isFeatured && (
              <span class="absolute top-5 right-5 inline-flex items-center gap-1.5 rounded-full bg-accent text-bg text-[0.7rem] font-display font-semibold px-3 py-1 tracking-wider uppercase">
                <span aria-hidden="true">★</span> Signature Tool
              </span>
            )}
            <div class={`mb-5 h-12 w-12 rounded-xl grid place-items-center ${isFeatured ? 'bg-accent text-bg' : 'bg-accent/15 text-accent'}`} aria-hidden="true">
              {s.icon === 'monitor' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
              )}
              {s.icon === 'map' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
              )}
              {s.icon === 'quote' && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M7 8h10M7 12h6"/><path d="m16 17 2 4 1.5-3 3-1.5L18 15"/></svg>
              )}
              {s.icon === 'target' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
              )}
              {s.icon === 'search' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
              )}
            </div>

            <h3 class={`font-display font-semibold leading-snug ${isFeatured ? 'text-[1.6rem] sm:text-[1.9rem]' : 'text-[1.2rem]'} text-text`}>
              {s.title}
            </h3>

            <!-- PHASE 2 COPY: 2-3 sentence description -->
            <p class={`mt-3 text-text-soft leading-relaxed ${isFeatured ? 'text-[1.02rem] max-w-2xl' : 'text-[0.95rem]'}`}>
              <span class="inline-block px-2 py-0.5 rounded bg-accent/12 text-accent text-[0.65rem] uppercase tracking-[0.16em] mr-2 align-middle">Phase 2</span>
              Description copy goes here. Two to three tight sentences explaining what this service is, who it's for, and why it matters in the context of the system.
            </p>

            <!-- PHASE 2 COPY: bullet list -->
            <ul class="mt-5 space-y-2 text-[0.92rem] text-text-soft">
              {[1, 2, 3].map((n) => (
                <li class="flex items-start gap-2.5">
                  <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
                  <span>
                    <span class="inline-block px-1.5 py-0.5 rounded bg-text-muted/15 text-text-muted text-[0.6rem] uppercase tracking-[0.16em] mr-1.5 align-middle">Phase 2</span>
                    Bullet {n} placeholder
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-6">
              <a href="#audit-form" class={isFeatured ? 'btn-primary' : 'btn-ghost'}>
                {isFeatured ? 'See Quote Forms in Detail' : 'Learn More'}
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
<!-- /CORE SERVICES SECTION -->
