<!-- FINAL CTA SECTION -->
<section class="relative overflow-hidden">
  <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
  <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
    <span class="eyebrow"><span class="dot" aria-hidden="true"></span> 3 Founding Spots Open</span>

    <h2 class="mt-6 text-[2.2rem] sm:text-[3.2rem] leading-[1.05] font-bold tracking-tight">
      Ready to Replace the Contact Form With a <span class="text-accent">Quote System That Sells?</span>
    </h2>
    <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
      If your site is getting visitors but not enough action, the problem may not be traffic. It may be the path. Let's build a clearer one.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href="#apply" class="btn-primary">
        Apply for a Wizard Build
        <span aria-hidden="true">↗</span>
      </a>
      <a href="#apply" class="btn-ghost">
        Start the 14-Day Sprint
        <span aria-hidden="true">↗</span>
      </a>
    </div>

    <p class="mt-6 text-[0.95rem] text-text-soft">
      Or call/text Bill:
      <a href="tel:7406176488" class="text-accent font-medium underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors whitespace-nowrap">(740) 617-6488</a>
    </p>

    <p class="mt-8 max-w-xl mx-auto text-[0.9rem] text-text-muted leading-relaxed">
      Accepting 3 founding Wizard clients at locked-in pricing. After that, standard rates apply.
    </p>
  </div>

  <!-- Footer -->
  <footer class="relative z-10 border-t border-line">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 py-10 flex flex-col gap-6">
      <div class="flex flex-col sm:flex-row items-center sm:items-end justify-between gap-6">
        <a href="#top" class="flex items-center" aria-label="Designed to Elevate">
          <img
            src="/logo-wordmark-orange.png"
            alt="Designed to Elevate"
            width="320"
            height="96"
            class="h-9 w-auto"
          />
        </a>
        <div class="text-[0.85rem] text-text-muted text-center sm:text-right">
          <div>© 2026 Designed to Elevate. All rights reserved.</div>
          <div class="mt-1 flex flex-wrap gap-4 justify-center sm:justify-end">
            <a href="tel:7406176488" class="hover:text-accent transition-colors">Call/Text: (740) 617-6488</a>
            <a href="/privacy" class="hover:text-text transition-colors">Privacy</a>
            <a href="/terms" class="hover:text-text transition-colors">Terms</a>
          </div>
        </div>
      </div>

      <!-- TintShopLaunch routing line -->
      <div class="border-t border-line pt-6 text-center sm:text-right text-[0.85rem] text-text-muted">
        Window tint shop?
        <a href="https://tintshoplaunch.com" target="_blank" rel="noopener noreferrer" class="text-accent font-medium hover:text-accent-hover transition-colors">Visit TintShopLaunch →</a>
      </div>
    </div>
  </footer>
</section>
<!-- /FINAL CTA SECTION -->
