<!-- 30-DAY POST-LAUNCH PROMISE -->
<section id="promise" class="relative border-b border-line">
  <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="card relative overflow-hidden p-7 sm:p-10 lg:p-12">
      <div class="accent-glow absolute -top-32 -right-32 w-[420px] h-[420px]" aria-hidden="true"></div>

      <div class="relative grid lg:grid-cols-[auto_1fr] gap-8 lg:gap-12 items-start">
        <!-- Left: 30-day anchor -->
        <div class="lg:pt-2">
          <div class="relative inline-flex flex-col items-start gap-2 rounded-2xl border border-accent/40 bg-accent/10 px-6 py-5 sm:px-8 sm:py-6 shadow-[0_20px_50px_-20px_rgba(255,107,26,0.45)]">
            <span class="font-display text-[0.7rem] font-bold uppercase tracking-[0.2em] text-accent">Post-launch</span>
            <span class="font-display font-bold text-[3.5rem] sm:text-[4.2rem] lg:text-[5rem] leading-none text-text">
              <span class="text-accent">30</span>
            </span>
            <span class="font-display text-[0.78rem] font-medium uppercase tracking-[0.16em] text-text-soft">Day Promise</span>
          </div>
        </div>

        <!-- Right: copy -->
        <div>
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Risk Reversal</span>
          <h2 class="mt-4 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold tracking-tight">
            Our 30-Day Post-Launch Promise
          </h2>

          <p class="mt-5 text-text-soft text-[1.02rem] leading-relaxed">
            The platform is already proven at Fitchin. Your install will be a custom build based on the same core platform, configured around your business.
          </p>

          <p class="mt-4 text-text text-[1.02rem] leading-relaxed">
            If something in your wizard, dashboard, or agreed automation flow doesn't work the way we scoped it during the first <span class="text-accent font-semibold">30 days after launch</span>, we'll fix it at no extra cost. If we can't fix a covered issue within that window, we'll <span class="text-accent font-semibold">credit your next monthly payment</span>.
          </p>

          <p class="mt-4 text-text-soft text-[1.02rem] leading-relaxed">
            The setup investment covers the custom strategy, design, configuration, and build. The monthly support keeps the system hosted, maintained, and supported after launch. The build itself has to work the way we said it would. That's the promise.
          </p>

          <div class="mt-7">
            <a href="#apply" class="btn-primary">
              Apply for a Wizard Build
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- /30-DAY PROMISE -->
