---
// LandingHeader — minimal header for ads landing page.
// No nav menu by design (kills conversion). Logo left, single CTA right.
---
<header class="relative z-30 w-full">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-5 flex items-center justify-between gap-4">
    <a href="#top" class="flex items-center" aria-label="Designed to Elevate">
      <img
        src="/logo-wordmark-orange.png"
        alt="Designed to Elevate"
        width="320"
        height="96"
        class="h-9 sm:h-10 w-auto"
      />
    </a>

    <a href="#audit-form" class="btn-primary !py-2.5 !px-3.5 sm:!px-4 !text-[0.78rem] sm:!text-[0.85rem] whitespace-nowrap">
      Get My Free Growth Audit
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>
