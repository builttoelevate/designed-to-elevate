---
// LandingHeader — minimal header for ads landing page.
// No nav menu by design (kills conversion). Logo left, single CTA right.
---
<header class="relative z-30 w-full">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-5 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-3" aria-label="Designed to Elevate">
      <img
        src="/logo-mark.png"
        alt=""
        width="36"
        height="36"
        class="h-9 w-9"
      />
      <span class="hidden sm:inline font-display font-semibold text-[0.95rem] tracking-tight text-text">
        Designed to Elevate
      </span>
    </a>

    <a href="#audit-form" class="btn-primary !py-2.5 !px-4 !text-[0.85rem]">
      Get Audit
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>
