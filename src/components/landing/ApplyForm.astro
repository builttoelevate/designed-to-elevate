---
const verticalOptions = [
  'Auto detail / ceramic / PPF',
  'Barbershop / personal services',
  'HVAC / roofing / pest / home services',
  'Contractors / landscaping / cleaning',
  'Other',
];

const applyingForOptions = [
  '14-Day Sprint ($497 founding)',
  'Custom Quote & Booking Wizard ($2,995 + $147/mo founding)',
  'Not sure yet',
];

const quoteVolumeOptions = ['0–10', '10–50', '50–200', '200+'];

const heardOptions = [
  'Google search',
  'Google Ads',
  'Referral from another shop owner',
  'Social media',
  'Other',
];
---
<!-- APPLY FORM SECTION -->
<section id="apply" class="relative overflow-hidden bg-surface-1/60 border-y border-line">
  <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
  <div class="accent-glow absolute -top-40 -left-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8 py-24 sm:py-32">
    <div class="grid lg:grid-cols-[1fr_1.05fr] gap-10 lg:gap-16">
      <!-- Left: offer copy -->
      <div>
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Apply</span>
        <h2 class="mt-5 text-[2.2rem] sm:text-[3rem] leading-[1.05] font-bold">
          Apply for a <span class="text-accent">Founding Wizard Build</span>
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed max-w-xl">
          Tell us a bit about your business and how you currently quote and book work. We'll respond within 24 hours.
        </p>

        <!-- Phone-first option -->
        <div class="mt-6 flex items-start gap-3 rounded-xl border border-accent/30 bg-accent/5 p-4">
          <span class="mt-0.5 inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-bg flex-shrink-0" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          </span>
          <div>
            <div class="font-display font-semibold text-[0.95rem] text-text">Prefer to talk?</div>
            <p class="text-[0.92rem] text-text-soft mt-0.5">
              Call or text Bill at
              <a href="tel:7406176488" class="text-accent font-semibold underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors whitespace-nowrap">(740) 617-6488</a>
            </p>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <form
          data-audit-form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="card p-6 sm:p-8 space-y-5"
          novalidate
        >
          <input type="hidden" name="access_key" value="1272e2dd-abff-4804-a541-beb2bd0be075" />
          <input type="hidden" name="subject" value="New Wizard Application — designedtoelevate.co" />
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Name <span class="text-accent">*</span></span>
              <input required name="name" type="text" autocomplete="name" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Your name" />
            </label>
            <label class="block">
              <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Business name <span class="text-accent">*</span></span>
              <input required name="business" type="text" autocomplete="organization" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Acme Auto Detail" />
            </label>
          </div>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Website URL</span>
            <input name="website" type="url" autocomplete="url" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="https://yourshop.com" />
          </label>

          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Phone <span class="text-accent">*</span></span>
              <input required name="phone" type="tel" autocomplete="tel" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="(555) 555-5555" />
            </label>
            <label class="block">
              <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Email <span class="text-accent">*</span></span>
              <input required name="email" type="email" autocomplete="email" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="you@yourshop.com" />
            </label>
          </div>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">What kind of service business? <span class="text-accent">*</span></span>
            <select required name="vertical" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 appearance-none bg-no-repeat bg-[right_0.85rem_center] bg-[length:1rem]" style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%239AA0AA' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>&quot;); padding-right: 2.5rem;">
              <option value="" disabled selected>Choose one…</option>
              {verticalOptions.map((v) => <option value={v}>{v}</option>)}
            </select>
          </label>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">What are you applying for? <span class="text-accent">*</span></span>
            <select required name="applying_for" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 appearance-none bg-no-repeat bg-[right_0.85rem_center] bg-[length:1rem]" style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%239AA0AA' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>&quot;); padding-right: 2.5rem;">
              <option value="" disabled selected>Choose one…</option>
              {applyingForOptions.map((o) => <option value={o}>{o}</option>)}
            </select>
          </label>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Roughly how many quote requests does your business get per month right now? <span class="text-accent">*</span></span>
            <select required name="quote_volume" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 appearance-none bg-no-repeat bg-[right_0.85rem_center] bg-[length:1rem]" style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%239AA0AA' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>&quot;); padding-right: 2.5rem;">
              <option value="" disabled selected>Choose one…</option>
              {quoteVolumeOptions.map((v) => <option value={v}>{v}</option>)}
            </select>
          </label>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">How do you currently quote and book work? <span class="text-accent">*</span></span>
            <textarea required name="how_quote" rows="4" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 resize-y" placeholder="A couple sentences is fine."></textarea>
          </label>

          <label class="block">
            <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">How did you hear about us? <span class="text-text-muted">(Optional)</span></span>
            <select name="how_heard" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 appearance-none bg-no-repeat bg-[right_0.85rem_center] bg-[length:1rem]" style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%239AA0AA' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>&quot;); padding-right: 2.5rem;">
              <option value="" selected>—</option>
              {heardOptions.map((o) => <option value={o}>{o}</option>)}
            </select>
          </label>

          <button type="submit" class="btn-primary w-full !py-3.5">
            Apply Now
            <span aria-hidden="true">↗</span>
          </button>

          <p
            data-audit-status
            class="hidden text-[0.92rem] text-accent font-display font-medium items-center gap-2"
            role="status"
            aria-live="polite"
          ></p>

          <p class="text-[0.78rem] text-text-muted leading-relaxed">
            Bill responds within 24 hours. No spam. No list-selling. Just a real conversation about whether this is a fit.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- /APPLY FORM SECTION -->
