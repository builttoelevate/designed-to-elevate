---
// LIVE SITE SHOWCASE — proof
// Two cards. Live screenshots auto-generated via WordPress mShots.
const projects = [
  {
    label: 'Auto Detail · Window Tint',
    name: 'Fitchin Auto Detailing & Window Tinting',
    url: 'https://fitchin-website.vercel.app',
    summary:
      'A real local service business where the website, quote flow, and lead path were built around getting more calls, quote requests, and booked jobs.',
    bullets: [
      'Custom quote wizard that prices 378 vehicles by tier and package',
      'Service packaging built around the real install workflow',
      'Mobile-first quote flow designed for paid traffic',
    ],
  },
  {
    label: 'Barbershop',
    name: 'Modern Classic Barbershop',
    url: 'https://builttoelevate.github.io/modern-classic/',
    summary:
      'A premium local barbershop brand hub built around trust, clean service presentation, and easier booking.',
    bullets: [
      'Brand hub on Astro with Square handling bookings and Shopify handling product',
      'Mobile-first homepage built around service clarity and booking flow',
      'Premium positioning for a local grooming brand',
    ],
  },
];

const shotFor = (url: string) =>
  `https://s.wordpress.com/mshots/v1/${encodeURIComponent(url)}?w=1200&h=900`;
---
<!-- LIVE SITE SHOWCASE -->
<section id="live-showcase" class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Proof</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        See It Working in Real Local Businesses
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        Two live projects built on the same system. Tap either to open the live site.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <article class="card card-hover overflow-hidden flex flex-col">
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="relative block aspect-[4/3] bg-surface-2 overflow-hidden border-b border-line group/shot"
            aria-label={`Open ${p.name} in a new tab`}
          >
            <img
              src={shotFor(p.url)}
              alt={`${p.name} — live site preview`}
              class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover/shot:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
            <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-bg/80 backdrop-blur px-2.5 py-1 text-[0.65rem] font-display tracking-wider uppercase text-text-soft border border-line">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              Live
            </span>
          </a>

          <div class="p-7 flex-1 flex flex-col">
            <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{p.label}</div>
            <h3 class="mt-2 font-display font-semibold text-[1.2rem] text-text leading-snug">{p.name}</h3>

            <p class="mt-4 text-[0.95rem] text-text-soft leading-relaxed">{p.summary}</p>

            <ul class="mt-5 space-y-2.5">
              {p.bullets.map((b) => (
                <li class="flex items-start gap-3 text-[0.9rem] text-text-soft leading-snug">
                  <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <div class="mt-7 pt-5 border-t border-line">
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost w-full"
              >
                Visit Live Site
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
<!-- /LIVE SITE SHOWCASE -->
