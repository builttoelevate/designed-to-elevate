---
// LIVE SITE SHOWCASE — proof
// Screenshots are auto-generated via WordPress mShots from each project's
// live URL. Owner quotes and outcome numbers are intentionally omitted
// until they can be added with a real human voice.
const projects = [
  {
    name: 'Fitchin Auto Detailing & Window Tinting',
    url: 'https://fitchin-website.vercel.app',
    industry: 'Auto Detail · Window Tint',
  },
  {
    name: 'Modern Classic Barbershop',
    url: 'https://builttoelevate.github.io/modern-classic/',
    industry: 'Barbershop',
  },
  {
    name: 'All Transport Bus',
    url: 'https://all-transport-bus.vercel.app',
    industry: 'Local Transport',
  },
];

const shotFor = (url: string) =>
  `https://s.wordpress.com/mshots/v1/${encodeURIComponent(url)}?w=1200&h=900`;
---
<!-- LIVE SITE SHOWCASE -->
<section id="live-showcase" class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Proof</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        See It Working in Real Local Businesses
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        Three live projects built on the same system. Tap any one to open the live site.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((p) => (
        <article class="card card-hover overflow-hidden flex flex-col">
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="relative block aspect-[4/3] bg-surface-2 overflow-hidden border-b border-line group/shot"
            aria-label={`Open ${p.name} in a new tab`}
          >
            <img
              src={shotFor(p.url)}
              alt={`${p.name} — live site preview`}
              class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover/shot:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
            <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-bg/80 backdrop-blur px-2.5 py-1 text-[0.65rem] font-display tracking-wider uppercase text-text-soft border border-line">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              Live
            </span>
          </a>

          <div class="p-6 flex-1 flex flex-col">
            <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{p.industry}</div>
            <h3 class="mt-2 font-display font-semibold text-[1.1rem] text-text">{p.name}</h3>

            <div class="mt-6 pt-5 border-t border-line">
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ghost w-full"
              >
                Visit Live Site
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
<!-- /LIVE SITE SHOWCASE -->
