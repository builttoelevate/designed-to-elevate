---
const cards = [
  {
    icon: 'monitor',
    title: 'Website Conversion',
    body: 'We review whether your website clearly explains what you do, builds trust fast, and pushes visitors toward calls, quote requests, or bookings.',
  },
  {
    icon: 'map-pin',
    title: 'Google Visibility',
    body: 'We look at your Google Business Profile, local search presence, reviews, and whether customers have enough reason to choose you over competitors.',
  },
  {
    icon: 'route',
    title: 'Quote & Lead Path',
    body: 'We review how easy it is for customers to ask for pricing, understand their options, and take the next step before they move on.',
  },
];
---
<!-- WHAT WE'LL REVIEW FOR YOU -->
<section class="relative border-b border-line">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Free Growth Audit</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        What We'll Review For You
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
        We'll look at the path customers take from finding you on Google to landing on your website, requesting a quote, or booking a job — then show you where leads are leaking.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-3 gap-5">
      {cards.map((c) => (
        <div class="card p-7 flex flex-col gap-4">
          <div class="h-11 w-11 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
            {c.icon === 'monitor' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
            )}
            {c.icon === 'map-pin' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
            )}
            {c.icon === 'route' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/></svg>
            )}
          </div>
          <h3 class="font-display font-semibold text-[1.15rem] leading-snug text-text">{c.title}</h3>
          <p class="text-[0.95rem] text-text-soft leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center text-center gap-5">
      <p class="text-[0.95rem] text-text-muted max-w-xl">
        You'll leave with clear recommendations you can use, whether we work together or not.
      </p>
      <a href="#audit-form" class="btn-primary">
        Get My Free Growth Audit
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>
<!-- /WHAT WE'LL REVIEW FOR YOU -->
