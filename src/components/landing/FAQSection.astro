---
const faqs = [
  {
    q: "What's the catch with founding pricing?",
    a: 'No catch. We\'re trading discounted rates for testimonials, case studies, and referrals — the things every new agency needs to grow. After 5 founding clients, prices return to standard rates.',
  },
  {
    q: 'What happens to my rate after the founding period ends?',
    a: 'Founding clients keep their locked-in rate for as long as they stay subscribed. When prices go up, yours doesn\'t.',
  },
  {
    q: 'Do I need a brand-new website, or can you improve what I have?',
    a: 'Sometimes the fastest win is fixing the homepage, service pages, quote form, or landing page before rebuilding everything. The free Lead Leak Audit will tell us which.',
  },
  {
    q: 'Who is this for?',
    a: 'Local service businesses doing $200K+/year — auto detail shops, tint shops, barbershops, contractors, cleaners, landscapers, HVAC, roofing, pest control, and similar. Not for brand-new startups, e-commerce, or non-service businesses.',
  },
  {
    q: 'Do you run Google Ads for me too?',
    a: 'Lead Engine and Custom Lead System include the landing page and strategy. Ad management itself is a separate add-on once we know the page is converting.',
  },
  {
    q: 'What makes this different from a regular agency?',
    a: 'The system was built inside real local service businesses, not in an agency conference room. Everything I recommend has been tested where it had to actually work. If it didn\'t move the needle, I don\'t sell it.',
  },
];
---
<!-- FAQ SECTION -->
<section id="faq" class="relative border-b border-line">
  <div class="mx-auto max-w-4xl px-5 sm:px-8 py-20 sm:py-28">
    <div>
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> FAQ</span>
      <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
        Common Questions
      </h2>
      <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed max-w-2xl">
        If something's not answered here, call or text Bill at
        <a href="tel:7406176488" class="text-accent font-medium underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors whitespace-nowrap">(740) 617-6488</a>.
      </p>
    </div>

    <div class="mt-10 space-y-3">
      {faqs.map((f) => (
        <details class="faq-item card group p-0 overflow-hidden">
          <summary class="cursor-pointer list-none flex items-start justify-between gap-4 px-6 py-5 sm:px-7 sm:py-6 select-none">
            <span class="font-display font-semibold text-[1.02rem] sm:text-[1.08rem] text-text leading-snug">{f.q}</span>
            <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full border border-line text-text-soft group-hover:border-accent group-hover:text-accent transition-colors flex-shrink-0" aria-hidden="true">
              <svg class="faq-chevron transition-transform duration-200" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </summary>
          <div class="px-6 pb-6 sm:px-7 sm:pb-7 -mt-1">
            <p class="text-[0.95rem] text-text-soft leading-relaxed max-w-prose">{f.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
      <a href="#audit-form" class="btn-primary">
        Claim My Founding 5 Spot
        <span aria-hidden="true">↗</span>
      </a>
      <a href="tel:7406176488" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call or Text Bill
      </a>
    </div>
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }
  .faq-item[open] { border-color: rgba(255, 107, 26, 0.4); }
</style>
<!-- /FAQ SECTION -->
