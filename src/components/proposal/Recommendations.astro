---
import SectionHead from './SectionHead.astro';

interface Item { title: string; body: string; }
interface Props { items: Item[]; }
const { items } = Astro.props;
---
<section>
  <div class="wrap">
    <SectionHead eyebrow="Beyond the website" title="What moves the needle next." />
    <p class="rec-subtitle">Three things lift a print shop's visibility harder than anything else. SEO isn't on this list. The new site is built search-engine clean out of the box, so rankings will follow on their own.</p>

    {items.map((item) => (
      <div class="rec-row">
        <h3 class="rec-title">{item.title}</h3>
        <p>{item.body}</p>
      </div>
    ))}
  </div>
</section>
