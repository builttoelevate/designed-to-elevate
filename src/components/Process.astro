---
const steps = [
  { n: '01', title: 'Discovery', body: 'A real conversation about your shop, your customers, your offer, and where the gaps actually are.' },
  { n: '02', title: 'Strategy', body: 'A focused plan — pages to build, copy direction, SEO structure, lead flow, and what the launch looks like.' },
  { n: '03', title: 'Build', body: 'Design and development. Copy, layout, mobile, performance. Every page wired toward the next step.' },
  { n: '04', title: 'Launch', body: 'Go-live, redirects, analytics, search console, the basics done right. Nothing left dangling.' },
  { n: '05', title: 'Improve', body: 'Iterate based on what real visitors do. New service pages, refined offers, monthly support if you want it.' },
];
---
<section class="process" id="process">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Process</span>
      <h2>Five steps. No mystery.</h2>
      <p class="lede">
        Straight path from first conversation to a site that earns its keep — and keeps earning after launch.
      </p>
    </div>

    <ol class="timeline" role="list">
      {steps.map((s, i) => (
        <li class="t-step reveal" style={`transition-delay:${i * 60}ms;`}>
          <div class="t-marker" aria-hidden="true">
            <span>{s.n}</span>
            <span class="line" />
          </div>
          <div class="t-body">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    padding: 0; margin: 0;
    display: grid;
    gap: 0;
    position: relative;
  }
  .t-step {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 28px;
    padding: 22px 0;
    position: relative;
    border-top: 1px solid var(--line);
  }
  .t-step:first-child { border-top: 1px solid var(--line); }
  .t-step:last-child { border-bottom: 1px solid var(--line); }

  .t-marker {
    position: relative;
    display: flex; flex-direction: column; align-items: center;
    padding-top: 4px;
  }
  .t-marker > span:first-child {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--blue) 0%, #3F61FF 100%);
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    box-shadow: 0 8px 24px -10px var(--blue-glow);
  }
  .t-marker .line {
    flex: 1;
    width: 2px;
    background: linear-gradient(180deg, var(--blue), transparent);
    margin-top: 8px;
  }
  .t-step:last-child .t-marker .line { display: none; }

  .t-body { padding-top: 8px; }
  .t-body h3 { margin-bottom: 8px; }
  .t-body p { color: var(--soft); max-width: 56ch; }

  @media (max-width: 600px) {
    .t-step { grid-template-columns: 64px 1fr; gap: 18px; }
    .t-marker > span:first-child { width: 44px; height: 44px; font-size: 0.85rem; border-radius: 10px; }
  }
</style>
