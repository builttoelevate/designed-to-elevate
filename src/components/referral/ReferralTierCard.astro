---
// Referral pricing card for the Modern Classic friends-pricing page.
// Ported from the janitorial repo and restyled onto DtE's theme.
// Founding 5 has been removed — the Modern Classic 50%-off price (mcPrice)
// is the hero price, with a 50/50 deposit split shown beneath it.
interface Props {
  tierId: "starter" | "leadgen" | "booking";
  name: string;
  standard: string; // full standard price (struck through)
  mcPrice: string;  // Modern Classic 50%-off price — the hero
  description: string;
  inclusions: string[];
  popular?: boolean;
}
const { tierId, name, standard, mcPrice, description, inclusions, popular = false } = Astro.props;

// 50/50 payment split — half on deposit, half at launch — derived from the price.
const half = (price: string) => {
  const n = Number(String(price).replace(/[^0-9.]/g, ""));
  const h = n / 2;
  const fmt = "$" + (Number.isInteger(h) ? h.toLocaleString("en-US") : h.toLocaleString("en-US", { minimumFractionDigits: 2 }));
  return `${fmt} today · ${fmt} at launch`;
};
const mcSplit = half(mcPrice);
---

<div class:list={["card relative flex flex-col p-7 sm:p-8", popular && "ring-2 ring-accent lg:scale-[1.03]"]}>
  {popular && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-accent px-3 py-1 text-xs font-semibold uppercase tracking-wide text-bg">
      Most Popular
    </span>
  )}
  <h3 class="font-display text-xl text-text">{name}</h3>

  <div class="ps mt-4">
    <div class="ps-std">{standard} <span>standard</span></div>
    <div class="ps-mc"><span class="ps-amt">{mcPrice}</span><span class="ps-lbl">Modern Classic · 50% off</span></div>
    <div class="ps-split">{mcSplit}</div>
  </div>

  <p class="mt-4 text-sm leading-relaxed text-text-soft">{description}</p>
  <ul class="mt-5 flex-1 space-y-2.5">
    {inclusions.map((item) => (
      <li class="flex items-start gap-2.5 text-sm text-text-soft">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
        <span>{item}</span>
      </li>
    ))}
  </ul>
  <button type="button" data-choose-tier={tierId} class="btn-primary mt-7 w-full">
    Choose This Plan
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
  </button>
</div>

<style>
  .ps-std { font-size: 12px; color: var(--color-text-muted); text-decoration: line-through; }
  .ps-std span { text-transform: uppercase; letter-spacing: .04em; }
  .ps-mc { margin-top: 4px; display: flex; align-items: baseline; gap: .5rem; }
  .ps-mc .ps-amt { font-family: var(--font-display); font-weight: 700; font-size: 2.5rem; line-height: 1; color: var(--color-accent); }
  .ps-mc .ps-lbl { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: var(--color-text-muted); }
  .ps-split { margin-top: .4rem; font-size: 12px; color: var(--color-text-muted); }
</style>
