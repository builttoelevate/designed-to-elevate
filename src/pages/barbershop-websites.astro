---
// /barbershop-websites — dedicated Google Ads landing page.
// No nav, single conversion path. Minimal header + footer baked in here
// so we don't reuse SiteHeader/SiteFooter (which would pull paid traffic
// off to other pages). LandingLayout still provides the global <head>,
// sticky-mobile-CTA observer JS, and Org/WebSite JSON-LD.
import LandingLayout from '../layouts/LandingLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const SITE = 'https://designedtoelevate.co';
const PHONE_DISPLAY = '(740) 617-6488';
const PHONE_TEL = 'tel:7406176488';
const EMAIL = 'bilsonxnc@gmail.com';
// TODO: swap to a real Calendly / scheduler URL once provisioned.
const QUOTE_HREF = '/contact?service=barbershop&from=barbershop-websites';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Barbershop Website Design',
  serviceType: 'Website design for barbershops',
  description:
    'Custom barbershop website that makes Square, Booksy, reviews, waitlists, and product sales feel like one premium brand experience. $1,997 setup + $97/month.',
  provider: { '@id': `${SITE}/#organization` },
  areaServed: { '@type': 'State', name: 'Ohio' },
  audience: { '@type': 'BusinessAudience', name: 'Barbershops' },
  url: `${SITE}/barbershop-websites`,
  offers: {
    '@type': 'Offer',
    price: '1997',
    priceCurrency: 'USD',
    description: '$1,997 setup + $97/month ongoing care plan',
  },
};

const painCards = [
  {
    title: "Your booking page looks like everyone else's",
    body: "Square, Booksy, and Shop Pay all have their own look. That's fine for platforms. It's not fine when you want the customer to believe in your shop.",
  },
  {
    title: 'Customers leave your brand before they book',
    body: 'If the customer leaves your site to book, every step is a chance to lose them. A custom front end keeps the whole flow inside your brand.',
  },
  {
    title: 'Retail product feels disconnected',
    body: 'Product retail should feel like part of the shop. A generic Shopify storefront makes your merch look like an afterthought.',
  },
  {
    title: 'Reviews, waitlists, and follow-up get handled manually',
    body: 'Without review automation and waitlist tools, every missed touchpoint is a missed return visit.',
  },
];

const whatThisIsBullets = [
  'New clients discovering your brand',
  'Customers choosing services',
  'Online booking that stays inside your brand',
  'Product sales connected to the same experience',
  'Reviews and waitlist follow-up that runs on its own',
  'Repeat appointments through customer login',
  'An owner dashboard you actually want to open',
];

const featureBullets = [
  'Branded booking experience so customers never feel like they left the shop',
  'Product shopping built into the same premium experience (no detour to a generic store)',
  'Automatic review requests by text after every appointment',
  'A waitlist that auto-invites customers when slots open',
  'Owner tools for reviews, waitlist openings, and repeat customers — all in one place',
];

const proofItems = [
  {
    src: '/showcase/modern-classic/calendar-availability.jpg',
    width: 1320,
    height: 2366,
    title: 'Real-time availability from Square',
    description:
      "The booking calendar pulls every barber's actual open slots in real time. Customers see exactly what's available — no calls, no callbacks.",
  },
  {
    src: '/showcase/modern-classic/barber-profile-michael.jpg',
    width: 880,
    height: 1842,
    title: 'Each barber gets their own brand',
    description:
      "Photo, bio, specialties, next-available time, and an Instagram link — so loyal clients can book the person they trust, not just any open chair.",
  },
  {
    src: '/showcase/modern-classic/product-retail.jpg',
    width: 1320,
    height: 2276,
    title: 'Product retail without leaving the brand',
    description:
      'The in-house grooming line lives on the same site, with the same look. No detour to a generic Shopify store.',
  },
  {
    src: '/showcase/modern-classic/my-bookings.jpg',
    width: 1306,
    height: 2560,
    title: 'Customers see their full history',
    description:
      'Upcoming and past appointments in one signed-in view. One-tap to rebook, reschedule, or cancel — and a quick text line straight to their barber.',
  },
  {
    src: '/showcase/modern-classic/group-booking-customer.jpg',
    width: 880,
    height: 2265,
    title: 'Group + back-to-back booking',
    description:
      'Book the family, the wedding party, or a back-to-back kids cut all in one transaction. Each appointment can still be managed separately.',
  },
  {
    src: '/showcase/modern-classic/reviews-section.jpg',
    width: 1320,
    height: 2183,
    title: 'Real reviews, baked into the homepage',
    description:
      'Google reviews stream straight into the homepage — proof points right where new customers decide whether to book.',
  },
];

const platformCards = [
  {
    label: 'Fast mobile experience',
    value:
      'Your site loads quickly, looks polished on phones, and helps customers move toward booking without friction.',
  },
  {
    label: 'Your booking platform stays in place',
    value:
      'Square, Booksy, or Shopify can keep running while your website controls the branded customer experience.',
  },
  {
    label: 'Follow-up that runs without you',
    value: 'Review requests, waitlist invites, and customer reminders fire automatically.',
  },
  {
    label: 'Owner tools that reduce app-hopping',
    value:
      'Manage booking flow, reviews, waitlist activity, and customer follow-up from one cleaner system.',
  },
];

const whoThisIsForBullets = [
  'Your shop already has a strong reputation',
  'You use Square, Booksy, Shopify, or similar tools',
  "Your website doesn't match the quality of your shop",
  'You want booking, reviews, products, and follow-up to feel connected',
  'You care about brand, not just having a link online',
];

const faqs = [
  {
    q: 'How much does a custom barbershop website cost?',
    a: '$1,997 setup + $97/month. Same build as Modern Classic Barbershop — custom homepage, services, barbers, gallery, Square booking integration, mobile-first design, and automated review requests. The monthly covers hosting, ongoing review automation, small updates, and software costs. If you want extras like a customer login, custom waitlist, product integration, or owner dashboard, we can talk about those separately on the call.',
  },
  {
    q: 'How long does it take?',
    a: '3-4 weeks from kickoff to launch for the standard build.',
  },
  {
    q: 'Do I have to stop using Square or Booksy?',
    a: 'No. Your booking platform stays in place — the website just makes the customer-facing experience feel like your shop instead of a generic booking page.',
  },
  {
    q: "What's the monthly fee for?",
    a: '$97/month covers hosting, automated review requests by text after appointments, small site updates, software costs, and ongoing care. Month-to-month, no long-term contract.',
  },
  {
    q: 'What happens after launch?',
    a: 'You get handoff, training, and one month of launch support included. Then the $97/month ongoing care plan keeps everything running and lets you submit small updates anytime.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<LandingLayout
  title="Custom Barbershop Websites Built Around Booking & Brand | Designed to Elevate"
  description="Custom barbershop websites that make Square, Booksy, reviews, waitlists, and product sales feel like one premium brand experience. See the Modern Classic Barbershop case study."
  pathname="barbershop-websites"
  noindex={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <BreadcrumbSchema items={[
    { name: 'Home', url: `${SITE}/` },
    { name: 'Barbershop Websites', url: `${SITE}/barbershop-websites` },
  ]} />

  <main>
    <!-- FIXED HERO BACKGROUND — pinned to the viewport with position:fixed so it
         stays still while content scrolls over it. Replaces the old JS scroll-
         parallax, which repainted a frame behind the native scroll and bounced
         on mobile. Sits at z-0; the hero is transparent to reveal it, and all
         content below is wrapped in an opaque bg-bg layer that scrolls over it. -->
    <div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
      <img
        src="/barbershop-websites/hero-bg-barbershop-interior.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-right md:object-center"
        width="1672"
        height="941"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/55"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-bg/70 via-bg/35 to-bg/10"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-bg"></div>
    </div>

    <!-- HERO — the minimal landing header sits over the same fixed background. -->
    <div id="top" class="relative z-10 overflow-hidden border-b border-line">

      <!-- MINIMAL LANDING HEADER — no nav, transparent over the hero photo. -->
      <header class="relative z-30 w-full">
        <div class="mx-auto max-w-7xl px-5 sm:px-8 py-4 sm:py-5 flex items-center justify-between gap-3 sm:gap-4">
          <a href="#top" class="flex items-center" aria-label="Designed to Elevate">
            <img
              src="/logo-wordmark-orange.png"
              alt="Designed to Elevate"
              width="320"
              height="96"
              class="h-8 sm:h-10 w-auto"
            />
          </a>
          <div class="flex items-center gap-2 sm:gap-3">
            <a
              href={PHONE_TEL}
              class="inline-flex items-center gap-1.5 sm:gap-2 font-display font-medium text-[0.78rem] sm:text-[0.85rem] text-text-soft hover:text-accent transition-colors px-2 py-2 rounded-md"
              aria-label={`Call or text Bill at ${PHONE_DISPLAY}`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>
              </svg>
              <span class="hidden xs:inline sm:inline">{PHONE_DISPLAY}</span>
              <span class="xs:hidden sm:hidden">Call</span>
            </a>
            <a href={QUOTE_HREF} class="btn-primary !py-2.5 !px-3.5 sm:!px-4 !text-[0.78rem] sm:!text-[0.85rem] whitespace-nowrap">
              Get a Free Quote
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </header>

      <!-- HERO CONTENT -->
      <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8 pt-6 sm:pt-10 pb-14 sm:pb-20">
        <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-center">
          <div>
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Barbershop Websites</span>
            <h1 class="mt-5 text-[2.2rem] sm:text-[2.9rem] lg:text-[3.3rem] leading-[1.04] font-bold tracking-tight">
              A barbershop website that makes booking feel like part of your brand — <span class="text-accent">not someone else's platform.</span>
            </h1>
            <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.1rem] leading-relaxed max-w-2xl">
              Keep Square, Booksy, or Shopify working behind the scenes while your customers experience a polished mobile-first website that looks like your shop, makes booking obvious, and helps bring people back.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href={QUOTE_HREF} data-hero-cta class="btn-primary">
                Book a Barbershop Website Call
                <span aria-hidden="true">↗</span>
              </a>
              <a href="#case-study" class="btn-ghost">
                See the Modern Classic Build
                <span aria-hidden="true">→</span>
              </a>
            </div>

            <div class="mt-6 text-[0.9rem] text-text-muted">
              $1,997 setup &nbsp;·&nbsp; $97/month ongoing care &nbsp;·&nbsp; 3-4 week build
            </div>
          </div>

          <div class="relative" aria-hidden="false">
            <div class="absolute -inset-6 bg-gradient-to-br from-accent/30 via-accent/5 to-transparent rounded-[2rem] blur-3xl opacity-60"></div>
            <img
              src="/case-studies/modern-classic-barbershop/mobile-booking-experience-explainer.png"
              alt="From First Click to Booked Appointment: a Modern Classic Barbershop mobile homepage shown on a phone, flanked by Branded booking flow and Built for thumbs first callouts and a Mobile-first badge."
              class="relative block w-full h-auto rounded-2xl"
              width="1448"
              height="1086"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- CONTENT OVER THE FIXED BACKGROUND — opaque bg-bg so the hero photo only
         shows behind the hero, then this layer scrolls up over it. -->
    <div class="relative z-10 bg-bg">

    <!-- PAIN -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-24">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The Problem</span>
          <h2 class="mt-5 text-[1.9rem] sm:text-[2.5rem] leading-[1.07] font-bold">
            Most barbershop websites feel like a booking platform — not the shop people are trying to trust.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            If the first thing a customer sees is a templated booking form, you are selling the platform, not the chair.
          </p>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 gap-5">
          {painCards.map((c) => (
            <div class="card p-7 flex flex-col gap-3">
              <h3 class="font-display font-semibold text-[1.05rem] leading-snug text-text">{c.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHAT THIS ACTUALLY IS -->
    <section class="relative border-b border-line bg-surface-1/30">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> What You Get</span>
        <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
          What this actually is.
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          Not just a prettier homepage. A custom barbershop website built around how your shop actually makes money:
        </p>

        <ul class="mt-9 grid sm:grid-cols-2 gap-4">
          {whatThisIsBullets.map((b) => (
            <li class="flex items-start gap-3 text-[1rem] text-text leading-snug">
              <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/15 text-accent flex-shrink-0" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CASE STUDY (Modern Classic feature) -->
    <section id="case-study" class="relative border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl mb-12">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Featured Build</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.5rem] leading-[1.05] font-bold">
            Modern Classic Barbershop &amp; Shave Parlor
          </h2>
          <div class="mt-3 text-text-muted text-[0.95rem]">Zanesville, Ohio</div>
        </div>

        <div class="grid lg:grid-cols-[0.9fr_1fr] gap-10 lg:gap-14 items-center">
          <div class="relative" aria-hidden="true">
            <div class="absolute -inset-6 bg-gradient-to-br from-accent/30 via-accent/5 to-transparent rounded-[2rem] blur-3xl opacity-60"></div>
            <div class="relative card overflow-hidden max-w-[22rem] mx-auto">
              <div class="relative aspect-[9/16] bg-surface-2 overflow-hidden">
                <img
                  src="/showcase/modern-classic/homepage.jpg"
                  alt="Modern Classic Barbershop mobile homepage"
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  width="1320"
                  height="2432"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>

          <div>
            <p class="text-text-soft text-[1.05rem] leading-relaxed">
              Modern Classic already had the reputation. The problem was the online experience didn't match the shop. Booking lived in Square. Product lived in Shopify. The old website didn't show the full brand. The new site brings everything together — discover, choose a service, book, shop product, join the waitlist, come back again — through one premium mobile-first website.
            </p>

            <ul class="mt-7 space-y-3">
              {featureBullets.map((b) => (
                <li class="flex items-start gap-3 text-[1rem] text-text leading-snug">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/15 text-accent flex-shrink-0" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <p class="mt-7 pt-6 border-t border-line text-text-soft text-[0.98rem] italic leading-relaxed">
              Same pattern translates to any shop running on Square, Booksy, or Squire — the platform stays invisible, the brand stays on top.
            </p>

            <div class="mt-7 flex flex-wrap gap-3">
              <a href="/case-studies/modern-classic-barbershop" class="btn-ghost">
                Read the full case study
                <span aria-hidden="true">→</span>
              </a>
              <a href="https://modernclassicbarbershop.com" target="_blank" rel="noopener noreferrer" class="btn-ghost">
                Visit the live site
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SIGNATURE FEATURES (branded explainer graphics) -->
    <section class="relative border-b border-line bg-surface-1/30">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-24">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Signature Features</span>
          <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
            Three features that turn a barbershop website into a booking machine.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Built first for Modern Classic, now available on every barbershop build — same Franklin pricing, same launch timeline.
          </p>
        </div>

        <div class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
          <figure class="flex flex-col gap-5">
            <div class="card overflow-hidden bg-surface-2 flex items-center justify-center">
              <img
                src="/case-studies/modern-classic-barbershop/automatic-reviews-explainer.png"
                alt="Automatic Review Generator diagram showing review-request emails sent 2–5 days after each visit, with stats panel tracking the daily cron run and an example email preview."
                class="block w-full h-auto"
                width="1122"
                height="1402"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption>
              <h3 class="font-display font-semibold text-[1.15rem] text-text">Automatic review generator</h3>
              <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                Auto-sends review emails 2–5 days after every visit — without anyone in the shop touching a phone. More reviews, more trust, less manual work.
              </p>
            </figcaption>
          </figure>

          <figure class="flex flex-col gap-5">
            <div class="card overflow-hidden bg-surface-2 flex items-center justify-center">
              <img
                src="/case-studies/modern-classic-barbershop/group-booking-explainer.png"
                alt="Group Booking diagram showing 2–3 people booked together in one transaction with separate services and back-to-back scheduling on one barber."
                class="block w-full h-auto"
                width="1672"
                height="941"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption>
              <h3 class="font-display font-semibold text-[1.15rem] text-text">Group booking — 2–3 people, one transaction</h3>
              <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                Families, friends, and small crews can book together in one flow. Pick services per person, choose separate barbers or back-to-back on the same chair.
              </p>
            </figcaption>
          </figure>

          <figure class="flex flex-col gap-5">
            <div class="card overflow-hidden bg-surface-2 flex items-center justify-center">
              <img
                src="/case-studies/modern-classic-barbershop/multi-visit-booking-explainer.png"
                alt="Multiple Bookings in One Session diagram letting a client reserve up to four future visits at once with date and time per visit, plus a full booking plan review."
                class="block w-full h-auto"
                width="1448"
                height="1086"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption>
              <h3 class="font-display font-semibold text-[1.15rem] text-text">Multiple bookings in one session</h3>
              <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                Loyal clients can reserve up to four future visits in a single session — keeping their chair locked in and saving the shop the back-and-forth.
              </p>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-24">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Real Screens</span>
          <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
            Real screens from a live barbershop website — not a mockup.
          </h2>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {proofItems.map((p) => (
            <div class="card overflow-hidden flex flex-col">
              <div class="relative aspect-[9/16] bg-surface-2 overflow-hidden">
                <img
                  src={p.src}
                  alt={p.title}
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  width={p.width}
                  height={p.height}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5 flex flex-col gap-2">
                <h3 class="font-display font-semibold text-[1rem] text-text">{p.title}</h3>
                <p class="text-[0.92rem] text-text-soft leading-relaxed">{p.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BUILT TO FEEL SIMPLE (renamed tech stack) -->
    <section class="relative border-b border-line bg-surface-1/30">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-24">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> How It Works</span>
          <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
            Built to feel simple for customers — and powerful behind the scenes.
          </h2>
        </div>

        <div class="mt-10 grid sm:grid-cols-2 gap-5">
          {platformCards.map((t) => (
            <div class="card p-6">
              <div class="font-display text-[0.74rem] uppercase tracking-[0.18em] text-accent mb-2">{t.label}</div>
              <div class="text-[1rem] text-text leading-relaxed">{t.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- REAL FEEDBACK (Modern Classic only) -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-24">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Real Feedback</span>
          <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
            Real reviews from the Modern Classic brand.
          </h2>
        </div>

        <div class="mt-10 max-w-lg">
          <div class="card overflow-hidden">
            <img
              src="/barbershop-reviews/michael-review-cropped.png"
              alt="Five-star Google review for Modern Classic Barbershop from Michael"
              class="w-full h-auto block"
              width="722"
              height="500"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- WHO THIS IS FOR -->
    <section class="relative border-b border-line bg-surface-1/30">
      <div class="mx-auto max-w-4xl px-5 sm:px-8 py-20 sm:py-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Fit Check</span>
        <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
          This is built for shops ready for more than a basic booking link.
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
          This is a good fit if:
        </p>

        <ul class="mt-7 space-y-3">
          {whoThisIsForBullets.map((b) => (
            <li class="flex items-start gap-3 text-[1rem] text-text leading-snug">
              <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/15 text-accent flex-shrink-0" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        <p class="mt-8 text-text-muted text-[0.95rem] italic">
          This isn't for shops that want the cheapest possible website or a one-page template.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-3xl px-5 sm:px-8 py-20 sm:py-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> FAQ</span>
        <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
          Honest answers, no fine print.
        </h2>

        <div class="mt-10 space-y-3">
          {faqs.map((f, i) => (
            <details class="card p-6 group" open={i === 0}>
              <summary class="cursor-pointer list-none font-display font-semibold text-[1rem] sm:text-[1.05rem] text-text flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <span class="text-accent text-[1.2rem] leading-none mt-0.5 group-open:rotate-45 transition-transform" aria-hidden="true">+</span>
              </summary>
              <p class="mt-4 text-[0.97rem] text-text-soft leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section id="apply" class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <h2 class="text-[2.1rem] sm:text-[2.9rem] leading-[1.05] font-bold tracking-tight">
          Stop sending customers to a booking page that <span class="text-accent">doesn't feel like your shop.</span>
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Give them a premium website that shows your brand, makes booking simple, connects your existing tools, and helps turn one-time visitors into repeat clients. $1,997 setup + $97/month.
        </p>

        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href={QUOTE_HREF} class="btn-primary">
            Book a Barbershop Website Call
            <span aria-hidden="true">↗</span>
          </a>
          <a href={PHONE_TEL} class="btn-ghost">
            Call/Text Bill
            <span aria-hidden="true">→</span>
          </a>
          <a href="/seo" class="btn-ghost">
            How we build for SEO
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <p class="mt-6 text-[0.95rem] text-text-soft">
          Or call/text directly:
          <a href={PHONE_TEL} class="text-accent font-medium underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors whitespace-nowrap">{PHONE_DISPLAY}</a>
        </p>
      </div>
    </section>
    </div>
  </main>

  <!-- MINIMAL FOOTER — no nav, no service links. Copyright + phone + email only. -->
  <footer class="relative z-10 border-t border-line bg-bg">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-[0.85rem] text-text-muted">
      <div>© 2026 Designed to Elevate. All rights reserved.</div>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={PHONE_TEL} class="hover:text-accent transition-colors">{PHONE_DISPLAY}</a>
        <a href={`mailto:${EMAIL}`} class="hover:text-accent transition-colors">{EMAIL}</a>
      </div>
    </div>
  </footer>

  <!-- STICKY MOBILE CTA — controlled by LandingLayout's IntersectionObserver
       which watches [data-hero-cta] and #apply. -->
  <div
    data-sticky-cta
    class="md:hidden fixed inset-x-0 bottom-0 z-40 border-t border-line bg-bg/95 backdrop-blur supports-[backdrop-filter]:bg-bg/85 px-3 py-3 pb-[max(env(safe-area-inset-bottom),0.75rem)] translate-y-full opacity-0 pointer-events-none transition-[transform,opacity] duration-300 ease-out"
    aria-label="Barbershop website conversion actions"
  >
    <div class="flex gap-2">
      <a href={PHONE_TEL} class="btn-ghost flex-1 !px-2 !text-[0.85rem]" aria-label={`Call or text Bill at ${PHONE_DISPLAY}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call/Text
      </a>
      <a href={QUOTE_HREF} class="btn-primary flex-1 !px-2 !text-[0.85rem]">
        Book a Call
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

</LandingLayout>
