---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

const builds = [
  { title: 'Quote & Estimate Wizards', body: 'Multi-step pricing flows tailored to your services. Customers get a real number; you get a structured lead.' },
  { title: 'Booking Request Flows', body: 'Smart intake that turns interest into a scheduled appointment without the back-and-forth text thread.' },
  { title: 'Lead Capture Systems', body: 'Capture name, contact, and intent before the final step — so even unfinished quotes become leads.' },
  { title: 'Follow-Up Automations', body: 'Automatic text + email confirmation, reminder sequences, and post-job review requests. Zero owner effort after launch.' },
  { title: 'Review Request Systems', body: 'Triggered review prompts the moment a job is marked complete — when customer satisfaction is highest.' },
  { title: 'Customer & Job Dashboards', body: 'Owner view of every lead, quote, and job in one place. Filter by status, assign to a tech, mark complete from a phone.' },
  { title: 'Internal Admin Tools', body: 'Custom back-office tools — pricing controls, role-based logins, schedule blockouts, multi-location support — built around how your business actually runs.' },
];

const audience = [
  'Auto detail / ceramic / PPF',
  'Window tint shops',
  'Barbershops · personal services',
  'HVAC · roofing · pest · home services',
  'Contractors · landscaping · cleaning',
  'Pressure washing',
  'Mobile mechanics',
  'Transportation · event rentals',
  'Dog groomers',
];

const outcomes = [
  { title: 'Fewer missed leads', body: 'Every quote — even the unfinished ones — lands in one dashboard.' },
  { title: 'Faster quotes', body: 'Customers see real pricing the moment they ask, not three days later.' },
  { title: 'Less chaos', body: 'Phone, text, Facebook, sticky notes — all replaced with one clear flow.' },
  { title: 'More reviews', body: 'Auto-prompted at the moment of peak satisfaction, not weeks after the fact.' },
  { title: 'More booked jobs', body: "Faster response + clearer pricing + automatic follow-up = more 'yes.'" },
];
---
<LandingLayout
  title="Custom Quote & Booking Systems for Local Service Businesses | Designed to Elevate"
  description="Custom quote wizards, booking flows, follow-up automations, and admin dashboards for local service businesses. Built around how your shop actually prices and books work."
  pathname="custom-lead-systems"
>
  <SiteHeader />

  <main>
    <!-- HERO -->
    <section id="top" class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8 pt-12 sm:pt-20 pb-16 sm:pb-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The Differentiator</span>
        <h1 class="mt-5 text-[2.4rem] sm:text-[3.2rem] lg:text-[3.6rem] leading-[1.04] font-bold tracking-tight">
          Custom <span class="text-accent">Lead Systems</span> for Local Service Businesses
        </h1>
        <p class="mt-6 text-text-soft text-[1.1rem] leading-relaxed max-w-3xl">
          If your business is running on text messages, spreadsheets, sticky notes, and three apps that don't talk to each other, I'll build one simple system that captures leads, quotes customers, organizes jobs, and follows up automatically.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary">
            Free Website Review
            <span aria-hidden="true">↗</span>
          </a>
          <a href="/case-studies/fitchin-auto-detail-tint" class="btn-ghost">
            See it live at Fitchin
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- THE PROBLEM -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The Problem</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          Most Shops Lose Leads Before They Ever See Them.
        </h2>
        <div class="mt-6 space-y-4 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          <p>A customer texts. Another fills out a Facebook form. Another calls and leaves a voicemail while you're under a hood. Another submits a quote request that goes to a Gmail inbox you check at 9 PM.</p>
          <p>By the time you get back to them, they've already booked the next shop on the list. The lead wasn't bad. The system was.</p>
        </div>
      </div>
    </section>

    <!-- WHAT I BUILD -->
    <section id="follow-up" class="relative border-b border-line bg-surface-1/40 scroll-mt-24">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-24 sm:py-32">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> What I Build</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.7rem] leading-[1.05] font-bold">
            One System. Seven Pieces. Built Around Your Business.
          </h2>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {builds.map((b) => (
            <div class="card p-7 flex flex-col gap-3">
              <h3 class="font-display font-semibold text-[1.05rem] leading-snug text-text">{b.title}</h3>
              <p class="text-[0.92rem] text-text-soft leading-relaxed">{b.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHO IT'S FOR -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Who It's For</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Built for Service Businesses With Real Pricing Logic
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            If every job is different — packages, add-ons, vehicle types, room counts, square footage — your contact form shouldn't be generic.
          </p>
        </div>

        <ul class="mt-8 flex flex-wrap gap-2">
          {audience.map((a) => (
            <li class="inline-flex items-center rounded-full border border-line bg-surface-2 px-3.5 py-1.5 text-[0.9rem] text-text-soft font-display">
              {a}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- WHY IT WORKS -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Why It Works</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            What Changes After Launch
          </h2>
        </div>

        <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {outcomes.map((o) => (
            <div class="card p-7 flex flex-col gap-3">
              <div class="h-9 w-9 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="font-display font-semibold text-[1.05rem] leading-snug text-text">{o.title}</h3>
              <p class="text-[0.92rem] text-text-soft leading-relaxed">{o.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ADVANCED SYSTEM EXPERIENCE -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="card relative overflow-hidden p-8 sm:p-12">
          <div class="accent-glow absolute -top-32 -right-32 w-[420px] h-[420px]" aria-hidden="true"></div>
          <div class="relative">
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Built Real Things</span>
            <h2 class="mt-5 text-[1.8rem] sm:text-[2.4rem] leading-[1.1] font-bold tracking-tight">
              This Isn't a "Form on a Webpage."
            </h2>
            <div class="mt-6 space-y-4 text-text-soft text-[1.02rem] leading-relaxed max-w-3xl">
              <p>
                The wizard pattern came from real production work — vehicle-based quote logic across 378 vehicles, dynamic pricing rules, multi-step quote flows, an admin dashboard for lead management, and a multi-tenant SaaS architecture so the same core platform can configure to a new business in days, not months.
              </p>
              <p>
                The depth matters because your shop's logic is real. Tier 2 ceramic over a 2024 Ford F-150 with rear seats added is a different price than a base detail on a sedan. The system has to know the difference.
              </p>
            </div>
            <div class="mt-8">
              <a href="/case-studies/fitchin-auto-detail-tint" class="btn-ghost">
                See the Fitchin build
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <h2 class="text-[2.2rem] sm:text-[3rem] leading-[1.05] font-bold tracking-tight">
          Want a system like this for your shop?
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Have a site or thinking about building one? Send what you've got — no pitch, no pressure.
        </p>
        <div class="mt-10">
          <a href="/contact" class="btn-primary">
            Free Website Review
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
