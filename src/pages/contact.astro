---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
---
<LandingLayout
  title="Contact — Designed to Elevate"
  description="Talk through your project, ask a pricing question, or just say hi. Phone, email, or a quick message form — answered within 24 hours."
  pathname="contact"
>
  <SiteHeader />

  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 pt-16 sm:pt-24 pb-12 sm:pb-16">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Contact</span>
        <h1 class="mt-6 text-[2.4rem] sm:text-[3.2rem] lg:text-[3.6rem] leading-[1.05] font-bold tracking-tight max-w-3xl">
          Let's find the leaks in your <span class="text-accent">lead system</span>.
        </h1>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl">
          For founding pricing inquiries, see the
          <a href="/grow" class="text-accent font-medium underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-colors">Founding 5 offer</a>.
          For everything else, drop a line below.
        </p>
      </div>
    </section>

    <!-- TWO-COLUMN: info + form -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-24">
        <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-14 items-start">
          <!-- LEFT: contact info -->
          <div>
            <div class="card p-7 sm:p-8 space-y-6">
              <div>
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Phone</div>
                <a
                  href="tel:7406176488"
                  class="mt-2 inline-flex items-center gap-2 font-display font-semibold text-[1.4rem] sm:text-[1.6rem] text-text hover:text-accent transition-colors"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
                  (740) 617-6488
                </a>
                <p class="mt-1 text-[0.85rem] text-text-muted">Tap to call or text — Bill picks up.</p>
              </div>

              <div class="border-t border-line pt-6">
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Email</div>
                <a
                  href="mailto:bilsonxnc@gmail.com"
                  class="mt-2 inline-flex items-center gap-2 font-display font-medium text-[1.05rem] text-text hover:text-accent transition-colors break-all"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
                  bilsonxnc@gmail.com
                </a>
              </div>

              <div class="border-t border-line pt-6">
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Service Area</div>
                <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                  Based in Zanesville, Ohio. <br />
                  Available remote anywhere in the U.S.
                </p>
              </div>

              <div class="border-t border-line pt-6">
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Response Time</div>
                <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                  Within 24 hours, every time.
                </p>
              </div>
            </div>
          </div>

          <!-- RIGHT: form -->
          <div>
            <form
              data-audit-form
              action="https://api.web3forms.com/submit"
              method="POST"
              class="card p-6 sm:p-8 space-y-5"
              novalidate
            >
              <input type="hidden" name="access_key" value="1272e2dd-abff-4804-a541-beb2bd0be075" />
              <input type="hidden" name="subject" value="New Contact Form Lead — designedtoelevate.co" />
              <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

              <div class="grid sm:grid-cols-2 gap-5">
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Name <span class="text-accent">*</span></span>
                  <input required name="name" type="text" autocomplete="name" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Your name" />
                </label>
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Business name</span>
                  <input name="business" type="text" autocomplete="organization" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Acme Auto Detail" />
                </label>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Phone</span>
                  <input name="phone" type="tel" autocomplete="tel" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="(555) 555-5555" />
                </label>
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Email <span class="text-accent">*</span></span>
                  <input required name="email" type="email" autocomplete="email" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="you@yourshop.com" />
                </label>
              </div>

              <label class="block">
                <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Website URL</span>
                <input name="website" type="url" autocomplete="url" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="https://yourshop.com" />
              </label>

              <label class="block">
                <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">What do you need help with? <span class="text-accent">*</span></span>
                <textarea required name="message" rows="5" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 resize-y" placeholder="Tell us a little about your business, where you feel stuck, or what you're hoping to fix."></textarea>
              </label>

              <button type="submit" class="btn-primary w-full !py-3.5">
                Send Message
                <span aria-hidden="true">↗</span>
              </button>

              <p
                data-audit-status
                class="hidden text-[0.92rem] text-accent font-display font-medium items-center gap-2"
                role="status"
                aria-live="polite"
              ></p>

              <p class="text-[0.78rem] text-text-muted leading-relaxed">
                Bill responds within 24 hours. No spam, no list-selling, no long-form sales calls.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- FOUNDING 5 CALLOUT -->
    <section class="relative">
      <div class="mx-auto max-w-4xl px-5 sm:px-8 py-16 sm:py-24">
        <a href="/grow" class="block group">
          <div class="card card-hover p-7 sm:p-9 flex flex-col sm:flex-row sm:items-center gap-6">
            <div class="flex-shrink-0">
              <div class="inline-flex items-center gap-2 rounded-full bg-accent/15 border border-accent/40 px-3 py-1 font-display text-[0.7rem] font-bold uppercase tracking-[0.16em] text-accent">
                <span aria-hidden="true">★</span> Founding 5
              </div>
            </div>
            <div class="flex-1">
              <h3 class="font-display font-semibold text-[1.2rem] sm:text-[1.4rem] text-text leading-snug">
                Interested in founding pricing?
              </h3>
              <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                See the Founding 5 offer — 5 founding client spots at locked-in launch pricing, plus a free Lead Leak Audit.
              </p>
            </div>
            <span class="inline-flex items-center gap-1.5 font-display font-medium text-[0.95rem] text-accent group-hover:translate-x-0.5 transition-transform flex-shrink-0">
              See the offer
              <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
