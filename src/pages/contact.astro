---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const SITE = 'https://designedtoelevate.co';

// ContactPage schema points back to the sitewide Organization so Google
// associates the phone/email on this page with the right business entity.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: `${SITE}/contact`,
  name: 'Contact Designed to Elevate',
  description:
    'Phone, email, and contact form for Designed to Elevate, a one-person Ohio web design studio for local service businesses.',
  mainEntity: { '@id': `${SITE}/#organization` },
};
---
<LandingLayout
  title="Contact Designed to Elevate | Ohio Web Design & Lead Systems"
  description="Have a site or thinking about building one? Send what you've got — no pitch, no pressure. Web design and lead systems for Ohio service businesses."
  pathname="contact"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <BreadcrumbSchema items={[
    { name: 'Home', url: `${SITE}/` },
    { name: 'Contact', url: `${SITE}/contact` },
  ]} />

  <SiteHeader />

  <main>
    <section class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8 pt-12 sm:pt-20 pb-12">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Contact</span>
        <h1 class="mt-5 text-[2.5rem] sm:text-[3.4rem] lg:text-[3.8rem] leading-[1.02] font-bold tracking-tight">
          Let's <span class="text-accent">Talk</span>.
        </h1>
        <p class="mt-6 text-text-soft text-[1.1rem] sm:text-[1.18rem] leading-relaxed max-w-2xl">
          Not sure what you need yet? Have a site or thinking about building one? Send what you've got — no pitch, no pressure.
        </p>
      </div>
    </section>

    <section class="relative">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-20">
        <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-14 items-start">
          <!-- LEFT: contact info -->
          <div>
            <div class="card p-7 sm:p-8 space-y-6">
              <div>
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Phone</div>
                <button type="button" data-call-text class="mt-2 inline-flex items-center gap-2 font-display font-semibold text-[1.4rem] sm:text-[1.5rem] text-text hover:text-accent transition-colors">
         <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
         (740) 617-6488
        </button>
                <p class="mt-1 text-[0.85rem] text-text-muted">Tap to call or text — Bill picks up.</p>
              </div>

              <div class="border-t border-line pt-6">
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Email</div>
                <a href="mailto:bilsonxnc@gmail.com" class="mt-2 inline-flex items-center gap-2 font-display font-medium text-[1.05rem] text-text hover:text-accent transition-colors break-all">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
                  bilsonxnc@gmail.com
                </a>
              </div>

              <div class="border-t border-line pt-6">
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Service Area</div>
                <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                  Coshocton, Zanesville, Newark &amp; Eastern Ohio.<br/>
                  Available remote anywhere in the U.S.
                </p>
              </div>

              <div class="border-t border-line pt-6">
                <div class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-accent">Response Time</div>
                <p class="mt-2 text-[0.95rem] text-text-soft leading-relaxed">
                  Within 24 hours, every time.
                </p>
              </div>
            </div>
          </div>

          <!-- RIGHT: form -->
          <div>
            <form
              data-audit-form
              action="https://api.web3forms.com/submit"
              method="POST"
              class="card p-6 sm:p-8 space-y-5"
              novalidate
            >
              <!-- Web3Forms wiring (working now). Brief calls for Resend
                   migration — when ready, this form needs the Vercel
                   serverless adapter + RESEND_API_KEY. Until then, this
                   posts to Web3Forms and email forwards to bilsonxnc@gmail.com. -->
              <input type="hidden" name="access_key" value="1272e2dd-abff-4804-a541-beb2bd0be075" />
              <input type="hidden" name="subject" value="New Contact Form Lead — designedtoelevate.co" />
              <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

              <div class="grid sm:grid-cols-2 gap-5">
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Name <span class="text-accent">*</span></span>
                  <input required name="name" type="text" autocomplete="name" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Your name" />
                </label>
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Business name</span>
                  <input name="business" type="text" autocomplete="organization" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="Acme Auto Detail" />
                </label>
              </div>

              <label class="block">
                <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Email <span class="text-accent">*</span></span>
                <input required name="email" type="email" autocomplete="email" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="you@yourshop.com" />
              </label>

              <div class="grid sm:grid-cols-2 gap-5">
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Phone <span class="text-text-muted">(optional)</span></span>
                  <input name="phone" type="tel" autocomplete="tel" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="(555) 555-5555" />
                </label>
                <label class="block">
                  <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Website URL <span class="text-text-muted">(if you have one)</span></span>
                  <input name="website" type="url" autocomplete="url" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60" placeholder="https://yourshop.com (optional)" />
                </label>
              </div>

              <label class="block">
                <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">Estimated budget range <span class="text-text-muted">(optional)</span></span>
                <select name="budget" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 appearance-none bg-no-repeat bg-[right_0.85rem_center] bg-[length:1rem]" style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%239AA0AA' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>&quot;); padding-right: 2.5rem;">
                  <option value="Not sure yet" selected>Not sure yet</option>
                  <option value="Under $1,500">Under $1,500</option>
                  <option value="$1,500–$3,000">$1,500–$3,000</option>
                  <option value="$3,000–$5,000">$3,000–$5,000</option>
                  <option value="$5,000+">$5,000+</option>
                </select>
              </label>

              <label class="block">
                <span class="block font-display font-medium text-[0.82rem] text-text-soft mb-1.5">What do you need help with? <span class="text-accent">*</span></span>
                <textarea required name="message" rows="5" class="w-full rounded-md bg-surface-2 border border-line px-3.5 py-2.5 text-[0.95rem] text-text placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent/60 resize-y" placeholder="E.g., my current site isn't getting calls — I need a new site for my business — I want better Google rankings"></textarea>
              </label>

              <button type="submit" class="btn-primary w-full !py-3.5">
                Send
                <span aria-hidden="true">↗</span>
              </button>

              <p
                data-audit-status
                class="hidden text-[0.92rem] text-accent font-display font-medium items-center gap-2"
                role="status"
                aria-live="polite"
              ></p>

              <p class="text-[0.78rem] text-text-muted leading-relaxed">
                Bill responds within 24 hours. No spam, no list-selling, no long-form sales calls.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
