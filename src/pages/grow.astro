---
<LandingLayout
  title="Custom Quote & Booking Systems for Service Businesses | Designed to Elevate"
  description="Replace your contact form with a custom quote and booking system. Built for local service businesses — auto detail, barbershops, contractors, HVAC, and more. Founding pricing open."
  pathname="grow"
>
  <LandingHeader />
  <main class="pb-24 md:pb-0">
    <HeroSection />
    <ProblemSection />
    <SystemSection />
    <WizardSection />
    <ProofSection />
    <OffersSection />
    <WhichOneFitsSection />
    <WhoThisIsForSection />
    <FoundingCapacitySection />
    <AboutSection />
    <ProcessSection />
    <FAQSection />
    <ApplyForm />
    <FinalCTASection />
  </main>
  <StickyMobileCTA />
</LandingLayout>
