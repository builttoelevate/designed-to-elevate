import LandingLayout from '../layouts/LandingLayout.astro';
import LandingHeader from '../components/landing/LandingHeader.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import ProblemSection from '../components/landing/ProblemSection.astro';
import SystemSection from '../components/landing/SystemSection.astro';
import WizardSection from '../components/landing/WizardSection.astro';
import ProofSection from '../components/landing/ProofSection.astro';
import OffersSection from '../components/landing/OffersSection.astro';
import WhichOneFitsSection from '../components/landing/WhichOneFitsSection.astro';
