---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
---
<LandingLayout
  title="Page not found | Designed to Elevate"
  description="That page doesn't exist or has moved. Head back home or get in touch."
  pathname="404"
  noindex={true}
>
  <SiteHeader />

  <main>
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-3xl px-5 sm:px-8 pt-20 sm:pt-28 pb-20 sm:pb-28 text-center">
        <span class="eyebrow justify-center"><span class="dot" aria-hidden="true"></span> 404</span>
        <h1 class="font-display text-4xl sm:text-6xl font-bold tracking-tight mt-4 mb-4">
          This page took a wrong turn.
        </h1>
        <p class="text-text-muted text-lg leading-relaxed max-w-xl mx-auto mb-9">
          The page you're after doesn't exist or has moved. No big deal — here's the way back.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/" class="btn-primary">Back to home</a>
          <a href="/contact" class="btn-ghost">Get in touch</a>
        </div>

        <div class="mt-12 pt-8 border-t border-line">
          <p class="text-xs uppercase tracking-[0.18em] text-text-muted mb-4">Popular pages</p>
          <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
            <a href="/web-design" class="text-text-soft hover:text-accent transition-colors">Web design</a>
            <a href="/custom-lead-systems" class="text-text-soft hover:text-accent transition-colors">Custom lead systems</a>
            <a href="/local-seo" class="text-text-soft hover:text-accent transition-colors">Local SEO</a>
            <a href="/case-studies" class="text-text-soft hover:text-accent transition-colors">Case studies</a>
            <a href="/about" class="text-text-soft hover:text-accent transition-colors">About</a>
          </nav>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
