    name: 'The Works',
    code: 'T3',
    setup: '$4,497',
    blurb: 'Everything Fitchin has — T2 + automated SMS reviews + customer self-service online booking. The whole system, on autopilot.',
    features: [
      'Everything in T2',
      'Automated SMS Google-review requests (skips no-shows)',
      'Customer self-service online booking → calendar',
    ],
    highlight: false,
  },
