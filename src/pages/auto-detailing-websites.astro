  areaServed: { '@type': 'State', name: 'Ohio' },
  audience: { '@type': 'BusinessAudience', name: 'Auto detailing and ceramic coating shops' },
  url: `${SITE}/auto-detailing-websites`,
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: '997',
    highPrice: '4497',
    priceCurrency: 'USD',
    offerCount: '6',
    description: 'Form line install: $997 / $1,497 / $2,497. Website line install: $1,497 / $2,497 / $4,497. You own everything outright at handoff — no required ongoing fee.',
  },
};

