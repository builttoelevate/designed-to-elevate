// No nav, single conversion path. Minimal header + footer baked in here so we
// don't reuse SiteHeader/SiteFooter (which would pull paid traffic off to other
// pages). Mirrors the barbershop-websites LP structure. noindex so it doesn't
// compete with the indexed /auto-detail-websites SEO page. LandingLayout still
// provides the global <head>, sticky-mobile-CTA observer JS, and the call/text
// dialog.
import LandingLayout from '../layouts/LandingLayout.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import QuoteFlowSection from '../components/landing/QuoteFlowSection.astro';

const SITE = 'https://designedtoelevate.co';
const PHONE_DISPLAY = '(740) 617-6488';
const PHONE_TEL = 'tel:7406176488';
const EMAIL = 'bilsonxnc@gmail.com';
const QUOTE_HREF = '#quote';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Auto Detailing Website Design',
  serviceType: 'Website and quote-system design for auto detailing and ceramic coating shops',
  description:
    'Detailing and ceramic coating shop websites built around a real quote system — vehicle-by-vehicle pricing for detail packages and ceramic tiers, lead capture before the final step, and a text-to-book handoff. Two product lines: add the wizard to your existing site (Form line, $997–$2,497 install) or build a new site with the wizard included (Website line, $1,497–$4,497 install). Install pricing only. You own everything at handoff — no required ongoing fee.',
