const caseFacts = [
  '378 vehicle configurations priced',
  'Detailing, ceramic & tint in one guided flow',
  'Partial-lead capture — no quote lost',
  'Quote texts straight to the shop to book',
  'Sub-second mobile loads built for Google Ads, SEO, and local traffic',
];

const caseBullets = [
  'One quote flow across detailing, ceramic coating, tint, and add-ons — priced by vehicle',
  'Ceramic tiers shown inline so customers see the value gap (Crystal+ → Pro+ → Max G+)',
  'Condition-aware detailing questions — interior condition, pet hair, stains',
  'Lead capture before the final step — partial quotes still land in the dashboard',
  'The finished quote deep-links into a text to book — no phone tag',
];

// Real, measured PageSpeed Insights scores on the live Fitchin build
// (desktop, May 2026). Same numbers surfaced on /seo — keep in sync there
// if they change.
const caseScores = [
  { score: '98', label: 'Performance' },
  { score: '97', label: 'Accessibility' },
  { score: '100', label: 'Best Practices' },
  { score: '100', label: 'SEO' },
];

const proofItems = [
  {
    src: '/wizard/step-1-service.png',
    title: 'Pick the service',
    description:
      'Detailing, ceramic coating, or tint — your full menu in one guided flow. Customers self-select, then the questions adapt to what they chose.',
  },
  {
    src: '/wizard/step-5-summary.png',
    title: 'An estimate they can adjust',
    description:
      'Customers see an itemized quote they can toggle line by line, with a live subtotal, tax, and total — before anything is booked.',
  },
  {
    src: '/wizard/step-6-final-quote.png',
    title: 'Priced and ready to book',
