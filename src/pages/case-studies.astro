---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

const SITE = 'https://designedtoelevate.co';

const studies = [
  {
    label: 'Auto Detail · Window Tint',
    name: 'Fitchin Automotive Detailing & Window Tinting',
    location: 'Coshocton, Ohio',
    summary:
      'Custom website plus a 378-vehicle quote wizard that takes paid traffic and Google Business Profile clicks straight to a quote request.',
    bullets: [
      '378-vehicle pricing logic',
      'Tiered film + add-on upgrades',
      'Lead capture before the final step',
    ],
    image: '/showcase/fitchin-mobile.png',
    detail: '/case-studies/fitchin-auto-detail-tint',
    live: 'https://fitchinautodetail.com',
    badges: ['Live in Production', 'Full Wizard Install'],
  },
  {
    label: 'Barbershop',
    name: 'Modern Classic Barbershop & Shave Parlor',
    location: 'Zanesville, Ohio',
    summary:
      'Premium custom-designed brand hub running on top of Square booking and Shopify product, with a custom waitlist and customer-login layer on top.',
    bullets: [
      'Custom front end on Square API',
      'Square + Shopify integration',
      'Auto-review + waitlist flows',
    ],
    image: '/showcase/modern-classic-mobile.png',
    detail: '/case-studies/modern-classic-barbershop',
    live: 'https://mdrnclassic.com',
    badges: ['Live in Production', 'Custom Square Integration'],
  },
  {
    label: 'Event Transportation',
    name: 'All Transport Party Bus Rentals',
    location: 'Carrollton, Ohio',
    summary:
      'Mobile-first site with service-by-occasion sections, fleet gallery, and a quote/availability flow built for local-search visibility across Eastern Ohio and NW Pennsylvania.',
    bullets: [
      'Mobile-first quote/availability flow',
      'Local SEO across 100-mile radius',
      'Service-by-occasion structure',
    ],
    image: '/showcase/all-transport-mobile.png',
    detail: '/case-studies/all-transport-party-bus',
    live: 'https://www.alltransportbusco.com',
    badges: ['Live in Production', 'Local-Search Lead Site'],
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Case Studies — Designed to Elevate',
  description:
    'Three live builds for local Ohio service businesses by Designed to Elevate: Fitchin Auto Detail & Tint, Modern Classic Barbershop, and All Transport Party Bus Rentals.',
  url: `${SITE}/case-studies`,
};
---
<LandingLayout
  title="Case Studies — What I've Built | Designed to Elevate"
  description="Three live local Ohio builds by Designed to Elevate: Fitchin Auto Detail & Tint's 378-vehicle quote system, Modern Classic Barbershop's custom Square integration, and All Transport's local-search-driven event-rental site."
  pathname="case-studies"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <SiteHeader />

  <main>
    <!-- HERO -->
    <section id="top" class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8 pt-12 sm:pt-20 pb-16 sm:pb-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Case Studies</span>
        <h1 class="mt-5 text-[2.5rem] sm:text-[3.4rem] lg:text-[4rem] leading-[1.02] font-bold tracking-tight">
          What I've <span class="text-accent">Built</span>
        </h1>
        <p class="mt-6 text-text-soft text-[1.1rem] leading-relaxed max-w-3xl">
          Three live builds. Three real shops. Each one solves a different problem — quote logic, brand unification, and local-search-driven conversion. All running today.
        </p>
      </div>
    </section>

    <!-- DIRECTORY GRID -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-16 sm:py-24">
        <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-5 lg:gap-6">
          {studies.map((s) => (
            <article class="card card-hover overflow-hidden flex flex-col group">
              <a href={s.detail ?? s.live} target={s.detail ? undefined : '_blank'} rel={s.detail ? undefined : 'noopener noreferrer'} class="relative block aspect-[9/12] bg-surface-2 overflow-hidden border-b border-line">
                <img
                  src={s.image}
                  alt={`${s.name} mobile site preview`}
                  class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
                <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-bg/85 backdrop-blur px-2 py-0.5 text-[0.6rem] font-display tracking-wider uppercase text-text-soft border border-line">
                    <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                    Live
                  </span>
                </div>
              </a>

              <div class="p-6 flex-1 flex flex-col">
                <div class="text-[0.68rem] uppercase tracking-[0.18em] text-accent font-display">{s.label}</div>
                <h2 class="mt-2 font-display font-semibold text-[1.15rem] text-text leading-snug">{s.name}</h2>
                <div class="mt-1 text-[0.85rem] text-text-muted">{s.location}</div>

                <p class="mt-4 text-[0.92rem] text-text-soft leading-relaxed">{s.summary}</p>

                <ul class="mt-4 space-y-1.5">
                  {s.bullets.map((b) => (
                    <li class="flex items-start gap-2.5 text-[0.85rem] text-text-soft leading-snug">
                      <span class="mt-1.5 inline-block h-1.5 w-1.5 rounded-full bg-accent flex-shrink-0" aria-hidden="true"></span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-6 pt-5 border-t border-line flex flex-wrap gap-3 items-center">
                  {s.detail ? (
                    <>
                      <a href={s.detail} class="inline-flex items-center gap-1.5 font-display font-medium text-[0.9rem] text-accent group-hover:translate-x-0.5 transition-transform">
                        Read the case study
                        <span aria-hidden="true">→</span>
                      </a>
                      <a href={s.live} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 font-display font-medium text-[0.85rem] text-text-muted hover:text-text transition-colors">
                        Live site
                        <span aria-hidden="true">↗</span>
                      </a>
                    </>
                  ) : (
                    <a href={s.live} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 font-display font-medium text-[0.9rem] text-accent group-hover:translate-x-0.5 transition-transform">
                      Visit live site
                      <span aria-hidden="true">↗</span>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <h2 class="text-[2.2rem] sm:text-[3rem] leading-[1.05] font-bold tracking-tight">
          Want to be the next one?
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Send your website. I'll tell you what I'd fix first. No pitch, no pressure.
        </p>
        <div class="mt-10">
          <a href="/contact" class="btn-primary">
            Start a Conversation
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
