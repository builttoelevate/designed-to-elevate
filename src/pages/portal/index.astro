---
export const prerender = false;

import PortalLayout from '../../layouts/PortalLayout.astro';
import { createServerSupabase } from '../../lib/supabase';
import { firstName } from '../../lib/session';
import {
  STATUS_LABELS,
  STATUS_ORDER,
  categoryLabel,
  priorityLabel,
  relativeDate,
  type RequestStatus,
} from '../../lib/portal';

const session = Astro.locals.session!; // middleware guarantees this
if (session.role === 'admin') {
  return Astro.redirect('/portal/admin');
}

const supabase = createServerSupabase({ cookies: Astro.cookies, request: Astro.request });

const filter = (Astro.url.searchParams.get('status') || '').toLowerCase() as RequestStatus | '';
const validFilter = (STATUS_ORDER as string[]).includes(filter) ? filter : '';

let q = supabase
  .from('requests')
  .select('id, title, status, priority, category, created_at')
  .order('created_at', { ascending: false });

if (validFilter) q = q.eq('status', validFilter);

const { data: requests, error } = await q;
const list = requests ?? [];

// Surface "needs your action" jobs separately so the client sees them the
// moment the page loads — these are anything the studio has switched into
// waiting_on_client. Sorted by urgency (urgent → important → normal) within
// the bucket via a stable ordering, then by created_at desc.
const PRI_RANK: Record<string, number> = { urgent: 0, important: 1, normal: 2 };
const waitingList = (requests ?? [])
  .filter((r) => r.status === 'waiting_on_client')
  .slice()
  .sort((a, b) => {
    const pa = PRI_RANK[a.priority ?? 'normal'] ?? 2;
    const pb = PRI_RANK[b.priority ?? 'normal'] ?? 2;
    if (pa !== pb) return pa - pb;
    return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
  });
const hasWaiting = waitingList.length > 0;

// Per the plan, clients only have one client_id. The dashboard scopes by RLS,
// so we don't need to pass client_id explicitly.
---
<PortalLayout title="Your requests | Client Hub" session={session}>
  <section class="mb-7">
    <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
      Welcome back, {firstName(session)}.
    </h1>
  </section>

  {error && (
    <div class="ph-flash" data-tone="error">{error.message}</div>
  )}

  {hasWaiting && !validFilter && (
    <section class="ph-waiting-banner mb-6" aria-label="Jobs that need your action">
      <div class="flex items-start gap-3">
        <span class="ph-waiting-dot" aria-hidden="true"></span>
        <div class="flex-1 min-w-0">
          <div class="font-display font-bold text-base sm:text-lg">
            {waitingList.length === 1
              ? '1 job needs your response'
              : `${waitingList.length} jobs need your response`}
          </div>
          <p class="text-sm text-text-muted mt-1">
            We're paused on {waitingList.length === 1 ? 'this one' : 'these'} until you reply. Tap a card below to open it.
          </p>
          <ul class="mt-3 space-y-1.5">
            {waitingList.map((r) => (
              <li>
                <a href={`/portal/r/${r.id}`} class="ph-waiting-link inline-flex items-baseline gap-2 max-w-full">
                  <span class="truncate font-medium">{r.title}</span>
                  <span class="ph-waiting-urgency" data-priority={r.priority}>
                    {r.priority === 'urgent' ? "Blocking — can't move forward" : r.priority === 'important' ? "Soon — don't sit on it" : 'Whenever you get a chance'}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <div class="flex flex-wrap items-center gap-2 mb-4">
    <a href="/portal" class:list={["px-3 py-1.5 rounded-full text-sm border transition", validFilter === '' ? 'bg-accent text-bg border-accent' : 'border-line text-text-muted hover:text-text']}>
      All
    </a>
    {STATUS_ORDER.map((s) => (
      <a
        href={`/portal?status=${s}`}
        class:list={["px-3 py-1.5 rounded-full text-sm border transition", validFilter === s ? 'bg-accent text-bg border-accent' : 'border-line text-text-muted hover:text-text']}
      >
        {STATUS_LABELS[s]}
        {s === 'waiting_on_client' && waitingList.length > 0 && (
          <span class="ml-1.5 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1 rounded-full bg-yellow-300/20 text-yellow-200 text-[10px] font-bold">
            {waitingList.length}
          </span>
        )}
      </a>
    ))}
  </div>

  {list.length === 0 ? (
    <div class="ph-card p-8 sm:p-12 text-center">
      <h2 class="font-display text-xl font-bold mb-2">No requests yet</h2>
      <p class="text-text-muted mb-6">Click below when you need something updated on your site.</p>
      <a href="/portal/new" class="btn-primary">Submit a Change</a>
    </div>
  ) : (
    <ul class="space-y-3">
      {list.map((r) => {
        const waiting = r.status === 'waiting_on_client';
        return (
          <li>
            <a
              href={`/portal/r/${r.id}`}
              class:list={['ph-card block p-4 sm:p-5 transition', waiting ? 'ph-card-waiting' : 'hover:border-accent/40']}
              aria-label={waiting ? `Needs your response: ${r.title}` : r.title}
            >
              <div class="flex items-start justify-between gap-3 mb-1.5">
                <div class="min-w-0">
                  {waiting && (
                    <div class="text-[10px] font-bold uppercase tracking-[0.14em] text-yellow-300 mb-1 inline-flex items-center gap-1.5">
                      <span class="ph-waiting-dot-sm" aria-hidden="true"></span>
                      Needs your response
                    </div>
                  )}
                  <h3 class="font-display font-semibold text-base sm:text-lg leading-tight">{r.title}</h3>
                </div>
                <span class="ph-badge shrink-0" data-status={r.status}>{STATUS_LABELS[r.status as RequestStatus]}</span>
              </div>
              <div class="text-xs text-text-muted flex flex-wrap items-center gap-x-3 gap-y-1">
                <span>{categoryLabel(r.category)}</span>
                <span class="ph-pri" data-priority={r.priority}>{priorityLabel(r.priority)}</span>
                <span>{relativeDate(r.created_at)}</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )}

  <style>
    .ph-waiting-banner {
      position: relative;
      padding: 1.1rem 1.2rem;
      border-radius: 0.85rem;
      border: 1px solid rgba(250, 204, 21, 0.32);
      background: linear-gradient(135deg, rgba(250, 204, 21, 0.08), rgba(255, 107, 26, 0.05));
    }
    .ph-waiting-dot {
      display: inline-block;
      width: 0.65rem;
      height: 0.65rem;
      margin-top: 0.55rem;
      border-radius: 999px;
      background: #facc15;
      box-shadow: 0 0 0 0 rgba(250, 204, 21, 0.6);
      animation: ph-pulse 1.8s ease-out infinite;
      flex-shrink: 0;
    }
    .ph-waiting-dot-sm {
      display: inline-block;
      width: 0.45rem;
      height: 0.45rem;
      border-radius: 999px;
      background: #facc15;
      box-shadow: 0 0 0 0 rgba(250, 204, 21, 0.6);
      animation: ph-pulse 1.8s ease-out infinite;
    }
    @keyframes ph-pulse {
      0%   { box-shadow: 0 0 0 0 rgba(250, 204, 21, 0.55); }
      70%  { box-shadow: 0 0 0 10px rgba(250, 204, 21, 0); }
      100% { box-shadow: 0 0 0 0 rgba(250, 204, 21, 0); }
    }
    .ph-waiting-link {
      color: var(--color-text);
      text-decoration: none;
      padding: 0.35rem 0.55rem;
      border-radius: 0.4rem;
      transition: background 120ms ease;
    }
    .ph-waiting-link:hover {
      background: rgba(250, 204, 21, 0.08);
    }
    .ph-waiting-urgency {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      color: var(--color-text-muted);
    }
    .ph-waiting-urgency[data-priority="urgent"]    { color: #fca5a5; }
    .ph-waiting-urgency[data-priority="important"] { color: #fcd34d; }

    .ph-card-waiting {
      border-color: rgba(250, 204, 21, 0.35) !important;
      background: linear-gradient(180deg, rgba(250, 204, 21, 0.04), transparent 60%);
    }
    .ph-card-waiting:hover {
      border-color: rgba(250, 204, 21, 0.55) !important;
    }
    @media (prefers-reduced-motion: reduce) {
      .ph-waiting-dot,
      .ph-waiting-dot-sm { animation: none; }
    }
  </style>
</PortalLayout>
