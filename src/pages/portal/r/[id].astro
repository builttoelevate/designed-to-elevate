---
export const prerender = false;

import PortalLayout from '../../../layouts/PortalLayout.astro';
import { createServerSupabase, createServiceSupabase } from '../../../lib/supabase';
import { isImageFilename } from '../../../lib/file-uploads';
import {
  STATUS_LABELS,
  STATUS_DESCRIPTIONS,
  categoryLabel,
  externalUrl,
  priorityLabel,
  relativeDate,
  type RequestStatus,
} from '../../../lib/portal';

type UploaderTag = 'admin' | 'client' | 'unknown';

interface SignedFile {
  id: string;
  filename: string;
  view: string;
  download: string;
  isImage: boolean;
  thumb: string | null;
  uploader: UploaderTag;
  uploaderName: string | null;
  isSelf: boolean;
}

const session = Astro.locals.session!;
if (session.role === 'admin') {
  return Astro.redirect(`/portal/admin/r/${Astro.params.id}`);
}

const { id } = Astro.params;
if (!id) return Astro.redirect('/portal');

const supabase = createServerSupabase({ cookies: Astro.cookies, request: Astro.request });

const { data: req, error } = await supabase
  .from('requests')
  .select('id, title, description, status, priority, category, page_url, created_at, preferred_completion_date, completed_at, instructions, instructions_ack_at')
  .eq('id', id)
  .maybeSingle();

if (error || !req) {
  return Astro.redirect('/portal');
}

// Service-role client for both the files query and the signed URLs. The
// profiles RLS policy (`profiles_select_self_or_admin`) only lets a client
// read their OWN profile row, so a join against `profiles:uploaded_by` from
// the user's session client would return null for every admin upload — the
// client wouldn't be able to tell who responded. Reading the join through
// service role is privacy-safe: the only field exposed is the admin's
// display name + role, both of which are already public ("Designed to
// Elevate").
const admin = createServiceSupabase();

const [{ data: files }, { data: comments }] = await Promise.all([
  admin
    .from('request_files')
    .select('id, file_url, filename, uploaded_by, created_at, profiles:uploaded_by (full_name, role)')
    .eq('request_id', id)
    .order('created_at'),
  supabase
    .from('comments')
    .select('id, body, created_at, author_id, profiles:author_id (full_name, role)')
    .eq('request_id', id)
    .order('created_at'),
]);

// Mint a viewing URL (opens inline in a new tab) and a forced-download URL
// (Content-Disposition: attachment with the original filename) per file. 2h
// TTL so a tap after a quick context-switch still works. View URL doubles
// as the thumbnail src when the file is an image.
const SIGNED_TTL_SECONDS = 60 * 60 * 2;
const signedFiles: SignedFile[] = [];
for (const f of files ?? []) {
  const [{ data: viewData }, { data: dlData }] = await Promise.all([
    admin.storage.from('request-files').createSignedUrl(f.file_url, SIGNED_TTL_SECONDS),
    admin.storage.from('request-files').createSignedUrl(f.file_url, SIGNED_TTL_SECONDS, {
      download: f.filename,
    }),
  ]);
  if (!viewData?.signedUrl || !dlData?.signedUrl) continue;

  const profile = (f as any).profiles as { full_name: string | null; role: string | null } | null;
  const uploader: UploaderTag = !f.uploaded_by
    ? 'unknown'
    : profile?.role === 'admin'
    ? 'admin'
    : 'client';
  const isImage = isImageFilename(f.filename);

  signedFiles.push({
    id: f.id,
    filename: f.filename,
    view: viewData.signedUrl,
    download: dlData.signedUrl,
    isImage,
    thumb: isImage ? viewData.signedUrl : null,
    uploader,
    uploaderName: profile?.full_name ?? null,
    isSelf: !!f.uploaded_by && f.uploaded_by === session.userId,
  });
}

// Client-perspective uploader label. The viewer is the client; admin uploads
// are responses from the studio, and the client's own files are "You".
function uploaderLabel(f: SignedFile): string {
  if (f.uploader === 'admin') return 'Designed to Elevate';
  if (f.isSelf) return 'You';
  if (f.uploader === 'client') return f.uploaderName || 'Teammate';
  return '';
}

const editable = req.status === 'new';
const status = req.status as RequestStatus;
---
<PortalLayout title={`${req.title} | Client Hub`} session={session}>
  <div class="mb-5">
    <a href="/portal" class="text-sm text-text-muted hover:text-text inline-flex items-center gap-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Back to all requests
    </a>
  </div>

  <article class="ph-card p-5 sm:p-7">
    <div class="flex items-start justify-between gap-4 mb-3">
      <h1 class="font-display text-xl sm:text-2xl font-bold tracking-tight leading-tight">{req.title}</h1>
      <span class="ph-badge shrink-0" data-status={status}>{STATUS_LABELS[status]}</span>
    </div>
    <p class="text-sm text-text-muted mb-5">{STATUS_DESCRIPTIONS[status]}</p>

    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5 text-xs">
      <div>
        <dt class="text-text-muted uppercase tracking-wide">Type</dt>
        <dd class="mt-0.5 font-medium">{categoryLabel(req.category)}</dd>
      </div>
      <div>
        <dt class="text-text-muted uppercase tracking-wide">Priority</dt>
        <dd class="mt-0.5 font-medium ph-pri" data-priority={req.priority}>{priorityLabel(req.priority)}</dd>
      </div>
      <div>
        <dt class="text-text-muted uppercase tracking-wide">Submitted</dt>
        <dd class="mt-0.5 font-medium">{relativeDate(req.created_at)}</dd>
      </div>
      {req.preferred_completion_date && (
        <div>
          <dt class="text-text-muted uppercase tracking-wide">Preferred</dt>
          <dd class="mt-0.5 font-medium">{new Date(req.preferred_completion_date).toLocaleDateString()}</dd>
        </div>
      )}
    </dl>

    {req.page_url && (
      <div class="mb-5">
        <div class="text-xs text-text-muted uppercase tracking-wide mb-1">Page</div>
        <a href={externalUrl(req.page_url)} target="_blank" rel="noopener" class="text-sm underline break-all">{req.page_url}</a>
      </div>
    )}

    <div class="mb-2 text-xs text-text-muted uppercase tracking-wide">Details</div>
    <p class="whitespace-pre-wrap leading-relaxed text-text/90">{req.description}</p>

    {req.instructions && (
      <div class="mt-6 rounded-lg border border-accent/40 bg-accent/[0.06] p-4" data-instructions>
        <div class="text-xs text-accent uppercase tracking-wide font-semibold mb-2">Instructions from Designed to Elevate</div>
        <p class="whitespace-pre-wrap leading-relaxed text-sm text-text/90">{req.instructions}</p>
        <div class="mt-4" data-ack-wrap>
          {req.instructions_ack_at ? (
            <span class="inline-flex items-center gap-1.5 text-sm text-green-400" data-ack-done>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              You confirmed you've read this
            </span>
          ) : (
            <button type="button" class="btn-primary !py-2 !px-4 !text-[0.85rem]" data-ack-btn data-request-id={req.id}>
              <span data-ack-label>Got it — I've read this</span>
            </button>
          )}
        </div>
      </div>
    )}

    {signedFiles.length > 0 && (
      <>
        <div class="mt-6 mb-2 flex items-center justify-between gap-3">
          <span class="text-xs text-text-muted uppercase tracking-wide">Attachments</span>
          {signedFiles.length > 1 && (
            <a
              href={`/api/portal/requests/${req.id}/files/download-all`}
              class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold rounded border border-line text-text-soft hover:text-accent hover:border-accent/40 transition"
              aria-label="Download all attachments as a zip"
            >
              Download all
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </a>
          )}
        </div>
        <ul class="space-y-2">
          {signedFiles.map((f) => {
            const label = uploaderLabel(f);
            return (
              <li class="ph-card flex flex-wrap items-center gap-x-3 gap-y-2 px-3 py-2">
                <div class="flex items-center gap-3 min-w-0 flex-1 basis-full sm:basis-0">
                {f.isImage && f.thumb ? (
                  <a
                    href={f.view}
                    target="_blank"
                    rel="noopener"
                    class="shrink-0 block w-14 h-14 rounded overflow-hidden border border-line bg-surface-2"
                    aria-label={`Open ${f.filename} in a new tab`}
                  >
                    <img
                      src={f.thumb}
                      alt=""
                      width="56"
                      height="56"
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover"
                    />
                  </a>
                ) : (
                  <div class="shrink-0 w-14 h-14 rounded border border-line bg-surface-2 flex items-center justify-center text-text-muted" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  </div>
                )}

                <div class="flex-1 min-w-0">
                  <a
                    href={f.view}
                    target="_blank"
                    rel="noopener"
                    class="block text-sm truncate hover:text-accent transition"
                    title={`Open ${f.filename} in a new tab`}
                  >{f.filename}</a>
                  {label && <div class="text-xs text-text-muted mt-0.5 truncate">{label}</div>}
                </div>
                </div>

                <div class="flex flex-wrap items-center gap-2 shrink-0">
                <a
                  href={f.download}
                  class="shrink-0 inline-flex items-center justify-center p-1.5 rounded text-text-muted hover:text-accent hover:bg-accent/10 transition"
                  aria-label={`Download ${f.filename}`}
                  title={`Download ${f.filename}`}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                </a>
                {f.uploader !== 'admin' && (
                  <button
                    type="button"
                    class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold rounded border border-line text-text-muted hover:text-red-400 hover:border-red-400/40 transition"
                    data-remove-file
                    data-request-id={req.id}
                    data-file-id={f.id}
                    data-filename={f.filename}
                    aria-label={`Remove ${f.filename}`}
                  >
                    Remove
                  </button>
                )}
                </div>
              </li>
            );
          })}
        </ul>
      </>
    )}

    {editable && (
      <p class="ph-hint mt-6">
        You can still edit this request — work hasn't started yet.
        <a href={`/portal/r/${req.id}/edit`} class="underline ml-1">Edit</a>
      </p>
    )}
  </article>

  <section class="mt-8">
    <h2 class="font-display text-lg font-bold tracking-tight mb-3">Messages</h2>

    <ul class="space-y-3 mb-4">
      {(comments ?? []).length === 0 && (
        <li class="text-sm text-text-muted">No messages yet.</li>
      )}
      {(comments ?? []).map((c: any) => {
        const isAdminAuthor = c.profiles?.role === 'admin';
        return (
          <li class="ph-card p-3 sm:p-4">
            <div class="flex items-center gap-2 mb-1 text-xs text-text-muted">
              <span class="font-semibold text-text">
                {isAdminAuthor ? 'Bill — Designed to Elevate' : (c.profiles?.full_name || 'You')}
              </span>
              <span>·</span>
              <span>{relativeDate(c.created_at)}</span>
            </div>
            <p class="whitespace-pre-wrap text-sm leading-relaxed">{c.body}</p>
          </li>
        );
      })}
    </ul>

    <form class="ph-card p-3 sm:p-4" data-comment-form data-request-id={req.id}>
      <label for="body" class="sr-only">Message</label>
      <textarea id="body" name="body" required class="ph-input" placeholder="Reply with a note, more details, or a question…" rows="3"></textarea>
      <div class="flex items-center justify-end gap-2 mt-2">
        <button type="submit" class="btn-primary text-sm py-2 px-4">
          <span data-btn-label>Send</span>
        </button>
      </div>
      <div class="ph-flash hidden mt-3" data-flash></div>
    </form>
  </section>
</PortalLayout>

<script>
  // Remove an attachment the client uploaded. Admin completion screenshots
  // don't render a Remove button (and the API rejects it anyway).
  document.querySelectorAll<HTMLButtonElement>('[data-remove-file]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const requestId = btn.dataset.requestId!;
      const fileId = btn.dataset.fileId!;
      const filename = btn.dataset.filename || 'this file';
      if (!confirm(`Remove ${filename}? This can't be undone.`)) return;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Removing…';
      try {
        const res = await fetch(`/api/portal/requests/${requestId}/files/${fileId}`, {
          method: 'DELETE',
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || `HTTP ${res.status}`);
        }
        btn.closest('li')?.remove();
      } catch (err) {
        btn.disabled = false;
        btn.textContent = original;
        alert(`Couldn't remove: ${err instanceof Error ? err.message : 'unknown'}`);
      }
    });
  });

  // Instructions acknowledgment — stamps instructions_ack_at and swaps the
  // button for a confirmation line in place.
  const ackBtn = document.querySelector<HTMLButtonElement>('[data-ack-btn]');
  if (ackBtn) {
    const ackLabel = ackBtn.querySelector<HTMLElement>('[data-ack-label]');
    ackBtn.addEventListener('click', async () => {
      const requestId = ackBtn.dataset.requestId;
      if (!requestId) return;
      ackBtn.disabled = true;
      if (ackLabel) ackLabel.textContent = 'Saving…';
      try {
        const res = await fetch(`/api/portal/requests/${requestId}/acknowledge`, { method: 'POST' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const wrap = document.querySelector<HTMLElement>('[data-ack-wrap]');
        if (wrap) {
          wrap.innerHTML =
            '<span class="inline-flex items-center gap-1.5 text-sm text-green-400">' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>' +
            "You confirmed you've read this</span>";
        }
      } catch {
        ackBtn.disabled = false;
        if (ackLabel) ackLabel.textContent = "Couldn't save — tap to retry";
      }
    });
  }

  const form = document.querySelector<HTMLFormElement>('[data-comment-form]');
  const flash = document.querySelector<HTMLElement>('[data-flash]');
  const label = document.querySelector<HTMLElement>('[data-btn-label]');

  if (form && flash && label) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const requestId = form.dataset.requestId;
      const body = (form.querySelector('textarea[name="body"]') as HTMLTextAreaElement).value.trim();
      if (!body || !requestId) return;

      label.textContent = 'Sending…';
      form.querySelectorAll('textarea,button').forEach((el) =>
        ((el as HTMLTextAreaElement | HTMLButtonElement).disabled = true)
      );

      try {
        const res = await fetch(`/api/portal/requests/${requestId}/comments`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ body }),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);
        window.location.reload();
      } catch (err) {
        flash.dataset.tone = 'error';
        flash.textContent = err instanceof Error ? err.message : 'Could not send';
        flash.classList.remove('hidden');
        label.textContent = 'Send';
        form.querySelectorAll('textarea,button').forEach((el) =>
          ((el as HTMLTextAreaElement | HTMLButtonElement).disabled = false)
        );
      }
    });
  }
</script>
