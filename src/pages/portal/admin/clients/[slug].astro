---
export const prerender = false;

import PortalLayout from '../../../../layouts/PortalLayout.astro';
import { createServiceSupabase } from '../../../../lib/supabase';
import { STATUS_LABELS, relativeDate, type RequestStatus } from '../../../../lib/portal';

const session = Astro.locals.session!;
const { slug } = Astro.params;
if (!slug) return Astro.redirect('/portal/admin/clients');

const admin = createServiceSupabase();

const { data: client } = await admin
  .from('clients')
  .select('id, slug, business_name, primary_contact_email, site_url, status, created_at')
  .eq('slug', slug)
  .maybeSingle();

if (!client) return Astro.redirect('/portal/admin/clients');

const [{ data: members }, { data: requests }] = await Promise.all([
  admin
    .from('client_users')
    .select('id, role, created_at, profiles:user_id (id, full_name)')
    .eq('client_id', client.id),
  admin
    .from('requests')
    .select('id, title, status, created_at')
    .eq('client_id', client.id)
    .order('created_at', { ascending: false })
    .limit(20),
]);

// Pull auth.users info for each member so we can show invite + sign-in
// status. listUsers paginates; for DTE's scale a single 200-user page
// covers everything. Track invited_at, last_sign_in_at, email_confirmed_at.
import { relativeDate } from '../../../../lib/portal';

interface AuthInfo {
  email: string | null;
  invited_at: string | null;
  last_sign_in_at: string | null;
  email_confirmed_at: string | null;
}

const userIds = (members ?? [])
  .map((m: any) => m.profiles?.id)
  .filter((v: any): v is string => typeof v === 'string');

const authById = new Map<string, AuthInfo>();
if (userIds.length > 0) {
  const { data: usersPage } = await admin.auth.admin.listUsers({ perPage: 200 });
  for (const u of usersPage?.users ?? []) {
    if (userIds.includes(u.id)) {
      authById.set(u.id, {
        email: u.email ?? null,
        invited_at: u.invited_at ?? null,
        last_sign_in_at: u.last_sign_in_at ?? null,
        email_confirmed_at: u.email_confirmed_at ?? null,
      });
    }
  }
}

function memberStatus(info: AuthInfo | undefined): 'active' | 'pending' | 'unknown' {
  if (!info) return 'unknown';
  return info.last_sign_in_at ? 'active' : 'pending';
}
---
<PortalLayout title={`${client.business_name} | Admin`} session={session}>
  <div class="mb-5">
    <a href="/portal/admin/clients" class="text-sm text-text-muted hover:text-text inline-flex items-center gap-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      All clients
    </a>
  </div>

  <section class="ph-card p-5 sm:p-7 mb-6">
    <h1 class="font-display text-xl sm:text-2xl font-bold tracking-tight mb-3">{client.business_name}</h1>

    <form class="grid sm:grid-cols-2 gap-3" data-client-edit data-client-id={client.id}>
      <label class="block">
        <span class="ph-label">Business name</span>
        <input name="business_name" required class="ph-input" value={client.business_name} />
      </label>
      <label class="block">
        <span class="ph-label">Primary contact email</span>
        <input name="primary_contact_email" type="email" required class="ph-input" value={client.primary_contact_email} />
      </label>
      <label class="block">
        <span class="ph-label">Site URL</span>
        <input name="site_url" type="url" class="ph-input" value={client.site_url || ''} />
      </label>
      <label class="block">
        <span class="ph-label">Status</span>
        <select name="status" class="ph-input">
          {['active', 'paused', 'archived'].map((s) => (
            <option value={s} selected={client.status === s}>{s}</option>
          ))}
        </select>
      </label>
      <div class="sm:col-span-2 flex items-center gap-3">
        <button type="submit" class="btn-primary text-sm"><span data-edit-label>Save changes</span></button>
        <span class="text-xs text-text-muted" data-edit-flash></span>
      </div>
    </form>
  </section>

  <section class="ph-card p-5 sm:p-7 mb-6">
    <div class="flex items-end justify-between mb-3">
      <h2 class="font-display text-lg font-bold tracking-tight">Users</h2>
      <span class="text-xs text-text-muted">{(members ?? []).length} linked</span>
    </div>

    <ul class="divide-y divide-line/60 mb-4">
      {(members ?? []).length === 0 && (
        <li class="py-3 text-sm text-text-muted">No users linked yet.</li>
      )}
      {(members ?? []).map((m: any) => {
        const info = authById.get(m.profiles?.id);
        const status = memberStatus(info);
        const email = info?.email || '—';
        return (
          <li class="py-3 flex items-start justify-between gap-3">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-sm font-medium truncate">{m.profiles?.full_name || 'Unnamed user'}</span>
                {status === 'active' && (
                  <span class="ph-status-badge ph-status-active">Active</span>
                )}
                {status === 'pending' && (
                  <span class="ph-status-badge ph-status-pending">Invited — not yet signed in</span>
                )}
              </div>
              <div class="text-xs text-text-muted mt-0.5 truncate">{email}</div>
              {status === 'active' && info?.last_sign_in_at && (
                <div class="text-[11px] text-text-muted/80 mt-0.5">
                  Last seen {relativeDate(info.last_sign_in_at)}
                </div>
              )}
            </div>
            <div class="flex flex-col items-end gap-1.5 text-xs shrink-0">
              <span class="text-text-muted uppercase tracking-wide text-[10px]">{m.role}</span>
              {status === 'pending' && info?.email && (
                <button
                  type="button"
                  class="ph-link-btn"
                  data-resend-invite
                  data-membership-id={m.id}
                  data-email={info.email}
                >
                  Resend invite
                </button>
              )}
              <form method="post" data-remove-user data-membership-id={m.id} class="contents">
                <button type="submit" class="text-text-muted/70 hover:text-red-300 underline text-[11px]">Remove</button>
              </form>
            </div>
          </li>
        );
      })}
    </ul>
    <div class="ph-flash hidden mb-4" data-users-flash></div>

    <form class="space-y-3" data-invite-user data-client-id={client.id}>
      <div>
        <label for="invite-email" class="ph-label">Invite a user</label>
        <input
          id="invite-email"
          name="email"
          type="email"
          required
          autocomplete="off"
          inputmode="email"
          autocapitalize="off"
          spellcheck="false"
          placeholder="name@theirbusiness.com"
          class="ph-input"
        />
      </div>
      <div class="flex flex-col sm:flex-row sm:items-center gap-3">
        <label class="sm:flex-1">
          <span class="sr-only">Role</span>
          <select name="role" class="ph-input">
            <option value="owner">Owner</option>
            <option value="member">Member</option>
          </select>
        </label>
        <button type="submit" class="btn-primary text-sm whitespace-nowrap sm:w-auto w-full justify-center">
          <span data-invite-label>Invite + send link</span>
        </button>
      </div>
      <p class="ph-hint">
        Sends them a magic-link sign-in and links them to this client. If they already have an account, only the link goes out.
      </p>
    </form>
    <div class="ph-flash hidden mt-3" data-invite-flash></div>
  </section>

  <section>
    <div class="flex items-center justify-between gap-3 mb-3">
      <h2 class="font-display text-lg font-bold tracking-tight">Recent requests</h2>
      <a href={`/portal/admin/r/new?client=${client.id}`} class="btn-primary !py-1.5 !px-3 !text-[0.78rem] whitespace-nowrap">
        + Log a job
      </a>
    </div>
    <ul class="space-y-2">
      {(requests ?? []).length === 0 && (
        <li class="text-sm text-text-muted">No requests yet.</li>
      )}
      {(requests ?? []).map((r) => (
        <li>
          <a href={`/portal/admin/r/${r.id}`} class="ph-card flex items-center justify-between gap-3 p-3 hover:border-accent/40 transition">
            <span class="truncate font-medium text-sm">{r.title}</span>
            <span class="ph-badge shrink-0" data-status={r.status}>{STATUS_LABELS[r.status as RequestStatus]}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</PortalLayout>

<script>
  // Edit
  const editForm = document.querySelector<HTMLFormElement>('[data-client-edit]');
  const editLabel = document.querySelector<HTMLElement>('[data-edit-label]');
  const editFlash = document.querySelector<HTMLElement>('[data-edit-flash]');
  if (editForm && editLabel && editFlash) {
    editForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = editForm.dataset.clientId;
      const data = Object.fromEntries(new FormData(editForm).entries());
      editLabel.textContent = 'Saving…';
      try {
        const res = await fetch(`/api/portal/admin/clients/${id}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);
        editLabel.textContent = 'Save changes';
        editFlash.textContent = 'Saved ✓';
        setTimeout(() => (editFlash.textContent = ''), 1500);
      } catch (err) {
        editLabel.textContent = 'Save changes';
        editFlash.textContent = err instanceof Error ? err.message : 'Save failed';
      }
    });
  }

  // Invite user
  const invForm = document.querySelector<HTMLFormElement>('[data-invite-user]');
  const invLabel = document.querySelector<HTMLElement>('[data-invite-label]');
  const invFlash = document.querySelector<HTMLElement>('[data-invite-flash]');
  if (invForm && invLabel && invFlash) {
    invForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(invForm).entries());
      const clientId = invForm.dataset.clientId;
      invLabel.textContent = 'Sending…';
      try {
        const res = await fetch('/api/portal/admin/client-users', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ ...data, client_id: clientId }),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);

        // Tell the admin which Supabase template Supabase fired, so they
        // know at a glance whether the recipient got the branded invite
        // or a sign-in link (existing user). Hold the toast on screen for
        // a moment before reloading.
        const msg = json.emailKind === 'invite'
          ? `Branded invite sent to ${json.email || data.email}.`
          : `Existing user — sign-in (Magic Link) sent to ${json.email || data.email}.`;
        invFlash.dataset.tone = json.emailKind === 'invite' ? 'success' : 'info';
        invFlash.textContent = msg;
        invFlash.classList.remove('hidden');
        invLabel.textContent = json.emailKind === 'invite' ? 'Invite sent ✓' : 'Link sent ✓';
        setTimeout(() => window.location.reload(), 1800);
      } catch (err) {
        invFlash.dataset.tone = 'error';
        invFlash.textContent = err instanceof Error ? err.message : 'Invite failed';
        invFlash.classList.remove('hidden');
        invLabel.textContent = 'Invite + send link';
      }
    });
  }

  // Remove user
  document.querySelectorAll<HTMLFormElement>('[data-remove-user]').forEach((f) => {
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!confirm('Remove this user from the client?')) return;
      const id = f.dataset.membershipId;
      const res = await fetch(`/api/portal/admin/client-users/${id}`, { method: 'DELETE' });
      if (res.ok) window.location.reload();
      else alert('Could not remove');
    });
  });

  // Resend invite for a pending user
  const usersFlash = document.querySelector<HTMLElement>('[data-users-flash]');
  function showUsersFlash(msg: string, tone: 'success' | 'error') {
    if (!usersFlash) return;
    usersFlash.textContent = msg;
    usersFlash.dataset.tone = tone;
    usersFlash.classList.remove('hidden');
    if (tone === 'success') {
      setTimeout(() => usersFlash.classList.add('hidden'), 4000);
    }
  }
  document.querySelectorAll<HTMLButtonElement>('[data-resend-invite]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.membershipId!;
      const email = btn.dataset.email || 'them';
      const originalLabel = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Sending…';
      try {
        const res = await fetch(`/api/portal/admin/client-users/${id}/resend-invite`, {
          method: 'POST',
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);
        showUsersFlash(`Invite resent to ${email}`, 'success');
        btn.textContent = 'Sent ✓';
        setTimeout(() => { btn.textContent = originalLabel; btn.disabled = false; }, 2200);
      } catch (err) {
        showUsersFlash(err instanceof Error ? err.message : 'Could not resend invite', 'error');
        btn.textContent = originalLabel;
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  /* Status badges next to each user — quiet, dark-theme friendly. */
  .ph-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 1px solid transparent;
    line-height: 1.4;
    white-space: nowrap;
  }
  .ph-status-active {
    background: rgba(74, 222, 128, 0.10);
    color: #86efac;
    border-color: rgba(74, 222, 128, 0.25);
  }
  .ph-status-pending {
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-muted, #a4a8b0);
    border-color: rgba(255, 255, 255, 0.10);
  }
  .ph-link-btn {
    background: transparent;
    border: 1px solid var(--color-line, rgba(255,255,255,0.1));
    border-radius: 0.4rem;
    padding: 0.25rem 0.55rem;
    font-size: 0.72rem;
    color: var(--color-text, #f5f5f5);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }
  .ph-link-btn:hover:not(:disabled) {
    border-color: var(--color-accent, #ff6a1a);
    color: var(--color-accent, #ff6a1a);
  }
  .ph-link-btn:disabled { opacity: 0.6; cursor: progress; }
</style>
