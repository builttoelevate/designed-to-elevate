---
export const prerender = false;

import PortalLayout from '../../../../layouts/PortalLayout.astro';
import { createServiceSupabase } from '../../../../lib/supabase';
import { isImageFilename } from '../../../../lib/file-uploads';
import {
  STATUS_LABELS,
  STATUS_ORDER,
  BILLING_OPTIONS,
  categoryLabel,
  externalUrl,
  priorityLabel,
  relativeDate,
  type RequestStatus,
} from '../../../../lib/portal';

type UploaderTag = 'admin' | 'client' | 'unknown';

interface SignedFile {
  id: string;
  filename: string;
  view: string;
  download: string;
  isImage: boolean;
  thumb: string | null;
  uploader: UploaderTag;
  uploaderName: string | null;
  isSelf: boolean;
}

const session = Astro.locals.session!;
const { id } = Astro.params;
if (!id) return Astro.redirect('/portal/admin');

const admin = createServiceSupabase();

const { data: req } = await admin
  .from('requests')
  .select('id, title, description, status, priority, category, billing_type, page_url, created_at, completed_at, preferred_completion_date, client_id, clients:client_id (business_name, slug, primary_contact_email), submitter:submitted_by (full_name)')
  .eq('id', id)
  .maybeSingle();

if (!req) return Astro.redirect('/portal/admin');

const [{ data: files }, { data: comments }, { data: activity }] = await Promise.all([
  // profiles join lets us label each attachment with who uploaded it (admin
  // vs client) the same way the comments section already distinguishes
  // authors. uploaded_by carries through for the "is this me?" check.
  admin
    .from('request_files')
    .select('id, file_url, filename, uploaded_by, created_at, profiles:uploaded_by (full_name, role)')
    .eq('request_id', id)
    .order('created_at'),
  admin
    .from('comments')
    .select('id, body, visibility, created_at, author_id, profiles:author_id (full_name, role)')
    .eq('request_id', id)
    .order('created_at'),
  admin.from('request_activity').select('id, action, metadata, created_at, profiles:actor_id (full_name)').eq('request_id', id).order('created_at', { ascending: false }).limit(20),
]);

// Mint a viewing URL (opens inline in a new tab) and a forced-download URL
// (Content-Disposition: attachment with the original filename) per file. 2h
// TTL so a tap after a quick context-switch still works; the URLs are
// HttpOnly-cookie-protected at the bucket level via storage RLS anyway.
//
// The view URL doubles as the thumbnail src when the file is an image — no
// extra signed URL, no transform service. The browser fetches the full
// original to render a 56×56 thumbnail; acceptable at current volume.
const SIGNED_TTL_SECONDS = 60 * 60 * 2;
const signedFiles: SignedFile[] = [];
for (const f of files ?? []) {
  const [{ data: viewData }, { data: dlData }] = await Promise.all([
    admin.storage.from('request-files').createSignedUrl(f.file_url, SIGNED_TTL_SECONDS),
    admin.storage.from('request-files').createSignedUrl(f.file_url, SIGNED_TTL_SECONDS, {
      download: f.filename,
    }),
  ]);
  if (!viewData?.signedUrl || !dlData?.signedUrl) continue;

  const profile = (f as any).profiles as { full_name: string | null; role: string | null } | null;
  const uploader: UploaderTag = !f.uploaded_by
    ? 'unknown'
    : profile?.role === 'admin'
    ? 'admin'
    : 'client';
  const isImage = isImageFilename(f.filename);

  signedFiles.push({
    id: f.id,
    filename: f.filename,
    view: viewData.signedUrl,
    download: dlData.signedUrl,
    isImage,
    thumb: isImage ? viewData.signedUrl : null,
    uploader,
    uploaderName: profile?.full_name ?? null,
    isSelf: !!f.uploaded_by && f.uploaded_by === session.userId,
  });
}

// Admin-perspective uploader label. Matches the comments section's
// "Bill — Designed to Elevate" exactly so the two read as one voice.
function uploaderLabel(f: SignedFile): string {
  if (f.uploader === 'admin') return 'Bill — Designed to Elevate';
  if (f.uploader === 'client') {
    return f.uploaderName ? `Client · ${f.uploaderName}` : 'Client';
  }
  return 'Unknown uploader';
}
---
<PortalLayout title={`${req.title} | Admin`} session={session}>
  <div class="mb-5 flex items-center justify-between gap-3">
    <a href="/portal/admin" class="text-sm text-text-muted hover:text-text inline-flex items-center gap-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Queue
    </a>
    <div class="text-xs text-text-muted text-right">
      <div class="font-semibold text-text">{(req as any).clients?.business_name}</div>
      <div>Submitted by {(req as any).submitter?.full_name || 'client'} · {relativeDate(req.created_at)}</div>
    </div>
  </div>

  <article class="ph-card p-5 sm:p-7 mb-6">
    <div class="flex items-start justify-between gap-3 mb-3">
      <h1 class="font-display text-xl sm:text-2xl font-bold tracking-tight leading-tight">{req.title}</h1>
      <span class="ph-badge shrink-0" data-status={req.status}>{STATUS_LABELS[req.status as RequestStatus]}</span>
    </div>

    <div class="grid sm:grid-cols-2 gap-3 mb-5">
      <label class="block">
        <span class="ph-label">Status</span>
        <select class="ph-input" data-update-field="status" data-request-id={req.id}>
          {STATUS_ORDER.map((s) => (
            <option value={s} selected={req.status === s}>{STATUS_LABELS[s]}</option>
          ))}
        </select>
      </label>
      <label class="block">
        <span class="ph-label">Billing (admin only)</span>
        <select class="ph-input" data-update-field="billing_type" data-request-id={req.id}>
          {BILLING_OPTIONS.map((b) => (
            <option value={b.value} selected={req.billing_type === b.value}>{b.label}</option>
          ))}
        </select>
      </label>
    </div>

    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5 text-xs">
      <div>
        <dt class="text-text-muted uppercase tracking-wide">Type</dt>
        <dd class="mt-0.5 font-medium">{categoryLabel(req.category)}</dd>
      </div>
      <div>
        <dt class="text-text-muted uppercase tracking-wide">Priority</dt>
        <dd class="mt-0.5 font-medium ph-pri" data-priority={req.priority}>{priorityLabel(req.priority)}</dd>
      </div>
      <div>
        <dt class="text-text-muted uppercase tracking-wide">Submitted</dt>
        <dd class="mt-0.5 font-medium">{relativeDate(req.created_at)}</dd>
      </div>
      {req.preferred_completion_date && (
        <div>
          <dt class="text-text-muted uppercase tracking-wide">Preferred</dt>
          <dd class="mt-0.5 font-medium">{new Date(req.preferred_completion_date).toLocaleDateString()}</dd>
        </div>
      )}
    </dl>

    {req.page_url && (
      <div class="mb-5">
        <div class="text-xs text-text-muted uppercase tracking-wide mb-1">Page</div>
        <a href={externalUrl(req.page_url)} target="_blank" rel="noopener" class="text-sm underline break-all">{req.page_url}</a>
      </div>
    )}

    <div class="mb-2 text-xs text-text-muted uppercase tracking-wide">Details</div>
    <p class="whitespace-pre-wrap leading-relaxed text-text/90">{req.description}</p>

    {signedFiles.length > 0 && (
      <>
        <div class="mt-6 mb-2 text-xs text-text-muted uppercase tracking-wide">Attachments</div>
        <ul class="space-y-2">
          {signedFiles.map((f) => (
            <li class:list={[
              'ph-card flex items-center gap-3 px-3 py-2',
              // Faint accent tint on admin-uploaded rows so the eye can scan
              // client-vs-admin without reading the label every time.
              f.uploader === 'admin' && 'bg-accent/[0.04]',
            ]}>
              {f.isImage && f.thumb ? (
                <a
                  href={f.view}
                  target="_blank"
                  rel="noopener"
                  class="shrink-0 block w-14 h-14 rounded overflow-hidden border border-line bg-surface-2"
                  aria-label={`Open ${f.filename} in a new tab`}
                >
                  <img
                    src={f.thumb}
                    alt=""
                    width="56"
                    height="56"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover"
                  />
                </a>
              ) : (
                <div class="shrink-0 w-14 h-14 rounded border border-line bg-surface-2 flex items-center justify-center text-text-muted" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                </div>
              )}

              <div class="flex-1 min-w-0">
                <div class="text-sm truncate" title={f.filename}>{f.filename}</div>
                <div class="text-xs text-text-muted mt-0.5">{uploaderLabel(f)}</div>
              </div>

              <a
                href={f.view}
                target="_blank"
                rel="noopener"
                class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold rounded border border-line text-text-soft hover:text-accent hover:border-accent/40 transition"
                aria-label={`Open ${f.filename} in a new tab`}
              >
                Open
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
              <a
                href={f.download}
                class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold rounded bg-accent/15 text-accent hover:bg-accent/25 transition"
                aria-label={`Download ${f.filename}`}
              >
                Download
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    <div class="mt-6">
      <label class="ph-label">Upload completion screenshot</label>
      <input type="file" multiple data-admin-upload data-request-id={req.id} data-client-id={req.client_id} accept="image/*,application/pdf" class="ph-input" />
      <p class="ph-hint">Files attach to this request and become visible to the client.</p>
    </div>
  </article>

  <section class="mb-6">
    <h2 class="font-display text-lg font-bold tracking-tight mb-3">Messages</h2>

    <ul class="space-y-3 mb-4">
      {(comments ?? []).length === 0 && (
        <li class="text-sm text-text-muted">No messages yet.</li>
      )}
      {(comments ?? []).map((c: any) => {
        const isAdminAuthor = c.profiles?.role === 'admin';
        const internal = c.visibility === 'internal';
        return (
          <li class={`ph-card p-3 sm:p-4 ${internal ? 'border-yellow-400/30 bg-yellow-400/[0.03]' : ''}`}>
            <div class="flex items-center gap-2 mb-1 text-xs text-text-muted">
              <span class="font-semibold text-text">
                {isAdminAuthor ? 'Bill — Designed to Elevate' : (c.profiles?.full_name || 'Client')}
              </span>
              {internal && <span class="ph-badge" data-status="waiting_on_client">Internal</span>}
              <span>·</span>
              <span>{relativeDate(c.created_at)}</span>
            </div>
            <p class="whitespace-pre-wrap text-sm leading-relaxed">{c.body}</p>
          </li>
        );
      })}
    </ul>

    <form class="ph-card p-3 sm:p-4" data-comment-form data-request-id={req.id}>
      <textarea name="body" required class="ph-input" rows="3" placeholder="Reply to the client, or post an internal note…"></textarea>
      <div class="flex items-center justify-between gap-3 mt-2">
        <label class="text-sm flex items-center gap-2">
          <input type="checkbox" name="internal" class="accent-accent" />
          <span>Internal note (client won't see this)</span>
        </label>
        <button type="submit" class="btn-primary text-sm py-2 px-4">
          <span data-btn-label>Send</span>
        </button>
      </div>
      <div class="ph-flash hidden mt-3" data-flash></div>
    </form>
  </section>

  <section>
    <h3 class="font-display text-base font-bold tracking-tight mb-2">Activity</h3>
    <ul class="text-xs text-text-muted space-y-1">
      {(activity ?? []).map((a: any) => (
        <li>
          <span class="text-text/80">{a.profiles?.full_name || 'system'}</span>
          <span> · </span>
          <span>{a.action.replace(/_/g, ' ')}</span>
          {a.metadata?.from && a.metadata?.to && (
            <span> ({a.metadata.from} → {a.metadata.to})</span>
          )}
          <span> · </span>
          <span>{relativeDate(a.created_at)}</span>
        </li>
      ))}
    </ul>
  </section>
</PortalLayout>

<script>
  // Field updates (status, billing)
  document.querySelectorAll<HTMLSelectElement>('[data-update-field]').forEach((el) => {
    el.addEventListener('change', async () => {
      const field = el.dataset.updateField!;
      const requestId = el.dataset.requestId!;
      const prev = el.dataset.prev || el.value;
      el.dataset.prev = el.value;
      el.disabled = true;
      try {
        const res = await fetch(`/api/portal/admin/requests/${requestId}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ [field]: el.value }),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || `HTTP ${res.status}`);
        }
        el.classList.add('outline', 'outline-2', 'outline-green-500/40');
        setTimeout(() => el.classList.remove('outline', 'outline-2', 'outline-green-500/40'), 800);
      } catch (err) {
        alert(`Update failed: ${err instanceof Error ? err.message : 'unknown'}`);
        el.value = prev;
      } finally {
        el.disabled = false;
      }
    });
  });

  // Comment submit
  const cform = document.querySelector<HTMLFormElement>('[data-comment-form]');
  const flash = document.querySelector<HTMLElement>('[data-flash]');
  const label = document.querySelector<HTMLElement>('[data-btn-label]');
  if (cform && flash && label) {
    cform.addEventListener('submit', async (e) => {
      e.preventDefault();
      const requestId = cform.dataset.requestId;
      const body = (cform.querySelector('textarea[name="body"]') as HTMLTextAreaElement).value.trim();
      const internal = (cform.querySelector('input[name="internal"]') as HTMLInputElement).checked;
      if (!body || !requestId) return;
      label.textContent = 'Sending…';
      try {
        const res = await fetch(`/api/portal/requests/${requestId}/comments`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ body, visibility: internal ? 'internal' : 'public' }),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || `HTTP ${res.status}`);
        }
        window.location.reload();
      } catch (err) {
        flash.dataset.tone = 'error';
        flash.textContent = err instanceof Error ? err.message : 'Could not send';
        flash.classList.remove('hidden');
        label.textContent = 'Send';
      }
    });
  }

  // Admin file upload
  const fileInput = document.querySelector<HTMLInputElement>('[data-admin-upload]');
  if (fileInput) {
    fileInput.addEventListener('change', async () => {
      if (!fileInput.files || fileInput.files.length === 0) return;
      const requestId = fileInput.dataset.requestId!;
      const fd = new FormData();
      for (const f of Array.from(fileInput.files)) fd.append('files', f);
      try {
        const res = await fetch(`/api/portal/admin/requests/${requestId}/files`, {
          method: 'POST',
          body: fd,
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || `HTTP ${res.status}`);
        }
        window.location.reload();
      } catch (err) {
        alert(`Upload failed: ${err instanceof Error ? err.message : 'unknown'}`);
      }
    });
  }
</script>
