---
export const prerender = false;

import PortalLayout from '../../../layouts/PortalLayout.astro';
import { createServiceSupabase } from '../../../lib/supabase';
import {
  STATUS_LABELS,
  STATUS_ORDER,
  PRIORITY_OPTIONS,
  BILLING_OPTIONS,
  categoryLabel,
  priorityLabel,
  billingLabel,
  relativeDate,
  type RequestStatus,
} from '../../../lib/portal';

const session = Astro.locals.session!;
const params = Astro.url.searchParams;
const fStatus   = params.get('status') || '';
const fPriority = params.get('priority') || '';
const fBilling  = params.get('billing') || '';
const fClient   = params.get('client') || '';

const admin = createServiceSupabase();

let query = admin
  .from('requests')
  .select('id, title, status, priority, category, billing_type, created_at, client_id, clients:client_id (business_name, slug)')
  .order('created_at', { ascending: false });

if (fPriority) query = query.eq('priority', fPriority);
if (fBilling)  query = query.eq('billing_type', fBilling);
if (fClient)   query = query.eq('client_id', fClient);

const [{ data: requests }, { data: clients }] = await Promise.all([
  query,
  admin.from('clients').select('id, business_name').order('business_name'),
]);

const all = requests ?? [];
const counts: Record<string, number> = {};
for (const r of all) counts[r.status] = (counts[r.status] || 0) + 1;

const openCount = all.length - (counts.complete || 0);
const list = fStatus
  ? all.filter((r) => r.status === fStatus)
  : all.filter((r) => r.status !== 'complete');
const hasOtherFilters = Boolean(fPriority || fBilling || fClient);

function qs(overrides: Record<string, string>): string {
  const next = new URLSearchParams(params);
  for (const [k, v] of Object.entries(overrides)) {
    if (v) next.set(k, v);
    else next.delete(k);
  }
  const s = next.toString();
  return s ? `?${s}` : '';
}
---
<PortalLayout title="Admin queue | Client Hub" session={session}>
  <section class="mb-5 flex items-end justify-between gap-3 flex-wrap">
    <div>
      <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">Queue</h1>
      <p class="text-text-muted text-sm mt-1">Open client requests across all businesses. Completed jobs live under the "Complete" tab.</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-text-muted">{list.length} request{list.length === 1 ? '' : 's'}</span>
      <a href="/portal/admin/r/new" class="btn-primary !py-2 !px-3.5 !text-[0.8rem] whitespace-nowrap">
        + Log a job
      </a>
    </div>
  </section>

  <div class="ph-card p-3 sm:p-4 mb-5 grid grid-cols-2 sm:grid-cols-4 gap-2">
    <select class="ph-input" data-filter="client">
      <option value="">All clients</option>
      {(clients ?? []).map((c) => (
        <option value={c.id} selected={fClient === c.id}>{c.business_name}</option>
      ))}
    </select>
    <select class="ph-input" data-filter="status">
      <option value="">All statuses</option>
      {STATUS_ORDER.map((s) => (
        <option value={s} selected={fStatus === s}>{STATUS_LABELS[s]}</option>
      ))}
    </select>
    <select class="ph-input" data-filter="priority">
      <option value="">Any priority</option>
      {PRIORITY_OPTIONS.map((p) => (
        <option value={p.value} selected={fPriority === p.value}>{p.label}</option>
      ))}
    </select>
    <select class="ph-input" data-filter="billing">
      <option value="">Any billing</option>
      {BILLING_OPTIONS.map((b) => (
        <option value={b.value} selected={fBilling === b.value}>{b.label}</option>
      ))}
    </select>
  </div>

  <div class="flex flex-wrap gap-2 mb-4 text-xs">
    <a href="/portal/admin" class:list={["px-3 py-1.5 rounded-full border transition", !fStatus ? 'bg-accent text-bg border-accent' : 'border-line hover:text-text']}>
      All ({openCount})
    </a>
    {STATUS_ORDER.map((s) => (
      <a href={qs({ status: s })} class:list={["px-3 py-1.5 rounded-full border transition", fStatus === s ? 'bg-accent text-bg border-accent' : 'border-line text-text-muted hover:text-text']}>
        {STATUS_LABELS[s]} ({counts[s] || 0})
      </a>
    ))}
  </div>

  <ul class="space-y-2">
    {list.length === 0 && (
      <li class="text-text-muted text-sm">
        {!fStatus && !hasOtherFilters
          ? 'No new jobs. You’re all caught up.'
          : 'No requests match the filters.'}
      </li>
    )}
    {list.map((r: any) => (
      <li class="ph-card p-3 sm:p-4 hover:border-accent/40 transition flex items-start gap-3">
        <label class="shrink-0 pt-0.5 cursor-pointer" aria-label={`Select ${r.title}`}>
          <input type="checkbox" data-bulk-select value={r.id} class="w-4 h-4 align-middle accent-[color:var(--color-accent)] cursor-pointer" />
        </label>
        <a href={`/portal/admin/r/${r.id}`} class="block flex-1 min-w-0">
          <div class="flex items-start justify-between gap-3 mb-1.5">
            <div class="min-w-0">
              <h3 class="font-display font-semibold text-base leading-tight truncate">{r.title}</h3>
              <div class="text-xs text-text-muted mt-0.5">{r.clients?.business_name}</div>
            </div>
            <span class="ph-badge shrink-0" data-status={r.status}>{STATUS_LABELS[r.status as RequestStatus]}</span>
          </div>
          <div class="text-xs text-text-muted flex flex-wrap items-center gap-x-3 gap-y-1">
            <span>{categoryLabel(r.category)}</span>
            <span class="ph-pri" data-priority={r.priority}>{priorityLabel(r.priority)}</span>
            <span class="text-[11px] uppercase tracking-wide">{billingLabel(r.billing_type)}</span>
            <span>{relativeDate(r.created_at)}</span>
          </div>
        </a>
      </li>
    ))}
  </ul>

  <!-- BULK ACTION BAR — appears when at least one request is selected. -->
  <div
    data-bulk-bar
    class="hidden fixed inset-x-0 bottom-0 z-40 border-t border-line bg-bg/95 backdrop-blur supports-[backdrop-filter]:bg-bg/85 px-3 py-3 pb-[max(env(safe-area-inset-bottom),0.75rem)]"
    role="region"
    aria-label="Bulk status actions"
  >
    <div class="mx-auto max-w-7xl flex items-center gap-2 sm:gap-3 flex-wrap">
      <span class="text-sm text-text-soft whitespace-nowrap"><span data-bulk-count>0</span> selected</span>
      <select data-bulk-status class="ph-input flex-1 min-w-[10rem] !py-2 !text-sm" aria-label="New status">
        <option value="">Change status to…</option>
        {STATUS_ORDER.map((s) => (
          <option value={s}>{STATUS_LABELS[s]}</option>
        ))}
      </select>
      <button type="button" data-bulk-apply class="btn-primary !py-2 !px-4 !text-sm disabled:opacity-50 disabled:cursor-not-allowed" disabled>Apply</button>
      <button type="button" data-bulk-clear class="btn-ghost !py-2 !px-4 !text-sm">Clear</button>
    </div>
  </div>
</PortalLayout>

<script>
  document.querySelectorAll<HTMLSelectElement>('[data-filter]').forEach((el) => {
    el.addEventListener('change', () => {
      const params = new URLSearchParams(window.location.search);
      const key = el.dataset.filter!;
      if (el.value) params.set(key, el.value);
      else params.delete(key);
      const s = params.toString();
      window.location.search = s ? `?${s}` : '';
    });
  });

  // Bulk selection + bulk status change.
  (() => {
    const boxes = () => Array.from(document.querySelectorAll<HTMLInputElement>('[data-bulk-select]'));
    const bar = document.querySelector<HTMLDivElement>('[data-bulk-bar]');
    const countEl = document.querySelector<HTMLSpanElement>('[data-bulk-count]');
    const statusSel = document.querySelector<HTMLSelectElement>('[data-bulk-status]');
    const applyBtn = document.querySelector<HTMLButtonElement>('[data-bulk-apply]');
    const clearBtn = document.querySelector<HTMLButtonElement>('[data-bulk-clear]');
    if (!bar || !statusSel || !applyBtn || !clearBtn || !countEl) return;

    const selectedIds = () => boxes().filter((c) => c.checked).map((c) => c.value);

    const sync = () => {
      const ids = selectedIds();
      countEl.textContent = String(ids.length);
      bar.classList.toggle('hidden', ids.length === 0);
      applyBtn.disabled = ids.length === 0 || !statusSel.value;
    };

    boxes().forEach((c) => c.addEventListener('change', sync));
    statusSel.addEventListener('change', sync);

    clearBtn.addEventListener('click', () => {
      boxes().forEach((c) => (c.checked = false));
      statusSel.value = '';
      sync();
    });

    applyBtn.addEventListener('click', async () => {
      const ids = selectedIds();
      const status = statusSel.value;
      if (!ids.length || !status) return;
      const originalLabel = applyBtn.textContent;
      applyBtn.disabled = true;
      applyBtn.textContent = 'Applying…';
      try {
        const res = await fetch('/api/portal/admin/requests/bulk-status', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ ids, status }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || `Bulk update failed (${res.status})`);
        }
        window.location.reload();
      } catch (err: any) {
        alert(err?.message || 'Bulk update failed');
        applyBtn.textContent = originalLabel;
        sync();
      }
    });

    sync();
  })();
</script>
