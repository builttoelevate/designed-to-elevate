---
export const prerender = false;

import PortalLayout from '../../layouts/PortalLayout.astro';
import { CATEGORY_OPTIONS, PRIORITY_OPTIONS } from '../../lib/portal';

const session = Astro.locals.session!;
if (session.role === 'admin') {
  // Admin submits requests through /portal/admin if/when needed (Phase 2);
  // for now, redirect them to the queue.
  return Astro.redirect('/portal/admin');
}
if (session.clientIds.length === 0) {
  return Astro.redirect('/portal');
}
---
<PortalLayout title="Submit a Website Change | Client Hub" session={session}>
  <section class="max-w-2xl">
    <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight mb-3">
      Submit a Website Change
    </h1>
    <p class="text-text-muted mb-6 leading-relaxed">
      Need something updated? Tell us what you need below. Small updates like text,
      photos, hours, and links are included in your plan. New pages, custom features,
      or redesigns may need a separate estimate before work begins.
    </p>

    <form class="ph-card p-5 sm:p-7 space-y-5" data-request-form>
      <div>
        <label for="title" class="ph-label">What needs changed?</label>
        <input id="title" name="title" type="text" required maxlength="120" class="ph-input" />
      </div>

      <div>
        <label for="category" class="ph-label">What type of change is this?</label>
        <select id="category" name="category" required class="ph-input">
          <option value="">Pick one…</option>
          {CATEGORY_OPTIONS.map((o) => (
            <option value={o.value}>{o.label}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="page_url" class="ph-label">Page URL (optional)</label>
        <input
          id="page_url"
          name="page_url"
          type="text"
          inputmode="url"
          autocomplete="url"
          placeholder="modernclassicbarbershop.com"
          class="ph-input"
        />
      </div>

      <div>
        <label for="description" class="ph-label">Describe the change in detail</label>
        <textarea id="description" name="description" required class="ph-input"></textarea>
      </div>

      <div>
        <label for="files" class="ph-label">Upload files</label>
        <input id="files" name="files" type="file" multiple class="ph-input" accept="image/*,application/pdf" />
        <p class="ph-hint">Screenshots, logos, photos, PDFs — anything that helps us understand.</p>

        <!-- Pending list (pre-submit): files the user has picked, with × to remove. -->
        <ul class="mt-3 space-y-2 hidden" data-pending-list></ul>

        <!-- Progress chips (during submit): one per file, with % bar. -->
        <ul class="mt-3 space-y-2 hidden" data-upload-chips></ul>
      </div>

      <div>
        <label class="ph-label">How urgent is this?</label>
        <div class="grid sm:grid-cols-3 gap-2 mb-2">
          {PRIORITY_OPTIONS.map((o, i) => (
            <label class="ph-card flex items-center gap-2 px-3 py-2.5 cursor-pointer has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="priority" value={o.value} checked={i === 0} class="accent-accent" />
              <span class="font-display text-sm font-semibold">{o.label}</span>
            </label>
          ))}
        </div>
        <ul class="ph-hint space-y-1 mt-2">
          <li><strong>Whenever you get a chance</strong> — general update, no rush</li>
          <li><strong>Soon — please don't sit on it</strong> — needed this week, but the site still works</li>
          <li><strong>Blocking — I can't move forward</strong> — site issue, wrong info, broken page, or time-sensitive</li>
        </ul>
      </div>

      <div>
        <label for="preferred_completion_date" class="ph-label">Preferred completion date (optional)</label>
        <input id="preferred_completion_date" name="preferred_completion_date" type="date" class="ph-input" />
      </div>

      <button type="submit" class="btn-primary w-full sm:w-auto justify-center">
        <span data-btn-label>Submit Request</span>
      </button>

      <div class="ph-flash hidden" data-flash></div>
    </form>
  </section>
</PortalLayout>

<style>
  /* Lifted verbatim from src/pages/portal/admin/todos.astro so the upload
     progress chips render the same in both portals. */
  .ph-attach-row {
    padding: 0.35rem 0.5rem;
    border-radius: 0.45rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
  }
  .ph-progress-track {
    height: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    overflow: hidden;
    margin-top: 0.3rem;
  }
  .ph-progress-fill {
    height: 100%;
    background: var(--color-accent);
    width: 0%;
    transition: width 120ms linear;
  }
  .ph-progress-fill[data-state="failed"] {
    background: rgba(248, 113, 113, 0.6);
  }
  .ph-pending-row .ph-remove-btn {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1;
    padding: 0 0.25rem;
  }
  .ph-pending-row .ph-remove-btn:hover {
    color: var(--color-accent);
  }
  .ph-retry-btn {
    color: var(--color-accent);
    font-weight: 600;
    padding: 0.1rem 0.5rem;
    border-radius: 0.3rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }
  .ph-retry-btn:hover {
    background: color-mix(in srgb, var(--color-accent) 16%, transparent);
  }
  .ph-retry-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  // Max upload + MIME allowlist mirror the server-side validation in
  // src/lib/file-uploads.ts. Keep in sync.
  const MAX_UPLOAD_BYTES = 100 * 1024 * 1024;
  const ALLOWED_MIME_PREFIXES = ['image/', 'video/', 'audio/', 'text/'];
  const ALLOWED_MIME_EXACT = new Set([
    'application/pdf',
    'application/json',
    'application/xml',
    'application/zip',
    'application/x-zip-compressed',
    'application/x-tar',
    'application/gzip',
    'application/x-gzip',
    'application/x-7z-compressed',
    'application/rtf',
    'application/msword',
    'application/vnd.ms-excel',
    'application/vnd.ms-powerpoint',
    'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
    'application/vnd.openxmlformats-officedocument.presentationml.presentation',
    'application/octet-stream',
    '',
  ]);
  function isAllowedMime(m: string): boolean {
    if (ALLOWED_MIME_EXACT.has(m)) return true;
    return ALLOWED_MIME_PREFIXES.some((p) => m.startsWith(p));
  }
  function formatBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${Math.round(n / 1024)} KB`;
    return `${(n / (1024 * 1024)).toFixed(1)} MB`;
  }

  const form = document.querySelector<HTMLFormElement>('[data-request-form]');
  const flash = document.querySelector<HTMLElement>('[data-flash]');
  const label = document.querySelector<HTMLElement>('[data-btn-label]');
  const fileInput = document.querySelector<HTMLInputElement>('#files');
  const pendingList = document.querySelector<HTMLUListElement>('[data-pending-list]');
  const chipList = document.querySelector<HTMLUListElement>('[data-upload-chips]');

  if (!form || !flash || !label || !fileInput || !pendingList || !chipList) {
    // Page is broken at the markup level; let the JS noop rather than throw.
  } else {
    // ─── Pending file list ───────────────────────────────────────────────
    // Users can add more files (the input is `multiple`) and remove specific
    // ones before submit. We keep an authoritative array here because the
    // <input type="file"> .files list is read-only — once we strip a file
    // from the display, we can't remove it from the input directly.
    let pending: File[] = [];

    function showFlash(tone: 'success' | 'error' | 'warn', message: string) {
      flash!.dataset.tone = tone;
      flash!.textContent = message;
      flash!.classList.remove('hidden');
    }

    function renderPending() {
      pendingList!.innerHTML = '';
      if (pending.length === 0) {
        pendingList!.classList.add('hidden');
        return;
      }
      pendingList!.classList.remove('hidden');
      pending.forEach((file, idx) => {
        const li = document.createElement('li');
        li.className = 'ph-attach-row ph-pending-row flex items-center gap-2 text-xs';
        const name = document.createElement('span');
        name.className = 'flex-1 min-w-0 truncate';
        name.textContent = file.name;
        const size = document.createElement('span');
        size.className = 'text-text-muted shrink-0';
        size.textContent = formatBytes(file.size);
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.className = 'ph-remove-btn shrink-0';
        remove.setAttribute('aria-label', `Remove ${file.name}`);
        remove.textContent = '×';
        remove.addEventListener('click', () => {
          pending.splice(idx, 1);
          renderPending();
        });
        li.append(name, size, remove);
        pendingList!.appendChild(li);
      });
    }

    fileInput.addEventListener('change', () => {
      const picked = Array.from(fileInput.files ?? []);
      // Append, don't replace — user might pick a screenshot, then add a
      // logo. The native picker doesn't merge for us.
      for (const f of picked) {
        if (f.size <= 0) continue;
        if (f.size > MAX_UPLOAD_BYTES) {
          showFlash('error', `"${f.name}" exceeds 100 MB limit and was skipped.`);
          continue;
        }
        if (!isAllowedMime(f.type)) {
          showFlash('error', `"${f.name}" has an unsupported file type (${f.type || 'unknown'}) and was skipped.`);
          continue;
        }
        pending.push(f);
      }
      renderPending();
      // Reset the input so re-picking the same file re-fires the change event.
      fileInput.value = '';
    });

    // ─── Submit + retry flow ─────────────────────────────────────────────
    let uploadsInFlight = false;
    let requestId: string | null = null;
    const failedFiles = new Set<File>();
    const fileToChip = new Map<File, ChipHandles>();

    const beforeUnload = (e: BeforeUnloadEvent) => {
      if (!uploadsInFlight) return;
      e.preventDefault();
      e.returnValue = '';
    };
    window.addEventListener('beforeunload', beforeUnload);

    function disableForm(disabled: boolean) {
      form!.querySelectorAll<HTMLInputElement>('input,select,textarea,button').forEach((el) => {
        el.disabled = disabled;
      });
    }

    interface ChipHandles {
      pct: HTMLElement;
      fill: HTMLElement;
      name: HTMLElement;
      retry: HTMLButtonElement;
    }

    function createChip(file: File): ChipHandles {
      const li = document.createElement('li');
      li.className = 'ph-attach-row';
      li.innerHTML = `
        <div class="flex items-center gap-2 text-xs">
          <span class="flex-1 min-w-0 truncate" data-name></span>
          <span class="text-text-muted shrink-0" data-size></span>
          <span class="text-text-muted shrink-0" data-pct>0%</span>
          <button type="button" data-retry class="ph-retry-btn hidden">Retry</button>
        </div>
        <div class="ph-progress-track"><div class="ph-progress-fill" data-fill></div></div>
      `;
      const name = li.querySelector<HTMLElement>('[data-name]')!;
      const size = li.querySelector<HTMLElement>('[data-size]')!;
      const pct = li.querySelector<HTMLElement>('[data-pct]')!;
      const fill = li.querySelector<HTMLElement>('[data-fill]')!;
      const retry = li.querySelector<HTMLButtonElement>('[data-retry]')!;
      name.textContent = file.name;
      size.textContent = formatBytes(file.size);
      chipList!.appendChild(li);

      const handles: ChipHandles = { pct, fill, name, retry };
      retry.addEventListener('click', () => {
        if (uploadsInFlight) return;
        void retryFile(file);
      });
      return handles;
    }

    function resetChip(chip: ChipHandles) {
      chip.pct.textContent = '0%';
      chip.fill.style.width = '0%';
      delete chip.fill.dataset.state;
      chip.name.title = '';
      chip.retry.classList.add('hidden');
    }

    function markChipFailed(chip: ChipHandles, message: string) {
      chip.pct.textContent = 'Failed';
      chip.fill.style.width = '100%';
      chip.fill.dataset.state = 'failed';
      chip.name.title = message;
      chip.retry.classList.remove('hidden');
      // Re-enable explicitly: disableForm(true) earlier disabled every <button>
      // inside the form, including this retry button we're now revealing.
      chip.retry.disabled = false;
    }

    async function signFile(
      reqId: string,
      file: File
    ): Promise<{ attachment_id: string; storage_path: string; signed_url: string; token: string }> {
      const res = await fetch(`/api/portal/requests/${reqId}/attachments/sign`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          file_name: file.name,
          mime_type: file.type || 'application/octet-stream',
          size_bytes: file.size,
        }),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(body.error || `Sign HTTP ${res.status}`);
      return body;
    }

    function putToStorage(
      signedUrl: string,
      file: File,
      chip: ChipHandles
    ): Promise<void> {
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open('PUT', signedUrl, true);
        xhr.setRequestHeader('Content-Type', file.type || 'application/octet-stream');
        xhr.upload.addEventListener('progress', (e) => {
          if (!e.lengthComputable) return;
          const pct = Math.round((e.loaded / e.total) * 100);
          chip.pct.textContent = `${pct}%`;
          chip.fill.style.width = `${pct}%`;
        });
        xhr.addEventListener('load', () => {
          if (xhr.status >= 200 && xhr.status < 300) {
            chip.pct.textContent = '100%';
            chip.fill.style.width = '100%';
            resolve();
          } else {
            reject(new Error(`Upload HTTP ${xhr.status}`));
          }
        });
        xhr.addEventListener('error', () => reject(new Error('Network error during upload')));
        xhr.addEventListener('abort', () => reject(new Error('Upload aborted')));
        xhr.send(file);
      });
    }

    async function confirmFile(
      reqId: string,
      file: File,
      signed: { attachment_id: string; storage_path: string }
    ): Promise<void> {
      const res = await fetch(`/api/portal/requests/${reqId}/attachments/confirm`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          attachment_id: signed.attachment_id,
          storage_path: signed.storage_path,
          file_name: file.name,
          mime_type: file.type || 'application/octet-stream',
          size_bytes: file.size,
        }),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(body.error || `Confirm HTTP ${res.status}`);
    }

    /**
     * Sign → PUT → confirm for one file. Caller is responsible for setting
     * `uploadsInFlight` and updating the button label.
     */
    async function uploadOne(reqId: string, file: File): Promise<void> {
      const chip = fileToChip.get(file)!;
      resetChip(chip);
      const signed = await signFile(reqId, file);
      await putToStorage(signed.signed_url, file, chip);
      await confirmFile(reqId, file, signed);
    }

    /**
     * Re-run sign → PUT → confirm for one file that failed earlier. The
     * confirm endpoint is idempotent on (request_id, storage_path) so a
     * network blip between PUT and confirm during the original attempt
     * doesn't cause a duplicate row on retry.
     */
    async function retryFile(file: File): Promise<void> {
      if (!requestId) return;
      const chip = fileToChip.get(file)!;
      const remainingBefore = failedFiles.size;
      failedFiles.delete(file);
      uploadsInFlight = true;
      updatePartialFailFlash(remainingBefore - 1, pending.length);
      label!.textContent = 'Retrying…';

      try {
        await uploadOne(requestId, file);
        if (failedFiles.size === 0) {
          // All failures cleared — flip to full success.
          showFlash(
            'success',
            "Got it. Your request is in the queue and we'll email you when it's in progress."
          );
          label!.textContent = 'Submitted ✓';
          setTimeout(() => {
            window.location.assign(`/portal/r/${requestId}`);
          }, 900);
        } else {
          label!.textContent = 'Submitted ✓';
        }
      } catch (err) {
        const message =
          err instanceof Error ? err.message : 'Unknown error during upload';
        markChipFailed(chip, message);
        failedFiles.add(file);
        updatePartialFailFlash(failedFiles.size, pending.length);
        label!.textContent = 'Submitted ✓';
      } finally {
        uploadsInFlight = false;
      }
    }

    function updatePartialFailFlash(failedCount: number, totalCount: number) {
      if (failedCount === 0) return;
      const word = failedCount === 1 ? 'file' : 'files';
      showFlash(
        'warn',
        `Submitted, but ${failedCount} of ${totalCount} ${word} didn't upload. ` +
          `Tap Retry on the failed ${word}, or continue to the request and add ${
            failedCount === 1 ? 'it' : 'them'
          } there.`
      );
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      flash!.classList.add('hidden');

      // Snapshot the text fields before disabling inputs (disabled fields are
      // omitted from FormData per spec, and we want stable values).
      const fd = new FormData(form!);
      const payload = {
        title: (fd.get('title') as string | null)?.trim() ?? '',
        category: (fd.get('category') as string | null)?.trim() ?? '',
        page_url: (fd.get('page_url') as string | null)?.trim() || null,
        description: (fd.get('description') as string | null)?.trim() ?? '',
        priority: (fd.get('priority') as string | null) ?? 'normal',
        preferred_completion_date:
          (fd.get('preferred_completion_date') as string | null) || null,
      };

      label!.textContent = 'Submitting…';
      disableForm(true);
      uploadsInFlight = true;

      try {
        // ─── Step 1: create the request row ────────────────────────────
        const createRes = await fetch('/api/portal/requests', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const createBody = await createRes.json().catch(() => ({}));
        if (!createRes.ok) {
          throw new Error(createBody.error || `Create HTTP ${createRes.status}`);
        }
        requestId = createBody.id as string;

        // ─── Step 2: per-file sign → PUT → confirm loop ────────────────
        // Hide pending list, show chips. Sequential to keep LTE bandwidth
        // honest and to simplify per-file error mapping.
        pendingList!.classList.add('hidden');
        if (pending.length > 0) chipList!.classList.remove('hidden');

        // Pre-create chips for every file so the user sees the whole batch
        // up front, then fill them in one by one.
        for (const file of pending) {
          fileToChip.set(file, createChip(file));
        }

        for (let i = 0; i < pending.length; i++) {
          const file = pending[i];
          label!.textContent = `Uploading ${i + 1} of ${pending.length}…`;
          try {
            await uploadOne(requestId, file);
          } catch (err) {
            const message =
              err instanceof Error ? err.message : 'Unknown error during upload';
            markChipFailed(fileToChip.get(file)!, message);
            failedFiles.add(file);
            // Continue with the rest of the batch. The request is already
            // saved — we'd rather land 3 of 4 files than abort everything.
          }
        }

        // ─── Step 3: finalize ──────────────────────────────────────────
        uploadsInFlight = false;
        label!.textContent = 'Submitted ✓';

        if (failedFiles.size > 0) {
          updatePartialFailFlash(failedFiles.size, pending.length);
          // Do NOT auto-redirect on partial failure — the user might want to
          // tap Retry on the failed chip(s) first.
        } else {
          showFlash(
            'success',
            "Got it. Your request is in the queue and we'll email you when it's in progress."
          );
          setTimeout(() => {
            window.location.assign(`/portal/r/${requestId}`);
          }, 900);
        }
      } catch (err) {
        // The create call itself failed (or something at module scope threw).
        // Re-enable the form so the user can fix and resubmit. Chips and
        // pending list both clear back to a clean state.
        uploadsInFlight = false;
        requestId = null;
        chipList!.innerHTML = '';
        chipList!.classList.add('hidden');
        fileToChip.clear();
        failedFiles.clear();
        if (pending.length > 0) pendingList!.classList.remove('hidden');
        const message =
          err instanceof Error && err.message
            ? `Couldn't submit: ${err.message}`
            : "Couldn't submit. Try again, or text Bill at (740) 617-6488.";
        showFlash('error', message);
        label!.textContent = 'Submit Request';
        disableForm(false);
      }
    });
  }
</script>
