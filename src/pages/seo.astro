---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const SITE = 'https://designedtoelevate.co';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'SEO Website Design for Local Service Businesses',
  serviceType: 'SEO website design',
  description:
    'SEO-ready website design for local service businesses — technical SEO, structured data, Core Web Vitals performance, on-page SEO, and a local SEO foundation built into the site at launch.',
  provider: { '@id': `${SITE}/#organization` },
  areaServed: { '@type': 'State', name: 'Ohio' },
  url: `${SITE}/seo`,
};

// What makes the build SEO-ready — the on-page/technical work baked into every site.
const seoReady = [
  {
    title: 'Clean, semantic Astro builds',
    body: 'Hand-built on Astro with semantic HTML, so search engines can read your pages the way they were meant to be read — fast, structured, no page-builder bloat slowing things down.',
  },
  {
    title: 'Structured data (schema)',
    body: 'LocalBusiness, Service, FAQ, and Breadcrumb schema on the right pages, so Google can understand who you are, what you do, and the areas you serve.',
  },
  {
    title: 'Core Web Vitals & performance',
    body: 'Optimized images (WebP), lazy loading, and lean code so pages load fast on a phone — the speed Google rewards and customers expect.',
  },
  {
    title: 'On-page SEO',
    body: 'Page titles, meta descriptions, headings, internal links, and image alt text — built from how your customers actually search, not stuffed with keywords.',
  },
  {
    title: 'Local SEO foundation',
    body: 'Consistent name, address, and phone, service-area structure, and Google Business Profile alignment so you turn up in local results.',
  },
  {
    title: 'Indexable by design',
    body: 'Clean URLs, an auto-generated sitemap, and a crawl-friendly structure, so new pages get discovered by Google instead of buried.',
  },
];

// Fitchin is the only project with verified, measured scores. No invented per-site stats.
const fitchinScores = [
  { score: '100', label: 'SEO' },
  { score: '100', label: 'Best Practices' },
  { score: '96', label: 'Accessibility' },
  { score: '96', label: 'Performance' },
];

const faqs = [
  {
    q: 'Will an SEO-ready website get me to the top of Google?',
    a: `No one can promise a specific ranking, and anyone who guarantees a #1 spot is selling something. What we can do is build a site Google can crawl, understand, and load fast — the technical foundation rankings are built on. From there, where you land depends on your market, your reviews, and time.`,
  },
  {
    q: 'Can you improve SEO on my current website, or do I need a rebuild?',
    a: `Sometimes we can improve what you already have, and sometimes a rebuild is the smarter move — it depends on how your current site is built. Older WordPress and page-builder sites often have technical issues that are slower to patch than to rebuild cleanly. We start with a free review and tell you straight which path makes sense for you.`,
  },
  {
    q: "What's the difference between technical SEO and local SEO?",
    a: `Technical SEO is the under-the-hood work that lets Google read and rank your site — clean code, schema, speed, and structure. Local SEO is about showing up for nearby searches — your Google Business Profile, reviews, and service-area pages. We build the technical foundation into every site; the local side has its own page.`,
  },
  {
    q: 'Do you offer monthly SEO services?',
    a: `We build SEO-ready websites — technical SEO, schema, on-page work, and a local SEO foundation set up correctly at launch. We don't currently offer ongoing SEO retainers like blog subscriptions, link building, or citation management. If that's what you're after, let's talk about whether it's the right fit before you spend on it.`,
  },
  {
    q: 'How long until I see results?',
    a: `SEO compounds. The on-page foundation works from day one, but ranking movement usually shows up over weeks to a few months — not overnight — and it depends on your market and competition.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<LandingLayout
  title="SEO Website Design for Local Service Businesses | Designed to Elevate"
  description="SEO-ready websites for local service businesses — technical SEO, schema, performance, and a local SEO foundation built in so Google can find, understand, and rank your site."
  pathname="seo"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <BreadcrumbSchema items={[
    { name: 'Home', url: `${SITE}/` },
    { name: 'SEO', url: `${SITE}/seo` },
  ]} />

  <SiteHeader />

  <main>
    <!-- HERO -->
    <section id="top" class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8 pt-12 sm:pt-20 pb-16 sm:pb-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> SEO Web Design</span>
        <h1 class="mt-5 text-[2.4rem] sm:text-[3.2rem] lg:text-[3.6rem] leading-[1.04] font-bold tracking-tight">
          Built to Be <span class="text-accent">Found on Google</span> — and Built to Convert
        </h1>
        <p class="mt-6 text-text-soft text-[1.1rem] leading-relaxed max-w-3xl">
          SEO-ready websites for local service businesses — built so Google can crawl, understand, and rank them. Technical SEO, structured data, and performance baked into the build, not bolted on later. For shops across Coshocton, Zanesville, Newark, and Eastern Ohio.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary">
            Get a Free Quote
            <span aria-hidden="true">↗</span>
          </a>
          <a href="#proof" class="btn-ghost">
            See the scores
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- WHY IT MATTERS -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Why It Matters</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          Most local business websites are invisible to Google.
        </h2>
        <div class="mt-6 space-y-4 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          <p>
            Slow load times. No structured data. Thin service pages. A site built on a template that Google struggles to read. It looks fine to you — but to a search engine, it barely exists.
          </p>
          <p>
            Being found on Google isn't luck, and it isn't a plugin you switch on at the end. It's how the site is built from the first line of code. That's the part we get right.
          </p>
        </div>
      </div>
    </section>

    <!-- WHAT MAKES OUR WEBSITES SEO-READY -->
    <section id="seo-ready" class="relative border-b border-line bg-surface-1/40 scroll-mt-24">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-24 sm:py-32">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> What's Built In</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.7rem] leading-[1.05] font-bold">
            What Makes Our Websites SEO-Ready
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Every build ships with the technical and on-page work search engines look for — set up correctly at launch, not sold back to you later.
          </p>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {seoReady.map((i) => (
            <div class="card p-7 flex flex-col gap-3">
              <h3 class="font-display font-semibold text-[1.05rem] leading-snug text-text">{i.title}</h3>
              <p class="text-[0.92rem] text-text-soft leading-relaxed">{i.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section id="proof" class="relative border-b border-line scroll-mt-24">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Proof</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          We build what we measure.
        </h2>
        <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          <a href="/case-studies/fitchin-auto-detail-tint" class="text-accent hover:text-accent-hover underline underline-offset-4 decoration-accent/40">Fitchin Auto Detail &amp; Tint</a> in Coshocton, measured on Google PageSpeed Insights at launch:
        </p>

        <div class="mt-10 grid grid-cols-2 lg:grid-cols-4 gap-4">
          {fitchinScores.map((s) => (
            <div class="card p-7 text-center">
              <div class="font-display font-bold text-accent text-[2.8rem] sm:text-[3.2rem] leading-none">{s.score}</div>
              <div class="mt-3 text-[0.8rem] uppercase tracking-[0.16em] text-text-muted">{s.label}</div>
            </div>
          ))}
        </div>
        <p class="mt-5 text-[0.85rem] text-text-muted max-w-3xl">
          Google PageSpeed Insights, desktop, at launch (2026). Scores are a snapshot and can shift over time.
        </p>

        <p class="mt-8 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          Technical scores don't guarantee rankings, but they show the site was built on a strong foundation Google can crawl, understand, and measure clearly.
        </p>
      </div>
    </section>

    <!-- OPERATING STANDARD -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> How We Build</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          Every site is held to the same standard.
        </h2>
        <div class="mt-6 space-y-4 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          <p>
            Before a build goes live, it runs through the same documented launch gate and SEO checklist — every time. Titles, schema, performance, mobile, internal links, sitemap, accessibility: checked off before launch, not guessed at.
          </p>
          <p>
            It's not a secret sauce. It's a discipline — the kind of repeatable standard most freelancers and template shops skip.
          </p>
        </div>
      </div>
    </section>

    <!-- SCOPE: WHAT THIS IS / ISN'T -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Straight Talk</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          What this includes — and what it doesn't.
        </h2>
        <div class="mt-6 space-y-4 text-text-soft text-[1.05rem] leading-relaxed max-w-3xl">
          <p>
            <span class="text-text font-semibold">What you get:</span> an SEO-ready website build — clean technical foundation, structured data, performance, on-page SEO, and a local SEO foundation, all set up correctly at launch.
          </p>
          <p>
            <span class="text-text font-semibold">What it isn't:</span> an ongoing monthly SEO retainer. We don't currently sell blog-post subscriptions, link building, or recurring citation management. We build the foundation right — the on-page work you set up once and it keeps working. If you want ongoing local SEO help, start with our <a href="/local-seo" class="text-accent hover:text-accent-hover underline underline-offset-4 decoration-accent/40">Local SEO</a> page and we'll talk about what makes sense.
          </p>
          <p>
            And the honest part: nobody can guarantee a #1 ranking, and good SEO compounds over weeks and months, not overnight. We build the foundation Google rewards — we don't sell shortcuts.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-3xl px-5 sm:px-8 py-20 sm:py-24">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> FAQ</span>
        <h2 class="mt-5 text-[1.9rem] sm:text-[2.4rem] leading-[1.07] font-bold">
          Honest answers, no fine print.
        </h2>

        <div class="mt-10 space-y-3">
          {faqs.map((f, i) => (
            <details class="card p-6 group" open={i === 0}>
              <summary class="cursor-pointer list-none font-display font-semibold text-[1rem] sm:text-[1.05rem] text-text flex items-start justify-between gap-4">
                <span>{f.q}</span>
                <span class="text-accent text-[1.2rem] leading-none mt-0.5 group-open:rotate-45 transition-transform" aria-hidden="true">+</span>
              </summary>
              <p class="mt-4 text-[0.97rem] text-text-soft leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <h2 class="text-[2.2rem] sm:text-[3rem] leading-[1.05] font-bold tracking-tight">
          Want to know if your website is built to be found?
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Have a site or thinking about building one? I'll review how it's set up for Google as part of a free review — and tell you straight whether it needs a tune-up or a rebuild.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="/contact" class="btn-primary">
            Get a Free Quote
            <span aria-hidden="true">↗</span>
          </a>
          <a href="/case-studies/fitchin-auto-detail-tint" class="btn-ghost">
            See the Fitchin build
            <span aria-hidden="true">→</span>
          </a>
          <a href="/web-design" class="btn-ghost">
            Start with the website
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
