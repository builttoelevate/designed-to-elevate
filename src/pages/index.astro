---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

const services = [
  {
    title: 'Web Design',
    body: 'Custom sites, mobile-first, tuned to convert.',
    href: '/web-design',
    icon: 'monitor',
    primary: false,
  },
  {
    title: 'Custom Lead Systems',
    body: 'Quote wizards, dashboards, automations. The system behind the sale.',
    href: '/custom-lead-systems',
    icon: 'circuit',
    primary: true,
  },
  {
    title: 'Landing Pages',
    body: 'Single-purpose pages built to turn ad clicks into leads.',
    href: '/web-design#landing-pages',
    icon: 'target',
    primary: false,
  },
  {
    title: 'Local SEO',
    body: 'On-page SEO, service-area pages, citations.',
    href: '/local-seo',
    icon: 'pin',
    primary: false,
  },
  {
    title: 'Google Business Profile Optimization',
    body: 'Setup, photo strategy, review systems.',
    href: '/local-seo#gbp',
    icon: 'star',
    primary: false,
  },
  {
    title: 'Follow-Up & Review Systems',
    body: 'Automated review requests, lead follow-up sequences, customer dashboards.',
    href: '/custom-lead-systems#follow-up',
    icon: 'mail',
    primary: false,
  },
];

const industries = [
  'Window tint shops',
  'Auto detailers',
  'Ceramic coating shops',
  'Barbershops',
  'Contractors',
  'Pressure washing',
  'Dog groomers',
  'Mobile mechanics',
  'Transportation',
  'Landscapers',
  'Cleaning companies',
];

const caseStudies = [
  {
    label: 'Auto Detail · Window Tint',
    name: 'Fitchin Automotive Detailing & Window Tinting',
    summary: 'Custom multi-step quote wizard with 378-vehicle pricing logic and an admin dashboard for lead management.',
    image: '/showcase/fitchin-mobile.png',
    href: '/case-studies#fitchin',
  },
  {
    label: 'Barbershop',
    name: 'Modern Classic Barbershop & Shave Parlor',
    summary: 'Unified Astro brand hub with Square booking and Shopify product, premium visual identity worthy of the craft.',
    image: '/showcase/modern-classic-mobile.png',
    href: '/case-studies#modern-classic',
  },
  {
    label: 'Event Transportation',
    name: 'All Transport Party Bus Rentals',
    summary: 'Mobile-first site with service-by-occasion sections, fleet gallery, and a quote/availability flow built for local search.',
    image: null,
    href: '/case-studies#all-transport',
  },
];

// LocalBusiness schema for the homepage
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Designed to Elevate',
  description: 'Web design, custom lead systems, and local SEO for Ohio service businesses.',
  url: 'https://designedtoelevate.co',
  telephone: '+1-740-617-6488',
  email: 'bilsonxnc@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'OH',
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'City', name: 'Coshocton' },
    { '@type': 'City', name: 'Zanesville' },
    { '@type': 'City', name: 'Newark' },
    { '@type': 'City', name: 'Cambridge' },
    { '@type': 'City', name: 'Mount Vernon' },
    { '@type': 'City', name: 'Carrollton' },
  ],
  serviceType: [
    'Web Design',
    'Custom Lead Systems',
    'Quote & Booking Systems',
    'Landing Pages',
    'Local SEO',
    'Google Business Profile Optimization',
    'Follow-Up & Review Systems',
  ],
  sameAs: [
    // TODO: add Google Business Profile URL once live
  ],
};
---
<LandingLayout
  title="Web Design & Local SEO for Ohio Service Businesses | Designed to Elevate"
  description="Web design, custom lead systems, and local SEO for service businesses in Coshocton, Zanesville, Newark, and across Eastern Ohio. More than a website — the system behind the sale."
  pathname=""
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <SiteHeader />

  <main>
    <!-- HERO -->
    <section id="top" class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-60" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-12 sm:pt-20 pb-20 sm:pb-28">
        <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
          <div>
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> More Than a Website. A System Behind the Sale.</span>
            <h1 class="mt-5 text-[2.5rem] sm:text-[3.2rem] lg:text-[3.7rem] leading-[1.02] font-bold text-text">
              Web Design &amp; Local SEO for
              <span class="text-accent">Ohio Service Businesses</span>
            </h1>
            <p class="mt-6 max-w-[58ch] text-[1.05rem] sm:text-[1.15rem] leading-[1.6] text-text-soft">
              I build websites and the systems behind them — quote tools, lead capture, dashboards, follow-up, and review flows that help local businesses turn searches into booked jobs.
            </p>

            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3">
              <a href="/contact" class="btn-primary">
                Get a Free Website Review
                <span aria-hidden="true">↗</span>
              </a>
              <a href="/case-studies" class="btn-ghost">
                See My Work
                <span aria-hidden="true">→</span>
              </a>
            </div>

            <p class="mt-6 text-[0.88rem] text-text-muted">
              Coshocton · Zanesville · Newark · Eastern Ohio
            </p>
          </div>

          <div class="relative" aria-hidden="true">
            <div class="relative mx-auto w-full max-w-[400px]">
              <div class="absolute -inset-6 bg-gradient-to-br from-accent/30 via-accent/5 to-transparent rounded-[2rem] blur-3xl opacity-60" aria-hidden="true"></div>
              <img
                src="/showcase-phones.png"
                alt="Two phones displaying live websites built by Designed to Elevate"
                width="768"
                height="1381"
                loading="eager"
                decoding="async"
                class="relative w-full h-auto"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- THE PROBLEM -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-5xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The Real Problem</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.8rem] leading-[1.05] font-bold tracking-tight">
          Your business shouldn't run out of your <span class="text-accent">text inbox</span>.
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-3xl">
          Most local businesses are juggling leads across phone calls, Facebook messages, website forms, sticky notes, and half-finished spreadsheets. Quotes get forgotten. Follow-ups slip. Customers wait too long. Good jobs walk away.
        </p>
      </div>
    </section>

    <!-- DIFFERENTIATOR -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8 py-24 sm:py-32">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Why I'm Different</span>
        <h2 class="mt-5 text-[2.1rem] sm:text-[3rem] lg:text-[3.4rem] leading-[1.04] font-bold tracking-tight">
          More Than a Website. <span class="text-accent">A System Behind the Sale.</span>
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-3xl">
          A good-looking website is only the first step. The real money is in what happens after someone clicks. I build quote flows, lead capture systems, follow-up automations, dashboards, and review request systems so your business can respond faster and book more jobs without juggling everything manually.
        </p>
        <div class="mt-8">
          <a href="/custom-lead-systems" class="btn-primary">
            See How It Works
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- SERVICES GRID -->
    <section id="services" class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-24 sm:py-32">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> What I Do</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Six Things I Build for Local Service Businesses
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Pick the piece you need. Or stack them — the website, the system behind it, and the local SEO around it all work better together.
          </p>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
          {services.map((s) => (
            <a
              href={s.href}
              class:list={[
                'card card-hover group p-7 flex flex-col gap-4',
                s.primary ? 'border-accent/60 shadow-[0_30px_60px_-20px_rgba(255,107,26,0.3)]' : '',
              ]}
            >
              {s.primary && (
                <div class="inline-flex items-center gap-1.5 self-start rounded-full bg-accent px-2.5 py-1 font-display text-[0.65rem] font-bold uppercase tracking-[0.16em] text-bg">
                  <span aria-hidden="true">★</span> The Differentiator
                </div>
              )}
              <div class:list={[
                'h-11 w-11 rounded-lg grid place-items-center',
                s.primary ? 'bg-accent text-bg' : 'bg-accent/15 text-accent',
              ]} aria-hidden="true">
                {s.icon === 'monitor' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                )}
                {s.icon === 'circuit' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M11 9V5a2 2 0 0 1 2-2h2"/><path d="M11 15v4a2 2 0 0 0 2 2h2"/><circle cx="6" cy="12" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="18" cy="18" r="2"/><path d="M8 12h8"/></svg>
                )}
                {s.icon === 'target' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                )}
                {s.icon === 'pin' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
                )}
                {s.icon === 'star' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15 9 22 9.3 17 14 18.5 21 12 17.3 5.5 21 7 14 2 9.3 9 9 12 2"/></svg>
                )}
                {s.icon === 'mail' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
                )}
              </div>
              <h3 class="font-display font-semibold text-[1.15rem] leading-snug text-text">{s.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{s.body}</p>
              <span class="mt-auto inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                Learn more
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- INDUSTRIES -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-20">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Industries</span>
          <h2 class="mt-5 text-[1.7rem] sm:text-[2.1rem] leading-[1.1] font-bold">
            Built for Local Service Businesses
          </h2>
          <p class="mt-4 text-text-soft text-[1rem] leading-relaxed">
            If your business runs on quotes, bookings, and repeat customers, the system fits.
          </p>
        </div>

        <ul class="mt-8 flex flex-wrap gap-2">
          {industries.map((v) => (
            <li class="inline-flex items-center rounded-full border border-line bg-surface-2 px-3.5 py-1.5 text-[0.9rem] text-text-soft font-display">
              {v}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- PROOF PREVIEW -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-24 sm:py-32">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
          <div class="max-w-2xl">
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Recent Work</span>
            <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
              Real Sites. Real Systems. Already Running.
            </h2>
          </div>
          <a href="/case-studies" class="inline-flex items-center gap-1.5 font-display font-medium text-[0.95rem] text-accent hover:text-accent-hover transition-colors whitespace-nowrap">
            All case studies
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {caseStudies.map((c) => (
            <a href={c.href} class="card card-hover overflow-hidden flex flex-col group">
              <div class="relative aspect-[9/12] bg-surface-2 overflow-hidden border-b border-line">
                {c.image ? (
                  <img
                    src={c.image}
                    alt={`${c.name} preview`}
                    class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="absolute inset-0 grid place-items-center text-text-muted/60 text-[0.78rem] font-display uppercase tracking-[0.16em] text-center px-6 leading-relaxed">
                    [NEEDS IMAGE:<br/>All Transport hero screenshot]
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{c.label}</div>
                <h3 class="mt-2 font-display font-semibold text-[1.1rem] text-text leading-snug">{c.name}</h3>
                <p class="mt-3 text-[0.9rem] text-text-soft leading-relaxed">{c.summary}</p>
                <span class="mt-5 inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                  Read the case study
                  <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Easy Way to Start</span>
        <h2 class="mt-6 text-[2.2rem] sm:text-[3.2rem] leading-[1.05] font-bold tracking-tight">
          Not sure what you need yet?
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Send me your website and I'll tell you what I'd fix first. No pitch, no pressure.
        </p>
        <div class="mt-10">
          <a href="/contact" class="btn-primary">
            Get a Free Website Review
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
