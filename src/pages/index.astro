  pathname=""
>
  <Header />
  <main id="main">
    <Hero />
    <WhoFor />
    <Problem />
    <Services />
    <ElevateSystem />
    <Founder />
    <Projects />
    <Process />
    <WaysToWork />
    <FAQ />
    <CTA />
