---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

const SITE = 'https://designedtoelevate.co';

const services = [
  {
    title: 'Search-optimized websites',
    body: 'Built around local keywords, service pages, and trust signals so customers can find you on Google.',
    icon: 'search',
    href: '/web-design',
  },
  {
    title: 'Google Ads landing pages',
    body: 'Focused pages designed to turn paid clicks into real calls and quote requests.',
    icon: 'target',
    href: '/google-ads-landing-pages',
  },
  {
    title: 'Local SEO & GBP',
    body: 'Service areas, categories, photos, and review strategy aligned with the website.',
    icon: 'pin',
    href: '/local-seo',
  },
  {
    title: 'Custom quote & booking systems',
    body: 'Lead forms, pricing logic, and booking flows that help turn visitors into real customer opportunities.',
    icon: 'flow',
    href: '/custom-lead-systems',
  },
];

const projects = [
  {
    label: 'Auto Detail · Window Tint',
    name: 'Fitchin Auto Detail & Tint',
    location: 'Coshocton, OH',
    summary: 'Custom website plus a 378-vehicle quote wizard, designed to take paid clicks straight to a quote request.',
    image: '/showcase/fitchin-mobile.png',
    href: '/case-studies/fitchin-auto-detail-tint',
  },
  {
    label: 'Barbershop',
    name: 'Modern Classic Barbershop',
    location: 'Zanesville, OH',
    summary: 'Premium custom-designed brand hub running on top of Square booking and Shopify product.',
    image: '/showcase/modern-classic-mobile.png',
    href: '/case-studies/modern-classic-barbershop',
  },
  {
    label: 'Event Transportation',
    name: 'All Transport Party Bus Rentals',
    location: 'Carrollton, OH',
    summary: 'Mobile-first site organized by occasion — weddings, proms, tailgates — built for local search across a 100-mile radius.',
    image: '/showcase/all-transport-mobile.png',
    href: '/case-studies/all-transport-party-bus',
  },
];

const featuredBullets = [
  'Pricing logic for 378 vehicle types',
  'Film tier upgrades and add-ons',
  'Lead capture before the customer leaves',
  'Booking-focused next steps',
];

const aboutAccents = ['Local Ohio', 'Mobile-first', 'Built to convert'];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Designed to Elevate',
  description:
    'Local web design, landing pages, and lead systems for Ohio service businesses that want more calls, quote requests, and booked jobs.',
  url: SITE,
  telephone: '+1-740-617-6488',
  email: 'bilsonxnc@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'OH',
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'City', name: 'Coshocton' },
    { '@type': 'City', name: 'Zanesville' },
    { '@type': 'City', name: 'Newark' },
    { '@type': 'City', name: 'Cambridge' },
    { '@type': 'City', name: 'Mount Vernon' },
    { '@type': 'City', name: 'Carrollton' },
  ],
  serviceType: [
    'Search-Optimized Websites',
    'Google Ads Landing Pages',
    'Google Business Profile Optimization',
    'Custom Quote & Booking Systems',
  ],
  founder: { '@type': 'Person', name: 'Bill Chicha' },
  sameAs: [],
};
---
<LandingLayout
  title="Designed to Elevate | Local Web Design & Lead Systems in Ohio"
  description="Designed to Elevate builds search-optimized websites, landing pages, and lead systems for local Ohio businesses that want more calls, quote requests, and booked jobs. Recent work includes Fitchin Auto Detail & Tint and Modern Classic Barbershop."
  pathname=""
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <SiteHeader />

  <main id="main">
    <!-- ─── 1. HERO ─────────────────────────────────────────── -->
    <section id="top" class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-12 sm:pt-20 pb-16 sm:pb-24">
        <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-14 items-center">
          <div>
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> LOCAL WEBSITES + LEAD SYSTEMS</span>

            <h1 class="mt-5 text-[2.4rem] sm:text-[3.2rem] lg:text-[3.6rem] leading-[1.04] font-bold tracking-tight">
              Websites built to get found <span class="text-accent">— and built to convert.</span>
            </h1>

            <p class="mt-6 text-text-soft text-[1.1rem] leading-relaxed max-w-2xl">
              Search-optimized websites, landing pages, and lead systems for local Ohio businesses that want more calls, quote requests, and booked jobs.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a href="/contact" class="btn-primary">
                Start a Conversation
                <span aria-hidden="true">↗</span>
              </a>
              <a href="/case-studies" class="btn-ghost">
                See recent work
                <span aria-hidden="true">→</span>
              </a>
            </div>

            <p class="mt-7 text-text-soft text-[0.92rem] leading-relaxed max-w-2xl italic">
              Recent local work: Fitchin Auto Detail &amp; Tint, Coshocton <span class="text-accent not-italic font-bold px-1">·</span> Modern Classic Barbershop, Zanesville.
            </p>
          </div>

          <div class="relative" aria-hidden="true">
            <div class="absolute -inset-4 bg-gradient-to-br from-accent/35 via-accent/8 to-transparent rounded-[2rem] blur-3xl opacity-70"></div>
            <img
              src="/showcase-phones-cutout.png"
              alt=""
              width="768"
              height="1235"
              loading="eager"
              decoding="async"
              class="relative w-full h-auto max-w-[400px] mx-auto"
              style="filter: drop-shadow(0 0.4rem 0.8rem rgba(0,0,0,0.55)) drop-shadow(0 1.2rem 2rem rgba(0,0,0,0.65));"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 2. RECENT LOCAL WORK ────────────────────────────── -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
          <div class="max-w-2xl">
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> RECENT LOCAL WORK</span>
            <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
              Real websites built for real local businesses.
            </h2>
          </div>
          <a href="/case-studies" class="inline-flex items-center gap-1.5 font-display font-medium text-[0.95rem] text-accent hover:text-accent-hover transition-colors whitespace-nowrap">
            All case studies
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {projects.map((p) => (
            <a href={p.href} class="card card-hover overflow-hidden flex flex-col group">
              <div class="relative aspect-[9/12] bg-surface-2 overflow-hidden border-b border-line">
                <img
                  src={p.image}
                  alt={`${p.name} mobile site preview`}
                  class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
                <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-bg/85 backdrop-blur px-2.5 py-1 text-[0.65rem] font-display tracking-wider uppercase text-text-soft border border-line">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                  Live
                </span>
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{p.label}</div>
                <h3 class="mt-2 font-display font-semibold text-[1.1rem] text-text leading-snug">{p.name}</h3>
                <div class="mt-1 text-[0.85rem] text-text-muted">{p.location}</div>
                <p class="mt-3 text-[0.9rem] text-text-soft leading-relaxed">{p.summary}</p>
                <span class="mt-5 inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                  Read the case study
                  <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── 3. WHAT I BUILD ─────────────────────────────────── -->
    <section id="services" class="relative border-b border-line bg-surface-1/40">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> WHAT I BUILD</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Built around how local customers actually decide.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Pick the piece you need. Or stack them — the website, the system behind it, and the local SEO around it all work better together.
          </p>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 gap-5">
          {services.map((s) => (
            <a href={s.href} class="card card-hover group p-7 flex flex-col gap-4">
              <div class="h-11 w-11 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
                {s.icon === 'search' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                )}
                {s.icon === 'target' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                )}
                {s.icon === 'pin' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
                )}
                {s.icon === 'flow' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h7a4 4 0 0 1 0 8H8a4 4 0 0 0 0 8h13"/><path d="m17 17 4 4-4 4"/></svg>
                )}
              </div>
              <h3 class="font-display font-semibold text-[1.15rem] leading-snug text-text">{s.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{s.body}</p>
              <span class="mt-auto inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                Learn more
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── 4. FEATURED BUILD ───────────────────────────────── -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl mb-12">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> FEATURED BUILD</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            A custom quote system built for a real local shop.
          </h2>
        </div>

        <div class="grid lg:grid-cols-[0.9fr_1fr] gap-10 lg:gap-14 items-center">
          <div class="relative" aria-hidden="true">
            <div class="absolute -inset-6 bg-gradient-to-br from-accent/35 via-accent/8 to-transparent rounded-[2rem] blur-3xl opacity-65"></div>
            <div class="relative aspect-[847/1857] max-w-[20rem] mx-auto rounded-[1.6rem] overflow-hidden border border-accent/40 shadow-[0_30px_80px_-20px_rgba(255,107,26,0.5)] bg-surface-2 rotate-[-2deg]">
              <img
                src="/wizard/step-3-pick-film-full.png"
                alt=""
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>

          <div>
            <p class="text-text-soft text-[1.05rem] leading-relaxed">
              For Fitchin Auto Detail &amp; Tint, I built a custom quote system around how the shop actually sells window tint. Instead of sending every customer to a basic contact form, the system guides them through vehicle type, service options, film upgrades, add-ons, and contact details — then helps the shop follow up with a more complete lead.
            </p>

            <ul class="mt-7 space-y-3">
              {featuredBullets.map((b) => (
                <li class="flex items-start gap-3 text-[1rem] text-text leading-snug">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/15 text-accent flex-shrink-0" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <p class="mt-7 pt-6 border-t border-line text-text-soft text-[0.98rem] italic leading-relaxed">
              Not every business needs something this complex. But every local business needs a clear path from visitor to lead to customer.
            </p>

            <div class="mt-7">
              <a href="/case-studies/fitchin-auto-detail-tint" class="btn-ghost">
                Read the full case study
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 5. ABOUT ────────────────────────────────────────── -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="mx-auto max-w-4xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> ABOUT</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          Built from inside real local businesses.
        </h2>
        <p class="mt-7 text-text-soft text-[1.05rem] leading-relaxed">
          Designed to Elevate is built and run by <strong class="text-text font-semibold">Bill Chicha</strong>, based in Ohio. Every site, landing page, and lead system shown here was built hands-on — not handed off to a team or dropped into a generic template. The work focuses on what actually moves the needle for local service businesses: showing up on Google, building trust fast, and making it easy for customers to call, book, or request a quote.
        </p>

        <ul class="mt-7 flex flex-wrap gap-x-6 gap-y-3">
          {aboutAccents.map((a) => (
            <li class="inline-flex items-center gap-2 font-display text-[0.78rem] font-semibold uppercase tracking-[0.2em] text-text-soft">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              {a}
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a href="/about" class="btn-ghost">
            More about Bill
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ─── 6. FINAL CTA ────────────────────────────────────── -->
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Easy Way to Start</span>
        <h2 class="mt-6 text-[2.2rem] sm:text-[3rem] leading-[1.05] font-bold tracking-tight">
          Want your website to bring in more of the right customers?
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Send your website. I'll tell you what I'd fix first. No pitch, no pressure.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="/contact" class="btn-primary">
            Start a Conversation
            <span aria-hidden="true">↗</span>
          </a>
          <button type="button" data-call-text class="btn-ghost">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
      Call/Text Bill
     </button>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
