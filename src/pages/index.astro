---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';

const SITE = 'https://designedtoelevate.co';

const services = [
  {
    title: 'Search-optimized websites',
    body: 'Built around local keywords, service pages, and trust signals so customers can find you on Google.',
    icon: 'search',
  },
  {
    title: 'Google Ads landing pages',
    body: 'Focused pages designed to turn paid clicks into real calls and quote requests.',
    icon: 'target',
  },
  {
    title: 'Google Business Profile optimization',
    body: 'Service areas, categories, photos, and review strategy aligned with the website.',
    icon: 'pin',
  },
  {
    title: 'Custom quote & booking systems',
    body: 'Lead forms, pricing logic, and booking flows that help turn visitors into real customer opportunities.',
    icon: 'flow',
  },
];

const projects = [
  {
    label: 'Modern Classic Barbershop · Zanesville, OH',
    image: '/showcase/modern-classic-mobile.png',
    blurb: 'A premium, booking-focused website built to match the in-shop experience and make appointments easy.',
    bullets: [
      'Mobile-first homepage',
      'Booking-focused CTAs',
      'Product visibility for retail sales',
    ],
    href: 'https://mdrnclassic.com',
  },
  {
    label: 'Fitchin Auto Detail & Tint · Coshocton, OH',
    image: '/showcase/fitchin-mobile.png',
    blurb: 'A conversion-focused website plus a custom 378-vehicle quote system.',
    bullets: [
      'Local SEO structure',
      'Custom quote system',
      'Lead capture + booking flow',
    ],
    href: 'https://fitchinautodetail.com',
  },
];

const featuredBullets = [
  'Pricing logic for 378 vehicle types',
  'Film tier upgrades and add-ons',
  'Lead capture before the customer leaves',
  'Booking-focused next steps',
];

const aboutAccents = ['Local Ohio', 'Mobile-first', 'Built to convert'];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Designed to Elevate',
  description:
    'Local web design, landing pages, and lead systems for Ohio service businesses that want more calls, quote requests, and booked jobs.',
  url: SITE,
  telephone: '+1-740-617-6488',
  email: 'bilsonxnc@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'OH',
    addressCountry: 'US',
  },
  areaServed: [
    { '@type': 'City', name: 'Coshocton' },
    { '@type': 'City', name: 'Zanesville' },
    { '@type': 'City', name: 'Newark' },
    { '@type': 'City', name: 'Cambridge' },
    { '@type': 'City', name: 'Mount Vernon' },
    { '@type': 'City', name: 'Carrollton' },
  ],
  serviceType: [
    'Search-Optimized Websites',
    'Google Ads Landing Pages',
    'Google Business Profile Optimization',
    'Custom Quote & Booking Systems',
  ],
  founder: { '@type': 'Person', name: 'Bill Chicha' },
  sameAs: [],
};
---
<LandingLayout
  title="Designed to Elevate | Local Web Design & Lead Systems in Ohio"
  description="Designed to Elevate builds search-optimized websites, landing pages, and lead systems for local Ohio businesses that want more calls, quote requests, and booked jobs. Recent work includes Fitchin Auto Detail & Tint and Modern Classic Barbershop."
  pathname=""
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <SiteHeader />

  <main id="main">
    <!-- ─── 1. HERO ─────────────────────────────────────────── -->
    <section id="top" class="hp-section hp-hero">
      <div class="grid-bg hp-hero-grid" aria-hidden="true"></div>
      <div class="accent-glow hp-hero-glow" aria-hidden="true"></div>

      <div class="hp-container hp-hero-grid-layout">
        <div class="hp-hero-copy">
          <span class="hp-eyebrow">
            Local Websites <span class="hp-eyebrow-plus" aria-hidden="true">+</span> Lead Systems
          </span>

          <h1 class="hp-h1">
            Websites built to get found <span class="hp-accent-rule">—</span> and built to convert.
          </h1>

          <p class="hp-subhead">
            Search-optimized websites, landing pages, and lead systems for local Ohio businesses that want more calls, quote requests, and booked jobs.
          </p>

          <div class="hp-hero-actions">
            <a href="#contact" class="btn-primary">
              Start a Conversation
              <span aria-hidden="true">↗</span>
            </a>
          </div>

          <p class="hp-trust">
            <em>Recent local work:</em> Fitchin Auto Detail &amp; Tint, Coshocton <span class="hp-trust-sep" aria-hidden="true">·</span> Modern Classic Barbershop, Zanesville.
          </p>
        </div>

        <div class="hp-hero-art" aria-hidden="true">
          <div class="hp-hero-art-glow"></div>
          <img
            class="hp-hero-phones"
            src="/showcase-phones-cutout.png"
            alt=""
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <!-- ─── 2. RECENT LOCAL WORK ────────────────────────────── -->
    <section class="hp-section hp-section--alt">
      <div class="hp-container">
        <header class="hp-section-head">
          <span class="hp-eyebrow">RECENT LOCAL WORK</span>
          <h2 class="hp-h2">Real websites built for real local businesses.</h2>
        </header>

        <div class="hp-projects">
          {projects.map((p) => (
            <article class="card card-hover hp-project">
              <a href={p.href} target="_blank" rel="noopener noreferrer" class="hp-project-shot" aria-label={`Visit ${p.label}`}>
                <img src={p.image} alt={`${p.label} mobile site preview`} loading="lazy" decoding="async" />
                <span class="hp-project-live">
                  <span class="hp-project-live-dot" aria-hidden="true"></span>
                  Live
                </span>
              </a>
              <div class="hp-project-body">
                <div class="hp-project-label">{p.label}</div>
                <p class="hp-project-blurb">{p.blurb}</p>
                <ul class="hp-project-bullets">
                  {p.bullets.map((b) => (
                    <li><span class="hp-bullet-dot" aria-hidden="true"></span>{b}</li>
                  ))}
                </ul>
                <a href={p.href} target="_blank" rel="noopener noreferrer" class="hp-project-link">
                  Visit live site
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── 3. WHAT I BUILD ─────────────────────────────────── -->
    <section id="services" class="hp-section">
      <div class="hp-container">
        <header class="hp-section-head">
          <span class="hp-eyebrow">WHAT I BUILD</span>
          <h2 class="hp-h2">Built around how local customers actually decide.</h2>
        </header>

        <div class="hp-services">
          {services.map((s) => (
            <article class="card hp-service">
              <div class="hp-service-icon" aria-hidden="true">
                {s.icon === 'search' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                )}
                {s.icon === 'target' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                )}
                {s.icon === 'pin' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
                )}
                {s.icon === 'flow' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h7a4 4 0 0 1 0 8H8a4 4 0 0 0 0 8h13"/><path d="m17 17 4 4-4 4"/></svg>
                )}
              </div>
              <h3 class="hp-service-title">{s.title}</h3>
              <p class="hp-service-body">{s.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── 4. FEATURED BUILD ───────────────────────────────── -->
    <section class="hp-section hp-section--alt">
      <div class="hp-container">
        <header class="hp-section-head">
          <span class="hp-eyebrow">FEATURED BUILD</span>
          <h2 class="hp-h2">A custom quote system built for a real local shop.</h2>
        </header>

        <div class="hp-featured">
          <div class="hp-featured-art" aria-hidden="true">
            <div class="hp-featured-glow"></div>
            <div class="hp-featured-phone">
              <img src="/wizard/step-3-pick-film-full.png" alt="" loading="lazy" decoding="async" />
            </div>
          </div>

          <div class="hp-featured-copy">
            <p class="hp-featured-body">
              For Fitchin Auto Detail &amp; Tint, I built a custom quote system around how the shop actually sells window tint. Instead of sending every customer to a basic contact form, the system guides them through vehicle type, service options, film upgrades, add-ons, and contact details — then helps the shop follow up with a more complete lead.
            </p>

            <ul class="hp-featured-bullets">
              {featuredBullets.map((b) => (
                <li><span class="hp-bullet-dot" aria-hidden="true"></span>{b}</li>
              ))}
            </ul>

            <p class="hp-featured-close">
              Not every business needs something this complex. But every local business needs a clear path from visitor to lead to customer.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 5. ABOUT ────────────────────────────────────────── -->
    <section class="hp-section">
      <div class="hp-container hp-about-container">
        <header class="hp-section-head">
          <span class="hp-eyebrow">ABOUT</span>
          <h2 class="hp-h2">Built from inside real local businesses.</h2>
        </header>

        <p class="hp-about-body">
          Designed to Elevate is built and run by <span class="hp-em">Bill Chicha</span>, based in Ohio. Every site, landing page, and lead system shown here was built hands-on — not handed off to a team or dropped into a generic template. The work focuses on what actually moves the needle for local service businesses: showing up on Google, building trust fast, and making it easy for customers to call, book, or request a quote.
        </p>

        <ul class="hp-about-accents">
          {aboutAccents.map((a) => (
            <li><span class="hp-bullet-dot" aria-hidden="true"></span>{a}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─── 6. CONTACT ──────────────────────────────────────── -->
    <section id="contact" class="hp-section hp-section--contact">
      <div class="grid-bg hp-contact-grid" aria-hidden="true"></div>
      <div class="accent-glow hp-contact-glow" aria-hidden="true"></div>

      <div class="hp-container hp-contact-layout">
        <header class="hp-section-head">
          <h2 class="hp-h2">Want your website to bring in more of the right customers?</h2>
          <p class="hp-contact-sub">
            If you run a local Ohio business and your website isn't helping people find you, trust you, or contact you — let's take a look.
          </p>
        </header>

        <div class="hp-contact-grid-layout">
          <!-- LEFT: form -->
          <form
            data-audit-form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="card hp-form"
            novalidate
          >
            <!-- Wired to Web3Forms (working). Resend migration is a future task —
                 needs the Vercel serverless adapter + RESEND_API_KEY. -->
            <input type="hidden" name="access_key" value="1272e2dd-abff-4804-a541-beb2bd0be075" />
            <input type="hidden" name="subject" value="New Homepage Lead — designedtoelevate.co" />
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

            <label class="hp-field">
              <span class="hp-field-label">Name <span class="hp-req">*</span></span>
              <input required name="name" type="text" autocomplete="name" placeholder="Your name" />
            </label>

            <label class="hp-field">
              <span class="hp-field-label">Business name</span>
              <input name="business" type="text" autocomplete="organization" placeholder="Acme Auto Detail" />
            </label>

            <label class="hp-field">
              <span class="hp-field-label">Phone or email <span class="hp-req">*</span></span>
              <input required name="contact" type="text" autocomplete="email" placeholder="(555) 555-5555 or you@yourshop.com" />
            </label>

            <label class="hp-field">
              <span class="hp-field-label">What do you need help with? <span class="hp-req">*</span></span>
              <textarea required name="message" rows="5" placeholder="A couple of sentences is fine — what's stuck, what you're hoping to fix."></textarea>
            </label>

            <button type="submit" class="btn-primary hp-form-submit">
              Send
              <span aria-hidden="true">↗</span>
            </button>

            <p
              data-audit-status
              class="hp-form-status hidden"
              role="status"
              aria-live="polite"
            ></p>

            <p class="hp-form-fine">
              Bill responds within 24 hours. No spam, no list-selling, no long-form sales calls.
            </p>
          </form>

          <!-- RIGHT: direct contact -->
          <aside class="hp-direct">
            <div class="hp-direct-block">
              <div class="hp-direct-label">Or text Bill directly</div>
              <a href="tel:7406176488" class="hp-direct-value">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
                (740) 617-6488
              </a>
            </div>

            <div class="hp-direct-block">
              <div class="hp-direct-label">Email</div>
              <a href="mailto:bilsonxnc@gmail.com" class="hp-direct-value">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>
                bilsonxnc@gmail.com
              </a>
            </div>

            <div class="hp-direct-block">
              <div class="hp-direct-label">Service area</div>
              <div class="hp-direct-meta">Coshocton, Zanesville, Newark &amp; surrounding Ohio.</div>
            </div>

            <div class="hp-direct-block">
              <div class="hp-direct-label">Response time</div>
              <div class="hp-direct-meta">Within 24 hours.</div>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <!-- ─── FOOTER ────────────────────────────────────────────── -->
  <footer class="hp-footer">
    <div class="hp-container hp-footer-inner">
      <a href="#top" class="hp-footer-mark" aria-label="Designed to Elevate — home">
        <img src="/logo-wordmark-orange.png" alt="Designed to Elevate" width="320" height="96" />
      </a>
      <div class="hp-footer-tagline">
        Local websites + lead systems · Serving Coshocton, Zanesville, Newark, and surrounding Ohio.
      </div>
      <div class="hp-footer-meta">
        <a href="https://designedtoelevate.co">designedtoelevate.co</a>
        <span class="hp-footer-sep" aria-hidden="true">·</span>
        <a href="mailto:bilsonxnc@gmail.com">bilsonxnc@gmail.com</a>
        <span class="hp-footer-sep" aria-hidden="true">·</span>
        <a href="tel:7406176488">(740) 617-6488</a>
      </div>
      <div class="hp-footer-legal">
        © {new Date().getFullYear()} Designed to Elevate.
        <a href="/privacy">Privacy</a>
        <span class="hp-footer-sep" aria-hidden="true">·</span>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </footer>
</LandingLayout>

<style>
  /* Homepage — uses the global landing.css token system (--color-bg,
     --color-accent, .btn-primary, .card, .eyebrow, .grid-bg,
     .accent-glow) and adds Montserrat for headings to match the
     brochure aesthetic. Body type stays Inter (already loaded). */

  /* Container */
  .hp-container {
    width: 100%;
    max-width: 78rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 768px) {
    .hp-container { padding: 0 2rem; }
  }

  /* ── Header — replaced by the shared SiteHeader component for
     multi-page nav consistency across the site. The homepage now
     gets the same dropdown nav as every other interior page. ── */

  /* ── Sections ── */
  .hp-section {
    position: relative;
    padding: 4rem 0;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hp-section { padding: 6rem 0; }
  }
  .hp-section--alt { background: rgba(22, 25, 31, 0.4); border-top: 1px solid var(--color-line); border-bottom: 1px solid var(--color-line); }

  /* All h1/h2/h3 inside the homepage use Montserrat */
  .hp-h1,
  .hp-h2,
  .hp-h3,
  .hp-section h1,
  .hp-section h2,
  .hp-section h3 {
    font-family: 'Montserrat', system-ui, -apple-system, sans-serif;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .hp-section-head { max-width: 44rem; margin-bottom: 2.75rem; }
  .hp-h2 {
    margin-top: 1rem;
    font-size: clamp(1.85rem, 4.5vw, 2.6rem);
    line-height: 1.08;
    font-weight: 700;
    color: var(--color-text);
  }

  .hp-em { color: var(--color-accent); font-weight: 600; }

  /* ── Hero ── */
  .hp-hero { padding-top: 3.5rem; padding-bottom: 4rem; }
  @media (min-width: 768px) {
    .hp-hero { padding-top: 5rem; padding-bottom: 6rem; }
  }
  .hp-hero-grid {
    position: absolute; inset: 0;
    opacity: 0.5;
    z-index: 0;
  }
  .hp-hero-glow {
    position: absolute;
    top: -10rem; right: -10rem;
    width: 40rem; height: 40rem;
    z-index: 0;
  }
  .hp-hero-grid-layout {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .hp-hero-grid-layout {
      grid-template-columns: 1.1fr 1fr;
      align-items: center;
      gap: 3.5rem;
    }
  }
  .hp-h1 {
    margin-top: 1.25rem;
    font-size: clamp(2.4rem, 6.5vw, 3.7rem);
    line-height: 1.04;
    font-weight: 800;
    color: var(--color-text);
  }
  /* Em-dash with mild horizontal compression. Uncompressed at
     Montserrat 800 / clamp 2.4–3.7rem reads as a wall, not a
     dash. scaleX(0.78) keeps the glyph clearly readable as a
     dash but visually proportional to the surrounding letters. */
  .hp-accent-rule {
    color: var(--color-accent);
    display: inline-block;
    transform: scaleX(0.78);
    transform-origin: center;
    padding: 0 0.04em;
  }

  /* Hero eyebrow — short, single-line on mobile. The "+" is the
     visual rhythm hit; keeping it slightly bolder than the rest
     of the line ties to the orange accent vocabulary used across
     the brochure and brand. */
  .hp-eyebrow {
    display: block;
    font-family: 'Montserrat', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .hp-eyebrow-plus {
    padding: 0 0.18em;
    font-weight: 800;
  }

  .hp-subhead {
    margin-top: 1.4rem;
    max-width: 36rem;
    font-size: clamp(1.05rem, 2.2vw, 1.18rem);
    line-height: 1.55;
    color: var(--color-text-soft);
  }
  .hp-hero-actions { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 1rem; }

  /* Trust line — single clean italic gray line, no leading bullet
     (the prior dot column was creating awkward two-column wrapping
     on narrow viewports). */
  .hp-trust {
    margin-top: 1.6rem;
    max-width: 38rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-text-soft);
  }
  .hp-trust em { font-style: italic; color: var(--color-text); margin-right: 0.15rem; font-weight: 500; }
  .hp-trust-sep { color: var(--color-accent); padding: 0 0.25rem; font-weight: 700; }

  /* Hero phones art */
  .hp-hero-art {
    position: relative;
    width: 100%;
    max-width: 26rem;
    margin: 0 auto;
    aspect-ratio: 768 / 1235;
  }
  .hp-hero-art-glow {
    position: absolute;
    inset: -2rem;
    background: radial-gradient(ellipse 65% 65% at 50% 50%,
                rgba(255, 122, 26, 0.45) 0%,
                rgba(255, 122, 26, 0.12) 45%,
                rgba(255, 122, 26, 0) 75%);
    z-index: 0;
    pointer-events: none;
  }
  .hp-hero-phones {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter:
      drop-shadow(0 0.6rem 1rem rgba(0, 0, 0, 0.55))
      drop-shadow(0 1.2rem 2.4rem rgba(0, 0, 0, 0.65));
  }

  /* ── Recent Local Work ── */
  .hp-projects {
    display: grid;
    gap: 1.4rem;
  }
  @media (min-width: 900px) {
    .hp-projects { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  }
  .hp-project { overflow: hidden; transition: transform 0.2s ease, border-color 0.2s ease; }
  .hp-project:hover { transform: translateY(-3px); border-color: var(--color-line-2); }
  .hp-project-shot {
    position: relative;
    display: block;
    aspect-ratio: 9 / 11;
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-line);
    overflow: hidden;
  }
  .hp-project-shot img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.4s ease;
  }
  .hp-project-shot:hover img { transform: scale(1.02); }
  .hp-project-live {
    position: absolute;
    top: 0.85rem; left: 0.85rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: rgba(15, 16, 20, 0.85);
    backdrop-filter: blur(6px);
    border: 1px solid var(--color-line);
    font-family: 'Montserrat', system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-soft);
  }
  .hp-project-live-dot {
    width: 0.4rem; height: 0.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 0.18rem rgba(255, 122, 26, 0.25);
  }
