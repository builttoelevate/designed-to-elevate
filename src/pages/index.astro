---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import GrowthSystemSection from '../components/landing/GrowthSystemSection.astro';
import { foundingPackages } from '../data/founding-packages';

const industries = [
  'Auto Detail',
  'Window Tint',
  'Barbershops',
  'Contractors',
  'Cleaners',
  'Landscapers',
  'HVAC',
  'Home Services',
];

const painPoints = [
  {
    title: "People visit your site but don't call.",
    body: "Traffic is fine. Calls aren't. Usually the page tells visitors what you do — but never what to do next.",
  },
  {
    title: "Your Google profile isn't winning enough clicks.",
    body: 'Reviews, photos, categories, and posts that compound over time make a Google Business Profile pull customers in.',
  },
  {
    title: 'Your ads send traffic to pages that don\'t convert.',
    body: 'A homepage talks about everything. A real ad landing page answers one question and pushes one action.',
  },
  {
    title: 'Your quote process is too slow or too manual.',
    body: 'Customers go to whoever answers first. A built-for-you quote flow gives prices and captures leads instantly.',
  },
  {
    title: 'Your follow-up depends on memory instead of a system.',
    body: 'Lead capture, reminders, and review requests should run themselves — not live in your head.',
  },
];

const services = [
  {
    title: 'Conversion Websites',
    body: 'Built to make people call, request quotes, and trust your business faster.',
    icon: 'monitor',
  },
  {
    title: 'Local SEO Foundations',
    body: 'Google-friendly structure, service area pages, and review strategy that helps you show up locally.',
    icon: 'pin',
  },
  {
    title: 'Quote & Lead Systems',
    body: 'Custom forms, quote wizards, and lead capture flows that turn visitors into real conversations.',
    icon: 'route',
  },
  {
    title: 'Ad Landing Pages',
    body: "Focused pages built for paid traffic, so you're not wasting clicks on a generic homepage.",
    icon: 'target',
  },
];

const projectsPreview = [
  {
    label: 'Auto Detail · Window Tint',
    title: 'Fitchin Auto Detailing & Window Tinting',
    outcome: 'A custom 378-vehicle quote wizard turning Google searches into booked tint jobs.',
    image: '/showcase/fitchin-mobile.png',
  },
  {
    label: 'Barbershop',
    title: 'Modern Classic Barbershop',
    outcome: 'A premium brand hub with unified booking and product flows.',
    image: '/showcase/modern-classic-mobile.png',
  },
];

const whyDifferent = [
  {
    title: 'Built from real local business experience.',
    body: 'Every system tested where it had to actually work — not in an agency conference room.',
  },
  {
    title: 'Focused on leads, not vanity design.',
    body: "If a section doesn't help drive a call, quote, or booking, it doesn't ship.",
  },
  {
    title: 'Simple systems local owners can run.',
    body: 'You shouldn\'t need a marketing degree to keep your own website healthy. We build it that way.',
  },
  {
    title: 'No long contracts. No agency fluff.',
    body: 'No multi-year retainers. No mystery line items. Just the work and what it costs.',
  },
];
---
<LandingLayout
  title="Designed to Elevate — Lead Systems for Local Service Businesses"
  description="We build the path from Google search to quote request to booked job. Conversion websites, local SEO, quote tools, and ad landing pages built for how local owners actually run their business."
  pathname=""
>
  <SiteHeader />

  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-60" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8 pt-16 sm:pt-24 pb-20 sm:pb-28 text-center">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Designed to Elevate</span>

        <h1 class="mt-6 text-[2.5rem] sm:text-[3.4rem] lg:text-[4.2rem] leading-[1.02] font-bold tracking-tight max-w-4xl mx-auto">
          Lead Systems for
          <span class="text-accent">Local Service Businesses</span>
        </h1>

        <p class="mt-6 max-w-2xl mx-auto text-[1.05rem] sm:text-[1.15rem] leading-[1.6] text-text-soft">
          We build the path from <span class="text-text font-medium">Google search</span> to
          <span class="text-text font-medium">quote request</span> to
          <span class="text-text font-medium">booked job</span> — using websites, local SEO, quote tools, and ad landing pages built for how local owners actually run their business.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href="/grow" class="btn-primary">
            Get a Free Lead Leak Audit
            <span aria-hidden="true">↗</span>
          </a>
          <a href="/pricing" class="btn-ghost">
            View Pricing
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <p class="mt-7 text-[0.92rem] text-text-muted">
          Built by the operator behind Fitchin's custom 378-vehicle quote system.
        </p>
      </div>
    </section>

    <!-- INDUSTRIES STRIP -->
    <section class="relative border-b border-line bg-surface-1/30">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-10 sm:py-12">
        <div class="flex flex-col sm:flex-row items-center sm:items-baseline gap-y-4 gap-x-6 text-center sm:text-left">
          <span class="font-display text-[0.78rem] uppercase tracking-[0.18em] text-text-muted flex-shrink-0">
            Built for local service businesses like
          </span>
          <ul class="flex flex-wrap justify-center sm:justify-start gap-x-4 gap-y-2 text-[0.92rem] text-text-soft">
            {industries.map((i, idx) => (
              <li class="flex items-center gap-3">
                <span>{i}</span>
                {idx < industries.length - 1 && (
                  <span aria-hidden="true" class="text-text-muted/50">·</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- PAIN — Most local websites leak leads -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> The Real Problem</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.1] font-bold">
            Most local websites don't have a traffic problem.
            <br class="hidden sm:block" />
            They have a <span class="text-accent">lead leak problem</span>.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            The visitors are showing up. They're just not turning into calls, quote requests, or booked jobs. Here's where the leak usually is.
          </p>
        </div>

        <ul class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {painPoints.map((p, i) => (
            <li class="card p-6 sm:p-7 flex flex-col gap-3">
              <span class="font-display text-[0.72rem] tracking-[0.2em] uppercase text-accent">0{i + 1}</span>
              <h3 class="font-display font-semibold text-[1.1rem] leading-snug text-text">{p.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{p.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- THE SYSTEM (reused customer journey) -->
    <GrowthSystemSection />

    <!-- WHAT WE BUILD -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> What We Build</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Tools that turn local visibility into <span class="text-accent">booked jobs</span>.
          </h2>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 gap-5">
          {services.map((s) => (
            <article class="card p-7 flex flex-col gap-4">
              <div class="h-11 w-11 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
                {s.icon === 'monitor' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
                )}
                {s.icon === 'pin' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
                )}
                {s.icon === 'route' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/></svg>
                )}
                {s.icon === 'target' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
                )}
              </div>
              <h3 class="font-display font-semibold text-[1.15rem] leading-snug text-text">{s.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{s.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- RECENT WORK -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Recent Work</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Real systems, built inside <span class="text-accent">real local businesses</span>.
          </h2>
        </div>

        <div class="mt-12 grid md:grid-cols-2 gap-6">
          {projectsPreview.map((p) => (
            <article class="card card-hover overflow-hidden flex flex-col">
              <div class="relative aspect-[9/16] bg-surface-2 overflow-hidden border-b border-line">
                <img
                  src={p.image}
                  alt={`${p.title} — mobile preview`}
                  class="absolute inset-0 w-full h-full object-cover object-top"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
                <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-bg/80 backdrop-blur px-2.5 py-1 text-[0.65rem] font-display tracking-wider uppercase text-text-soft border border-line">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                  Live · Mobile
                </span>
              </div>
              <div class="p-7 flex-1 flex flex-col">
                <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{p.label}</div>
                <h3 class="mt-2 font-display font-semibold text-[1.2rem] text-text leading-snug">{p.title}</h3>
                <p class="mt-3 text-[0.95rem] text-text-soft leading-relaxed flex-1">{p.outcome}</p>
                <a href="/work" class="mt-5 inline-flex items-center gap-1.5 font-display font-medium text-[0.9rem] text-accent hover:text-accent-hover transition-colors">
                  View project
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-10 flex justify-center">
          <a href="/work" class="btn-ghost">
            View All Work
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- WHY US -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Why We're Different</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Built by an operator, <span class="text-accent">not an agency</span>.
          </h2>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 gap-5">
          {whyDifferent.map((w) => (
            <article class="card p-7 flex flex-col gap-3">
              <div class="h-9 w-9 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="font-display font-semibold text-[1.1rem] leading-snug text-text">{w.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{w.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PRICING TEASER -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="grid-bg absolute inset-0 z-0 opacity-30" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> Pricing</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Founding pricing, <span class="text-accent">locked in for life</span>.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            We're opening 5 founding client spots at discounted launch pricing while we build proof. Founding clients lock in their rate as long as they stay subscribed. After 5 spots, prices return to standard rates.
          </p>
        </div>

        <div class="mt-12 grid md:grid-cols-3 gap-5 items-stretch">
          {foundingPackages.map((p) => (
            <article class:list={[
              'relative card p-7 flex flex-col gap-4',
              p.popular ? 'border-accent/60 lg:scale-[1.02] lg:-translate-y-1 shadow-[0_30px_60px_-20px_rgba(255,107,26,0.3)]' : '',
            ]}>
              {p.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-accent px-3 py-1 font-display text-[0.7rem] font-bold uppercase tracking-[0.16em] text-bg shadow-[0_8px_20px_-6px_rgba(255,107,26,0.6)]">
                    <span aria-hidden="true">★</span> Most Popular
                  </span>
                </div>
              )}
              <div class="font-display font-semibold text-[1.25rem] text-text">{p.name}</div>
              <div class="flex items-baseline flex-wrap gap-x-2 gap-y-1">
                <span class="font-display font-bold text-[2rem] leading-none text-text">{p.foundingPrice}</span>
                <span class="text-[0.85rem] text-text-soft">{p.foundingMeta}</span>
              </div>
              <div class="text-[0.82rem] text-text-muted">
                <span class="line-through decoration-line-2">{p.futurePrice}</span> future rate
              </div>
            </article>
          ))}
        </div>

        <div class="mt-10 flex justify-center">
          <a href="/pricing" class="btn-ghost">
            View Full Pricing
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="relative overflow-hidden">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="accent-glow absolute -bottom-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl px-5 sm:px-8 py-24 sm:py-32 text-center">
        <h2 class="text-[2.2rem] sm:text-[3.2rem] leading-[1.05] font-bold tracking-tight">
          Ready to find where your <span class="text-accent">leads are leaking</span>?
        </h2>
        <p class="mt-6 text-text-soft text-[1.05rem] sm:text-[1.15rem] leading-relaxed max-w-2xl mx-auto">
          Free Lead Leak Audit. We'll show you exactly what's costing you calls, quote requests, and booked jobs.
        </p>

        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="/grow" class="btn-primary">
            Get Free Audit
            <span aria-hidden="true">↗</span>
          </a>
          <a href="/contact" class="btn-ghost">
            Talk Through Your Project
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</LandingLayout>
