---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

const SITE = 'https://designedtoelevate.co';

const services = [
  {
    title: 'Search-optimized websites',
    body: 'Built around local keywords, service pages, and trust signals so customers can find you on Google.',
    icon: 'search',
    href: '/web-design',
  },
  {
    title: 'Google Ads landing pages',
    body: 'Focused pages designed to turn paid clicks into real calls and quote requests.',
    icon: 'target',
    href: '/google-ads-landing-pages',
  },
  {
    title: 'Local SEO & Google Business',
    body: 'Service areas, categories, photos, and review strategy aligned with the website.',
    icon: 'pin',
    href: '/local-seo',
  },
  {
    title: 'Custom quote & booking systems',
    body: 'Lead forms, pricing logic, and booking flows that turn visitors into real customer opportunities.',
    icon: 'flow',
    href: '/custom-lead-systems',
  },
];

const projects = [
  {
    label: 'Auto Detail · Window Tint',
    name: 'Fitchin Auto Detail & Tint',
    location: 'Coshocton, OH',
    summary: 'Custom website and vehicle quote system built to turn paid clicks into real tint and detail quote requests.',
    image: '/showcase/fitchin-mobile.png',
    href: '/case-studies/fitchin-auto-detail-tint',
  },
  {
    label: 'Barbershop',
    name: 'Modern Classic Barbershop',
    location: 'Zanesville, OH',
    summary: 'Premium barbershop website connected to Square booking and product sales — designed to make booking easy and the brand feel high-end.',
    image: '/showcase/modern-classic-mobile.png',
    href: '/case-studies/modern-classic-barbershop',
  },
  {
    label: 'Event Transportation',
    name: 'All Transport Party Bus Rentals',
    location: 'Carrollton, OH',
    summary: 'Mobile-first website organized by occasion — weddings, proms, tailgates — designed to turn local Google searches into real quote requests.',
    image: '/showcase/all-transport-mobile.png',
    href: '/case-studies/all-transport-party-bus',
  },
];

const signatureFeatures = [
  {
    label: 'Fitchin Auto Detail & Tint',
    headline: 'A custom quote wizard for window tint.',
    body: 'A guided flow that walks customers through vehicle, film tier, and add-ons — so the shop gets a complete lead instead of a phone tag thread.',
    image: '/home/features/fitchin-guided-tint.png',
    imageWidth: 1448,
    imageHeight: 1086,
    alt: 'Fitchin website mockup showing the Guided Tint Selection wizard with film comparison cards',
    href: '/case-studies/fitchin-auto-detail-tint',
  },
  {
    label: 'Modern Classic Barbershop',
    headline: 'The next available appointment, on the homepage.',
    body: "We pull the soonest open slot from the barbershop's booking system and surface it right at the top of the site — so clients can act on it instantly.",
    image: '/home/features/modern-classic-next-opening.png',
    imageWidth: 1672,
    imageHeight: 941,
    alt: 'Modern Classic Barbershop homepage mockup showing the next available appointment widget',
    href: '/case-studies/modern-classic-barbershop',
  },
];

const aboutAccents = ['Local Ohio', 'Mobile-first', 'Built to convert'];

const industries = [
  { label: 'Barbershop', body: 'Booking + brand sites that sit on top of Square or Booksy.', href: '/web-design' },
  { label: 'Auto Detail', body: 'Vehicle-by-vehicle quote flows that capture leads instead of phone calls.', href: '/auto-detail-websites' },
  { label: 'Window Tint', body: 'Custom quote wizards built for tier comparison and per-section pricing.', href: '/window-tint-websites' },
  { label: 'HVAC', body: 'Two-path navigation: emergency calls and replacement estimates.', href: '/hvac-websites' },
  { label: 'Landscaping', body: 'Visual-first builds with seasonal service splits and project galleries.', href: '/landscaping-websites' },
];

const pricing = [
  {
    title: 'Starter Website',
    price: 'Starting at $1,500',
    body: 'For businesses that need a clean, professional site that ranks locally and invites contact.',
    featured: false,
  },
  {
    title: 'Lead Generation Website',
    price: 'Starting at $3,000',
    body: 'For businesses that want the website to bring in real calls, quote requests, and booked jobs.',
    featured: true,
  },
  {
    title: 'Custom Lead System',
    price: 'Starting at $5,000',
    body: 'Quote wizards, booking flows, dashboards, and integrations built around how your business actually sells.',
    featured: false,
  },
];

// Homepage emits LocalBusiness (more specific than the sitewide Organization
// in LandingLayout) plus an ItemList that exposes the three signature case
// studies so Google can pull them into rich results for brand queries.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${SITE}/#localbusiness`,
    name: 'Designed to Elevate',
    description:
      'Local web design, landing pages, and lead systems for Ohio service businesses that want more calls, quote requests, and booked jobs.',
    url: SITE,
    telephone: '+1-740-617-6488',
    email: 'bilsonxnc@gmail.com',
    image: `${SITE}/og-image.png`,
    priceRange: '$$',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'OH',
      addressCountry: 'US',
    },
    areaServed: [
      { '@type': 'City', name: 'Coshocton' },
      { '@type': 'City', name: 'Zanesville' },
      { '@type': 'City', name: 'Newark' },
      { '@type': 'City', name: 'Cambridge' },
      { '@type': 'City', name: 'Mount Vernon' },
      { '@type': 'City', name: 'Carrollton' },
    ],
    serviceType: [
      'Search-Optimized Websites',
      'Google Ads Landing Pages',
      'Google Business Profile Optimization',
      'Custom Quote & Booking Systems',
    ],
    founder: { '@type': 'Person', name: 'Bill Chicha' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Recent local work',
    itemListElement: projects.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE}${p.href}`,
      name: p.name,
    })),
  },
];
---
<LandingLayout
  title="Small Business Web Designer in Ohio | Designed to Elevate"
  description="Small business web designer in Ohio. Search-optimized websites, Google Ads landing pages, and custom lead systems for local service businesses that want more calls, quotes, and booked jobs."
  pathname=""
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <SiteHeader />

  <main id="main">
    <!-- ─── 1. HERO ─────────────────────────────────────────── -->
    <section id="top" class="relative overflow-hidden border-b border-line">
      <div class="grid-bg absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>
      <div class="accent-glow absolute -top-40 -right-40 w-[640px] h-[640px] z-0" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-12 sm:pt-20 pb-16 sm:pb-24">
        <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-14 items-center">
          <div>
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> LOCAL WEBSITES + LEAD SYSTEMS</span>

            <h1 class="mt-5 text-[2.4rem] sm:text-[3.2rem] lg:text-[3.6rem] leading-[1.04] font-bold tracking-tight">
              Websites built to get found <span class="text-accent">— and built to convert.</span>
            </h1>

            <p class="mt-6 text-text-soft text-[1.1rem] leading-relaxed max-w-2xl">
              Search-optimized websites, landing pages, and lead systems for local Ohio businesses that want more calls, quote requests, and booked jobs.
            </p>

            <div class="mt-8">
              <a href="/contact" class="btn-primary">
                Get a Free Quote
                <span aria-hidden="true">↗</span>
              </a>
            </div>

            <a href="/contact" class="mt-3 inline-block text-[0.92rem] hover:text-accent transition-colors" style="color:#B8B8BC;">
              Already have a site? Get a free review
              <span class="text-accent" aria-hidden="true">→</span>
            </a>

            <p class="mt-6 text-text-soft text-[0.92rem] leading-relaxed max-w-2xl italic">
              Recent local work: Fitchin Auto Detail &amp; Tint, Coshocton <span class="text-accent not-italic font-bold px-1">·</span> Modern Classic Barbershop, Zanesville <span class="text-accent not-italic font-bold px-1">·</span> All Transport Party Bus, Carrollton.
            </p>
          </div>

          <div class="relative" aria-hidden="true">
            <div class="absolute -inset-4 bg-gradient-to-br from-accent/35 via-accent/8 to-transparent rounded-[2rem] blur-3xl opacity-70"></div>
            <img
              src="/showcase-phones-cutout.png"
              alt=""
              width="768"
              height="1235"
              loading="eager"
              decoding="async"
              class="relative w-full h-auto max-w-[400px] mx-auto"
              style="filter: drop-shadow(0 0.4rem 0.8rem rgba(0,0,0,0.55)) drop-shadow(0 1.2rem 2rem rgba(0,0,0,0.65));"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 2. RECENT LOCAL WORK ────────────────────────────── -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
          <div class="max-w-2xl">
            <span class="eyebrow"><span class="dot" aria-hidden="true"></span> RECENT LOCAL WORK</span>
            <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
              Real websites built for real local businesses.
            </h2>
          </div>
          <a href="/case-studies" class="inline-flex items-center gap-1.5 font-display font-medium text-[0.95rem] text-accent hover:text-accent-hover transition-colors whitespace-nowrap">
            All case studies
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {projects.map((p) => (
            <a href={p.href} class="card card-hover overflow-hidden flex flex-col group">
              <div class="relative aspect-[9/12] bg-surface-2 overflow-hidden border-b border-line">
                <img
                  src={p.image}
                  alt={`${p.name} mobile site preview`}
                  class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
                  width="1320"
                  height="2678"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
                <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 rounded-full bg-bg/85 backdrop-blur px-2.5 py-1 text-[0.65rem] font-display tracking-wider uppercase text-text-soft border border-line">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                  Live
                </span>
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{p.label}</div>
                <h3 class="mt-2 font-display font-semibold text-[1.1rem] text-text leading-snug">{p.name}</h3>
                <div class="mt-1 text-[0.85rem] text-text-muted">{p.location}</div>
                <p class="mt-3 text-[0.9rem] text-text-soft leading-relaxed">{p.summary}</p>
                <span class="mt-5 inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                  Read the case study
                  <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── 2b. LEAD PATH FUNNEL ────────────────────────────── -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> THE LEAD PATH</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            How a local website turns a Google search into a repeat customer.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Every site I build is designed around the same four steps — show up where customers are searching, earn trust with real reviews, convert the visit into a booking, and follow up to bring them back.
          </p>
        </div>

        <figure class="mt-12">
          <img
            src="/home/website-lead-path-funnel.png"
            alt="Local business website lead path: Get Found on Google with optimized local SEO, Build Trust with real customer reviews, Convert visits with a seamless self-service booking system, and Follow Up with automated review requests — illustrated using Modern Classic Barbershop in Zanesville, Ohio."
            class="block w-full h-auto max-w-lg mx-auto rounded-2xl"
            loading="lazy"
            decoding="async"
            width="1122"
            height="1402"
          />
          <figcaption class="mt-6 text-center text-text-muted text-[0.92rem] italic max-w-xl mx-auto">
            Shown with Modern Classic Barbershop in Zanesville — a real client running this exact lead path today.
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ─── 3. WHAT I BUILD ─────────────────────────────────── -->
    <section id="services" class="relative border-b border-line bg-surface-1/40">
      <div class="grid-bg absolute inset-0 z-0 opacity-40" aria-hidden="true"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> WHAT I BUILD</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Built around how local customers actually decide.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Start with the piece you need most — a better website, a stronger landing page, local SEO, or a custom lead system. They work best when they work together.
          </p>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 gap-5">
          {services.map((s) => (
            <a href={s.href} class="card card-hover group p-7 flex flex-col gap-4">
              <div class="h-11 w-11 rounded-lg bg-accent/15 text-accent grid place-items-center" aria-hidden="true">
                {s.icon === 'search' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                )}
                {s.icon === 'target' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                )}
                {s.icon === 'pin' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12Z"/><circle cx="12" cy="9" r="2.5"/></svg>
                )}
                {s.icon === 'flow' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h7a4 4 0 0 1 0 8H8a4 4 0 0 0 0 8h13"/><path d="m17 17 4 4-4 4"/></svg>
                )}
              </div>
              <h3 class="font-display font-semibold text-[1.15rem] leading-snug text-text">{s.title}</h3>
              <p class="text-[0.95rem] text-text-soft leading-relaxed">{s.body}</p>
              <span class="mt-auto inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                Learn more
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>

        <p class="mt-8 text-text-soft text-[1rem] leading-relaxed">
          Every site I build is SEO-ready from day one —
          <a href="/seo" class="text-accent hover:text-accent-hover underline underline-offset-4 decoration-accent/40">see what that means →</a>
        </p>
      </div>
    </section>

    <!-- ─── 4. PRICING ──────────────────────────────────────── -->
    <section id="pricing" class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> PRICING</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Packages &amp; Starting Prices
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed italic">
            Starting points, not ceilings. Final scope and pricing depend on your project.
          </p>
        </div>

        <div class="mt-12 grid lg:grid-cols-3 gap-5 lg:gap-6 items-stretch">
          {pricing.map((p) => (
            <article
              class:list={[
                'card relative p-7 sm:p-8 flex flex-col',
                p.featured
                  ? 'border-accent/60 lg:scale-[1.02] lg:-translate-y-1 shadow-[0_30px_60px_-20px_rgba(255,107,26,0.35)]'
                  : '',
              ]}
            >
              {p.featured && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-accent px-3 py-1 font-display text-[0.7rem] font-bold uppercase tracking-[0.16em] text-bg shadow-[0_8px_20px_-6px_rgba(255,107,26,0.6)]">
                    <span aria-hidden="true">★</span> Most Popular
                  </span>
                </div>
              )}

              <h3 class="font-display font-semibold text-[1.4rem] text-text leading-snug">{p.title}</h3>
              <div class="mt-3 flex items-baseline gap-2">
                <span class="font-display font-bold text-[1.5rem] sm:text-[1.7rem] text-accent">{p.price}</span>
              </div>
              <p class="mt-4 text-[0.98rem] text-text-soft leading-relaxed">{p.body}</p>
            </article>
          ))}
        </div>

        <div class="mt-12 flex justify-center">
          <a href="/contact" class="btn-primary">
            Get a Free Quote
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ─── 4b. INDUSTRIES WE BUILD FOR ─────────────────────── -->
    <section id="industries" class="relative border-b border-line bg-surface-1/40 scroll-mt-24">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> INDUSTRIES WE BUILD FOR</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Built for the trades that actually live or die by their website.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Same conversion playbook, tuned to how each trade actually gets bought.
          </p>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {industries.map((i) => (
            <a href={i.href} class="card card-hover group p-7 flex flex-col gap-3">
              <h3 class="font-display font-semibold text-[1.05rem] leading-snug text-text">{i.label} Websites</h3>
              <p class="text-[0.92rem] text-text-soft leading-relaxed">{i.body}</p>
              <span class="mt-auto inline-flex items-center gap-1.5 text-[0.85rem] font-display font-medium text-accent group-hover:translate-x-0.5 transition-transform">
                See the page
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── 5. SIGNATURE FEATURES ───────────────────────────── -->
    <section class="relative border-b border-line">
      <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20 sm:py-28">
        <div class="max-w-3xl mb-12">
          <span class="eyebrow"><span class="dot" aria-hidden="true"></span> SIGNATURE FEATURES</span>
          <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
            Custom features built for how each local shop actually sells.
          </h2>
          <p class="mt-5 text-text-soft text-[1.05rem] leading-relaxed">
            Not bolt-on widgets. Real features designed around the business — and the buyer's next step.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
          {signatureFeatures.map((f) => (
            <article class="card overflow-hidden flex flex-col">
              <div class="relative bg-surface-2 border-b border-line">
                <div class="absolute inset-0 bg-gradient-to-br from-accent/15 via-transparent to-transparent pointer-events-none" aria-hidden="true"></div>
                <img
                  src={f.image}
                  alt={f.alt}
                  class="relative w-full h-auto"
                  width={f.imageWidth}
                  height={f.imageHeight}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-7 sm:p-8 flex-1 flex flex-col">
                <div class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-display">{f.label}</div>
                <h3 class="mt-2 font-display font-semibold text-[1.25rem] sm:text-[1.35rem] leading-snug text-text">{f.headline}</h3>
                <p class="mt-3 text-[0.98rem] text-text-soft leading-relaxed">{f.body}</p>
                <a href={f.href} class="mt-6 inline-flex items-center gap-1.5 text-[0.92rem] font-display font-medium text-accent hover:text-accent-hover transition-colors">
                  Read the case study
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>

        <p class="mt-12 max-w-2xl text-text-soft text-[0.98rem] italic leading-relaxed">
          Not every business needs something this custom. But every local business needs a clear path from visitor to lead to customer.
        </p>
      </div>
    </section>

    <!-- ─── 5. ABOUT ────────────────────────────────────────── -->
    <section class="relative border-b border-line bg-surface-1/40">
      <div class="mx-auto max-w-4xl px-5 sm:px-8 py-20 sm:py-28">
        <span class="eyebrow"><span class="dot" aria-hidden="true"></span> ABOUT</span>
        <h2 class="mt-5 text-[2rem] sm:text-[2.6rem] leading-[1.05] font-bold">
          Built from inside real local businesses.
        </h2>
        <p class="mt-7 text-text-soft text-[1.05rem] leading-relaxed">
          I'm <strong class="text-text font-semibold">Bill Chicha</strong>, the builder behind Designed to Elevate — a small business web designer based in Ohio. Every site, landing page, and lead system shown here was built hands-on by me — not outsourced, not handed to a team, and not dropped into a generic template. The work focuses on what local service businesses actually need: showing up on Google, building trust fast, and making it easy for customers to call, book, or request a quote.
        </p>

        <ul class="mt-7 flex flex-wrap gap-x-6 gap-y-3">
          {aboutAccents.map((a) => (
            <li class="inline-flex items-center gap-2 font-display text-[0.78rem] font-semibold uppercase tracking-[0.2em] text-text-soft">
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              {a}
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a href="/about" class="btn-ghost">
            More about Bill
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ─── 6. FINAL CTA ────────────────────────────────────── -->
    <section class="relative overflow-hidden">
