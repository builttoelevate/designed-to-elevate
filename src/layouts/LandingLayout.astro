---
import '../styles/landing.css';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  noindex?: boolean;
  ogImage?: string;
  // Skip-link target/label. Per-page override so the skip link lands on the
  // page's real conversion element (e.g. the pricing/form at #main) instead of
  // the default #apply CTA band. Defaults preserve every existing page.
  skipHref?: string;
  skipLabel?: string;
}

const {
  title = 'Designed to Elevate — Ohio Web Design & Lead Systems',
  description = 'Search-optimized websites, landing pages, and lead systems for local Ohio service businesses that want more calls, quote requests, and booked jobs.',
  pathname = '',
  noindex = false,
  ogImage,
  skipHref = '#apply',
  skipLabel = 'Skip to application form',
} = Astro.props;

const SITE_URL = 'https://designedtoelevate.co';
const canonical = `${SITE_URL}/${pathname}`.replace(/\/+$/, '/');
const ogImageUrl = `${SITE_URL}${ogImage ?? '/og-image.png'}`;

// Sitewide JSON-LD. Emits an Organization with a stable @id that per-page
// schema can reference (Service.provider, CreativeWork.creator, etc.), and a
// WebSite entity so Google can render a sitelinks search box if it chooses.
// Homepage-specific LocalBusiness schema lives in index.astro and complements
// — does not replace — the Organization defined here.
const sitewideSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: 'Designed to Elevate',
    url: SITE_URL,
    logo: `${SITE_URL}/logo-wordmark-orange.png`,
    email: 'bilsonxnc@gmail.com',
    telephone: '+1-740-617-6488',
    founder: { '@type': 'Person', name: 'Bill Chicha' },
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'OH',
      addressCountry: 'US',
    },
    areaServed: { '@type': 'State', name: 'Ohio' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE_URL}/#website`,
    url: SITE_URL,
    name: 'Designed to Elevate',
    publisher: { '@id': `${SITE_URL}/#organization` },
    inLanguage: 'en-US',
  },
];

// Google tag (gtag.js) — GA4 + Google Ads, loaded once site-wide off a SINGLE
// gtag setup: one script load with the GA4 ID as the src param, then both IDs
// configured (no second Google tag). To pause tracking, set an ID back to a
// value containing 'PLACEHOLDER'.
const GA4_ID = 'G-PKT3PJX7N7';                 // GA4 Measurement ID
const GOOGLE_ADS_ID = 'AW-11109940882';        // Google Ads conversion ID
const ADS_LEAD_LABEL = '7knECKXF0bgcEJL90LEp'; // quote-form submit conversion (send_to = AW-…/label)
const ADS_PHONE_LABEL = 'PHONE_LABEL';         // no tel/sms Ads label yet — phone taps fire a GA4 event to import later
const TRACKING_IDS = [GA4_ID, GOOGLE_ADS_ID].filter((id) => !id.includes('PLACEHOLDER'));
const TRACKING_ENABLED = TRACKING_IDS.length > 0;
---
<!doctype html>
<html lang="en" class="landing">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0E1014" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Bill Chicha" />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={canonical} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo-mark.png" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Designed to Elevate" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  {!noindex && (
    <script type="application/ld+json" set:html={JSON.stringify(sitewideSchema)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@700;800&family=Space+Grotesk:wght@500;600;700&display=swap"
  />

  {/* Google tag (gtag.js) — async, non-render-blocking. The remote loader only
      renders once REAL IDs replace the placeholders in the frontmatter (no 404
      tag requests for live visitors while pending). The gtag() stub + dataLayer
      are ALWAYS defined so conversion/event calls never throw before IDs exist. */}
  {TRACKING_ENABLED && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${TRACKING_IDS[0]}`}></script>
  )}
  <script is:inline define:vars={{ TRACKING_IDS, GA4_ID, GOOGLE_ADS_ID, ADS_LEAD_LABEL, ADS_PHONE_LABEL }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ window.dataLayer.push(arguments); }
    window.gtag = window.gtag || gtag;
    gtag('js', new Date());
    TRACKING_IDS.forEach(function (id) { gtag('config', id); });

    var adsReady = GOOGLE_ADS_ID.indexOf('PLACEHOLDER') === -1;
    var ga4Ready = GA4_ID.indexOf('PLACEHOLDER') === -1;
    var leadReady = adsReady && ADS_LEAD_LABEL.indexOf('LABEL') === -1;
    var phoneReady = adsReady && ADS_PHONE_LABEL.indexOf('LABEL') === -1;

    // Enhanced Conversions for Web — normalize the raw name/email/phone the form
    // collected; gtag SHA-256-hashes it in the browser before it ever leaves the
    // page. Phone must be E.164.
    function ecPhone(v){ var d = String(v || '').replace(/[^0-9]/g, ''); if (!d) return ''; if (d.length === 10) return '+1' + d; if (d.length === 11 && d.charAt(0) === '1') return '+' + d; return '+' + d; }
    function setUserData(d){
      if (!d) return;
      var ud = {};
      if (d.email) ud.email = String(d.email).trim().toLowerCase();
      if (d.phone) { var ph = ecPhone(d.phone); if (ph) ud.phone_number = ph; }
      if (d.name) {
        var parts = String(d.name).trim().split(/\s+/);
        ud.address = { first_name: parts.shift() || '', last_name: parts.join(' ') };
      }
      if (Object.keys(ud).length) gtag('set', 'user_data', ud);
    }

    // PRIMARY conversion — fires once, only on a CONFIRMED final form submit.
    // The audit-form handler dispatches this on an HTTP-200 success AFTER the lead
    // is saved; the partial lead-capture POST does NOT dispatch it, and it never
    // runs on the submit-button click before the save. So no double-count, no
    // premature fire. Enhanced-conversions user_data is set immediately before.
    document.addEventListener('audit-form:success', function (e) {
      var d = (e && e.detail) || {};
      setUserData(d);
      window.dataLayer.push({ event: 'generate_lead' });
      if (ga4Ready) gtag('event', 'generate_lead');
      if (leadReady) gtag('event', 'conversion', { send_to: GOOGLE_ADS_ID + '/' + ADS_LEAD_LABEL });
    });

    // SECONDARY signal — phone/text taps (often the likeliest mobile lead).
    // Distinct event name ('contact_click', with method) so it can be imported as
    // a SEPARATE Google Ads conversion later without touching the lead conversion.
    document.addEventListener('click', function (e) {
      var a = e.target && e.target.closest ? e.target.closest('a[href^="tel:"], a[href^="sms:"]') : null;
      if (!a) return;
      var method = a.getAttribute('href').indexOf('sms:') === 0 ? 'sms' : 'phone';
      window.dataLayer.push({ event: 'contact_click', method: method });
      if (ga4Ready) gtag('event', 'contact_click', { method: method });
      if (phoneReady) gtag('event', 'conversion', { send_to: GOOGLE_ADS_ID + '/' + ADS_PHONE_LABEL });
    });

    // ATTRIBUTION — read gclid/utm from the URL, persist to a 90-day cookie, and
    // stamp them (from URL or cookie) onto every lead form so the lead payload
    // carries them and a closed job can be traced to the originating click.
    (function () {
      try {
        var p = new URLSearchParams(window.location.search);
        var keys = ['gclid','gbraid','wbraid','utm_source','utm_medium','utm_campaign','utm_term','utm_content'];
        var COOKIE = 'dte_attr';
        var data = {};
        keys.forEach(function (k){ var v = p.get(k); if (v) data[k] = v; });
        if (Object.keys(data).length) {
          try { document.cookie = COOKIE + '=' + encodeURIComponent(JSON.stringify(data)) + ';path=/;max-age=7776000;SameSite=Lax'; } catch (e) {}
        } else {
          try {
            var m = document.cookie.match(new RegExp('(?:^|; )' + COOKIE + '=([^;]+)'));
            if (m) data = JSON.parse(decodeURIComponent(m[1])) || {};
          } catch (e) {}
        }
        var present = Object.keys(data);
        if (!present.length) return;
        var stamp = function () {
          document.querySelectorAll('[data-audit-form]').forEach(function (f) {
            present.forEach(function (k) {
              if (f.querySelector('input[name="' + k + '"]')) return;
              var i = document.createElement('input');
              i.type = 'hidden'; i.name = k; i.value = data[k];
              f.appendChild(i);
            });
          });
        };
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', stamp);
        else stamp();
      } catch (e) {}
    })();
  </script>
</head>
<body class="bg-bg text-text font-body antialiased">
  <a class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:px-3 focus:py-2 focus:rounded-md focus:bg-accent focus:text-bg" href={skipHref}>{skipLabel}</a>
  <slot />

  <!-- Global Call/Text popup. Any element with [data-call-text]
       opens this dialog so visitors can pick between calling and
       texting Bill instead of being dropped straight into the
       phone app. The dialog uses the native <dialog> element for
       built-in modality, focus trap, and ESC-to-close. -->
  <dialog
    id="call-text-popup"
    class="ct-popup"
    aria-labelledby="ct-popup-title"
  >
    <button type="button" class="ct-popup-close" data-popup-close aria-label="Close">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="ct-popup-eyebrow">
      <span class="ct-popup-dot" aria-hidden="true"></span>
      Reach Bill
    </div>
    <h2 id="ct-popup-title" class="ct-popup-number">(740) 617-6488</h2>

    <div class="ct-popup-actions">
      <a href="tel:7406176488" class="btn-primary ct-popup-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call
      </a>
      <a href="sms:7406176488" class="btn-ghost ct-popup-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Text
      </a>
    </div>

    <p class="ct-popup-fine">Bill picks up. No call center, no funnel.</p>
  </dialog>

  <style is:global>
    /* ── Call/Text popup ────────────────────────────────────────
       Uses native <dialog> element so the browser handles the
       backdrop, focus trap, and ESC-to-close for free. */
    .ct-popup {
      position: fixed;
      max-width: 22rem;
      width: calc(100% - 2rem);
      padding: 2rem 1.75rem 1.75rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: linear-gradient(180deg, var(--color-surface-1), var(--color-surface-2));
      color: var(--color-text);
      box-shadow:
        0 0 0 1px rgba(255, 122, 26, 0.08),
        0 30px 80px -20px rgba(0, 0, 0, 0.7),
        0 12px 32px -10px rgba(255, 107, 26, 0.25);
      text-align: center;
    }
    .ct-popup::backdrop {
      background: rgba(8, 9, 12, 0.78);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .ct-popup[open] {
      animation: ct-popup-in 0.18s ease-out;
    }
    @keyframes ct-popup-in {
      from { opacity: 0; transform: translateY(8px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .ct-popup-close {
      position: absolute;
      top: 0.6rem;
      right: 0.6rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      background: transparent;
      border: 0;
      padding: 0;
      color: var(--color-text-muted);
      cursor: pointer;
      border-radius: 0.4rem;
      transition: color 0.15s ease, background 0.15s ease;
    }
    .ct-popup-close:hover { color: var(--color-text); background: rgba(255, 255, 255, 0.05); }
    .ct-popup-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-display);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .ct-popup-dot {
      width: 0.4rem;
      height: 0.4rem;
      border-radius: 50%;
      background: var(--color-accent);
      box-shadow: 0 0 0 0.18rem rgba(255, 107, 26, 0.18);
    }
    .ct-popup-number {
      margin: 0.7rem 0 0;
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--color-text);
    }
    .ct-popup-actions {
      margin-top: 1.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.7rem;
    }
    .ct-popup-btn {
      width: 100%;
      gap: 0.45rem;
    }
    .ct-popup-fine {
      margin: 1.1rem 0 0;
      font-size: 0.78rem;
      color: var(--color-text-muted);
      line-height: 1.5;
    }
    /* Reset for [data-call-text] buttons used inline so they
       inherit whatever utility/Tailwind classes wrap them. */
    button[data-call-text] {
      background: none;
      border: 0;
      padding: 0;
      margin: 0;
      font: inherit;
      color: inherit;
      cursor: pointer;
      text-align: inherit;
    }
  </style>

  <script>
    // Call/Text popup — opens the global <dialog> when any element
    // with [data-call-text] is clicked.
    const ctPopup = document.getElementById('call-text-popup') as HTMLDialogElement | null;
    if (ctPopup) {
      document.querySelectorAll<HTMLElement>('[data-call-text]').forEach((trigger) => {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          if (typeof ctPopup.showModal === 'function') {
            ctPopup.showModal();
          } else {
            // Fallback for ancient browsers: jump straight to tel:
            window.location.href = 'tel:7406176488';
          }
        });
      });
      // Click outside the dialog content (on the backdrop) closes it.
      ctPopup.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target === ctPopup || target.closest('[data-popup-close]')) {
          ctPopup.close();
        }
      });
    }

    // Smooth-scroll for any in-page anchor link
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href');
        if (!id || id === '#') return;
        const el = document.querySelector(id);
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', id);
        }
      });
    });

    // Sticky mobile CTA — show only when the hero CTA has scrolled out
    // of view AND the apply form section is not yet visible. Keeps one
    // major orange filled CTA on screen at a time.
    const heroCta = document.querySelector<HTMLElement>('[data-hero-cta]');
    const stickyCta = document.querySelector<HTMLElement>('[data-sticky-cta]');
    // Prefer the real conversion form (#quote wizard) when present; fall back to
    // the #apply CTA band. querySelector returns whichever appears first in the
    // DOM, so pages with a mid-page #quote track it, and pages with only #apply
    // are unaffected.
    const applyFormSection = document.querySelector<HTMLElement>('#quote, #apply');

    if (heroCta && stickyCta) {
      let heroVisible = true;
      let formVisible = false;

      const update = () => {
        const show = !heroVisible && !formVisible;
        stickyCta.classList.toggle('translate-y-full', !show);
        stickyCta.classList.toggle('opacity-0', !show);
        stickyCta.classList.toggle('pointer-events-none', !show);
      };

      new IntersectionObserver(
        (entries) => {
          heroVisible = entries[0].isIntersecting;
          update();
        },
        { threshold: 0 }
      ).observe(heroCta);

      if (applyFormSection) {
        new IntersectionObserver(
          (entries) => {
            formVisible = entries[0].isIntersecting;
            update();
          },
          { threshold: 0.15 }
        ).observe(applyFormSection);
      }
    }

    // Audit form → Web3Forms.
    // FormData preserves multi-value `help[]` checkboxes natively;
    // Web3Forms parses them as an array and aggregates them in the email.
    // Conversion tracking is wired in the <head> gtag block: it listens for the
    // `audit-form:success` event dispatched below and fires the Ads/GA4 conversion.
    const form = document.querySelector<HTMLFormElement>('[data-audit-form]');
    const status = document.querySelector<HTMLElement>('[data-audit-status]');
    if (form && status) {
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const originalBtnHTML = submitBtn?.innerHTML ?? '';

      const showStatus = (msg: string, isError: boolean) => {
        status.textContent = msg;
        status.classList.remove('hidden');
        status.classList.add('flex');
        status.style.color = isError ? '#F87171' : '';
      };

      const setDisabled = (disabled: boolean) => {
        form.querySelectorAll('input, textarea, select, button').forEach((el) => {
          (el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | HTMLButtonElement).disabled = disabled;
        });
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Snapshot the form data BEFORE disabling controls — `disabled`
        // inputs are excluded from FormData per spec, which would strip
        // access_key and every other field from the payload.
        const formData = new FormData(form);

        setDisabled(true);
        if (submitBtn) submitBtn.innerHTML = 'Sending…';
        showStatus('Sending your application…', false);

        try {
          // multipart/form-data — bit-for-bit what a native HTML form POST
          // would send. Multi-value help[] checkboxes preserved as repeats.
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: formData,
          });
          const result = await response
            .json()
            .catch(() => ({} as { success?: boolean; message?: string }));

          if (response.ok && result.success) {
            // Dispatch a page-level event so per-page scripts (e.g. /upgrade
            // analytics) can react without re-implementing the fetch.
            document.dispatchEvent(new CustomEvent('audit-form:success', {
              detail: {
                source: (formData.get('source') as string) || form.getAttribute('action') || '',
                // Passed to gtag enhanced conversions (hashed in-browser by gtag).
                name: (formData.get('name') as string) || '',
                email: (formData.get('email') as string) || '',
                phone: (formData.get('phone') as string) || '',
              },
            }));

            // Opt-in redirect: forms with [data-redirect="/path"] navigate
            // to a thank-you page after a successful submit. Forms without
            // the attribute keep the existing inline-confirmation flow.
            const redirectTo = form.getAttribute('data-redirect');
            if (redirectTo) {
              if (submitBtn) submitBtn.innerHTML = 'Sent ✓';
              window.location.assign(redirectTo);
              return;
            }

            if (submitBtn) submitBtn.innerHTML = 'Sent ✓';
            showStatus(
              "Thanks! Bill will reach out within 24 hours. If you'd like to talk now, call or text (740) 617-6488.",
              false
            );
          } else {
            throw new Error(result.message || `HTTP ${response.status}`);
          }
        } catch (err) {
          setDisabled(false);
          if (submitBtn) submitBtn.innerHTML = originalBtnHTML;
          const detail = err instanceof Error ? err.message : 'Unknown error';
          document.dispatchEvent(new CustomEvent('audit-form:error', {
            detail: { message: detail },
          }));
          showStatus(
            `Couldn't send your application (${detail}). Please call or text Bill at (740) 617-6488 and we'll handle it directly.`,
            true
          );
        }
      });
    }
  </script>
</body>
</html>
