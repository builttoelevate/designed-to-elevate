---
import '../styles/landing.css';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = 'Founding 5 Pricing — Lead Systems for Local Service Businesses | Designed to Elevate',
  description = "We're opening 5 founding client spots at locked-in launch pricing. Get more calls, quote requests, and booked jobs from your website. Free Lead Leak Audit included.",
  pathname = 'grow',
} = Astro.props;

const SITE_URL = 'https://designedtoelevate.co';
const canonical = `${SITE_URL}/${pathname}`.replace(/\/+$/, '/');
---
<!doctype html>
<html lang="en" class="landing">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0E1014" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo-mark.png" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${SITE_URL}/og-image.png`} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Designed to Elevate" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${SITE_URL}/og-image.png`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
  />
</head>
<body class="bg-bg text-text font-body antialiased">
  <a class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:px-3 focus:py-2 focus:rounded-md focus:bg-accent focus:text-bg" href="#audit-form">Skip to audit form</a>
  <slot />

  <script>
    // Smooth-scroll for any in-page anchor link
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href');
        if (!id || id === '#') return;
        const el = document.querySelector(id);
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', id);
        }
      });
    });

    // Sticky mobile CTA — show only when the hero CTA has scrolled out
    // of view AND the audit form section is not yet visible. Keeps one
    // major orange filled CTA on screen at a time.
    const heroCta = document.querySelector<HTMLElement>('[data-hero-cta]');
    const stickyCta = document.querySelector<HTMLElement>('[data-sticky-cta]');
    const auditFormSection = document.querySelector<HTMLElement>('#audit-form');

    if (heroCta && stickyCta) {
      let heroVisible = true;
      let formVisible = false;

      const update = () => {
        const show = !heroVisible && !formVisible;
        stickyCta.classList.toggle('translate-y-full', !show);
        stickyCta.classList.toggle('opacity-0', !show);
        stickyCta.classList.toggle('pointer-events-none', !show);
      };

      new IntersectionObserver(
        (entries) => {
          heroVisible = entries[0].isIntersecting;
          update();
        },
        { threshold: 0 }
      ).observe(heroCta);

      if (auditFormSection) {
        new IntersectionObserver(
          (entries) => {
            formVisible = entries[0].isIntersecting;
            update();
          },
          { threshold: 0.15 }
        ).observe(auditFormSection);
      }
    }

    // Audit form → Web3Forms.
    // FormData preserves multi-value `help[]` checkboxes natively;
    // Web3Forms parses them as an array and aggregates them in the email.
    // Add Google Ads conversion tracking inside the success branch when ready.
    const form = document.querySelector<HTMLFormElement>('[data-audit-form]');
    const status = document.querySelector<HTMLElement>('[data-audit-status]');
    if (form && status) {
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const originalBtnHTML = submitBtn?.innerHTML ?? '';

      const showStatus = (msg: string, isError: boolean) => {
        status.textContent = msg;
        status.classList.remove('hidden');
        status.classList.add('flex');
        status.style.color = isError ? '#F87171' : '';
      };

      const setDisabled = (disabled: boolean) => {
        form.querySelectorAll('input, textarea, select, button').forEach((el) => {
          (el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | HTMLButtonElement).disabled = disabled;
        });
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        setDisabled(true);
        if (submitBtn) submitBtn.innerHTML = 'Sending…';
        showStatus('Sending your audit request…', false);

        try {
          // Submit FormData as multipart/form-data — bit-for-bit identical to
          // what the form's native action="..." method="POST" would send.
          // Multi-value help[] checkboxes are preserved as repeated entries.
          const formData = new FormData(form);
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: formData,
          });
          const result = await response
            .json()
            .catch(() => ({} as { success?: boolean; message?: string }));

          // Log full response for debugging in DevTools (remove later).
          console.log('[audit-form] web3forms response:', response.status, result);

          if (response.ok && result.success) {
            if (submitBtn) submitBtn.innerHTML = 'Sent ✓';
            showStatus(
              "Thanks! Bill will reach out within 24 hours. If you'd like to talk now, call or text 740-617-6488.",
              false
            );
          } else {
            throw new Error(result.message || `HTTP ${response.status}`);
          }
        } catch (err) {
          setDisabled(false);
          if (submitBtn) submitBtn.innerHTML = originalBtnHTML;
          const detail = err instanceof Error ? err.message : 'Unknown error';
          showStatus(
            `Couldn't send your request (${detail}). Please call or text Bill at 740-617-6488 and we'll handle it directly.`,
            true
          );
        }
      });
    }
  </script>
</body>
</html>
