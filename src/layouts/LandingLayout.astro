---
import '../styles/landing.css';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  noindex?: boolean;
  ogImage?: string;
  skipHref?: string;
  skipLabel?: string;
}

const {
  title = 'Designed to Elevate — Ohio Web Design & Lead Systems',
  description = 'Search-optimized websites, landing pages, and lead systems for local Ohio service businesses that want more calls, quote requests, and booked jobs.',
  pathname = '',
  noindex = false,
  ogImage,
  // Skip-link target/label. Per-page override so the skip link lands on the
  // page's real conversion element (e.g. the quote wizard at #quote) instead
  // of the generic #apply CTA band. Defaults preserve existing pages.
  skipHref = '#apply',
  skipLabel = 'Skip to application form',
} = Astro.props;

const SITE_URL = 'https://designedtoelevate.co';

// Google tag (gtag.js) — Google Ads conversion + GA4, loaded once for every
// page that uses this layout. PLACEHOLDER IDs until the real ones are
// provisioned: swap GOOGLE_ADS_ID / GA4_ID below and the async loader + config
// activate automatically. The gtag() stub in <head> is always defined so event
// calls (the quote-submit Ads conversion, dataLayer funnel events) never throw
// while the IDs are still placeholders.
const GOOGLE_ADS_ID = 'AW-PLACEHOLDER'; // ← replace with real Google Ads ID (AW-XXXXXXXXXX)
const GA4_ID = 'G-PLACEHOLDER';         // ← replace with real GA4 Measurement ID (G-XXXXXXXXXX)
const TRACKING_IDS = [GA4_ID, GOOGLE_ADS_ID].filter((id) => !id.includes('PLACEHOLDER'));
const canonical = `${SITE_URL}/${pathname}`.replace(/\/+$/, '/');
const ogImageUrl = `${SITE_URL}${ogImage ?? '/og-image.png'}`;

// Sitewide JSON-LD. Emits an Organization with a stable @id that per-page
// schema can reference (Service.provider, CreativeWork.creator, etc.), and a
// WebSite entity so Google can render a sitelinks search box if it chooses.
// Homepage-specific LocalBusiness schema lives in index.astro and complements
// — does not replace — the Organization defined here.
const sitewideSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: 'Designed to Elevate',
    url: SITE_URL,
    logo: `${SITE_URL}/logo-wordmark-orange.png`,
    email: 'bilsonxnc@gmail.com',
    telephone: '+1-740-617-6488',
    founder: { '@type': 'Person', name: 'Bill Chicha' },
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'OH',
      addressCountry: 'US',
    },
    areaServed: { '@type': 'State', name: 'Ohio' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE_URL}/#website`,
    url: SITE_URL,
    name: 'Designed to Elevate',
    publisher: { '@id': `${SITE_URL}/#organization` },
    inLanguage: 'en-US',
  },
];
---
<!doctype html>
<html lang="en" class="landing">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0E1014" />

  <!-- Google tag (gtag.js) — async, non-render-blocking. Remote loader only
       renders once real IDs replace the AW-PLACEHOLDER / G-PLACEHOLDER consts
       above (avoids shipping 404 requests to live visitors while pending).
       The gtag() stub + dataLayer are ALWAYS defined so the quote-submit Ads
       conversion and dataLayer funnel events never throw before IDs exist. -->
  {TRACKING_IDS.length > 0 && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${TRACKING_IDS[0]}`}></script>
  )}
  <script is:inline define:vars={{ TRACKING_IDS }}>
    window.dataLayer = window.dataLayer || [];
    function gtag() { window.dataLayer.push(arguments); }
    window.gtag = window.gtag || gtag;
    gtag('js', new Date());
    TRACKING_IDS.forEach(function (id) { gtag('config', id); });
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Bill Chicha" />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={canonical} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo-mark.png" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Designed to Elevate" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  {!noindex && (
    <script type="application/ld+json" set:html={JSON.stringify(sitewideSchema)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Load the Google Fonts CSS WITHOUT blocking first paint: fetch it as a
       stylesheet with media="print" then flip to "all" on load. Combined with
       display=swap, the LCP headline paints immediately in a fallback font
       instead of waiting on the Google Fonts round-trip (which was adding
       ~750ms of render-blocking to FCP/LCP). <noscript> keeps it working with
       JS disabled. -->
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
  </noscript>
</head>
<body class="bg-bg text-text font-body antialiased">
  <a class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:px-3 focus:py-2 focus:rounded-md focus:bg-accent focus:text-bg" href={skipHref}>{skipLabel}</a>
  <slot />

  <!-- Global Call/Text popup. Any element with [data-call-text]
       opens this dialog so visitors can pick between calling and
       texting Bill instead of being dropped straight into the
       phone app. The dialog uses the native <dialog> element for
       built-in modality, focus trap, and ESC-to-close. -->
  <dialog
    id="call-text-popup"
    class="ct-popup"
    aria-labelledby="ct-popup-title"
  >
    <button type="button" class="ct-popup-close" data-popup-close aria-label="Close">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="ct-popup-eyebrow">
      <span class="ct-popup-dot" aria-hidden="true"></span>
      Reach Bill
    </div>
    <h2 id="ct-popup-title" class="ct-popup-number">(740) 617-6488</h2>

    <div class="ct-popup-actions">
      <a href="tel:7406176488" class="btn-primary ct-popup-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        Call
      </a>
      <a href="sms:7406176488" class="btn-ghost ct-popup-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Text
      </a>
    </div>

    <p class="ct-popup-fine">Bill picks up. No call center, no funnel.</p>
  </dialog>

  <style is:global>
    /* ── Call/Text popup ────────────────────────────────────────
       Uses native <dialog> element so the browser handles the
       backdrop, focus trap, and ESC-to-close for free. */
    .ct-popup {
      position: fixed;
      max-width: 22rem;
      width: calc(100% - 2rem);
      padding: 2rem 1.75rem 1.75rem;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: linear-gradient(180deg, var(--color-surface-1), var(--color-surface-2));
      color: var(--color-text);
      box-shadow:
        0 0 0 1px rgba(255, 122, 26, 0.08),
        0 30px 80px -20px rgba(0, 0, 0, 0.7),
        0 12px 32px -10px rgba(255, 107, 26, 0.25);
      text-align: center;
    }
    .ct-popup::backdrop {
      background: rgba(8, 9, 12, 0.78);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .ct-popup[open] {
      animation: ct-popup-in 0.18s ease-out;
    }
    @keyframes ct-popup-in {
      from { opacity: 0; transform: translateY(8px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .ct-popup-close {
      position: absolute;
      top: 0.6rem;
      right: 0.6rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      background: transparent;
      border: 0;
      padding: 0;
      color: var(--color-text-muted);
      cursor: pointer;
      border-radius: 0.4rem;
      transition: color 0.15s ease, background 0.15s ease;
    }
    .ct-popup-close:hover { color: var(--color-text); background: rgba(255, 255, 255, 0.05); }
    .ct-popup-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-display);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .ct-popup-dot {
      width: 0.4rem;
      height: 0.4rem;
      border-radius: 50%;
      background: var(--color-accent);
      box-shadow: 0 0 0 0.18rem rgba(255, 107, 26, 0.18);
    }
    .ct-popup-number {
      margin: 0.7rem 0 0;
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--color-text);
    }
    .ct-popup-actions {
      margin-top: 1.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.7rem;
    }
    .ct-popup-btn {
      width: 100%;
      gap: 0.45rem;
    }
    .ct-popup-fine {
      margin: 1.1rem 0 0;
      font-size: 0.78rem;
      color: var(--color-text-muted);
      line-height: 1.5;
    }
    /* Reset for [data-call-text] buttons used inline so they
       inherit whatever utility/Tailwind classes wrap them. */
    button[data-call-text] {
      background: none;
      border: 0;
      padding: 0;
      margin: 0;
      font: inherit;
      color: inherit;
      cursor: pointer;
      text-align: inherit;
    }
  </style>

  <script>
    // Call/Text popup — opens the global <dialog> when any element
    // with [data-call-text] is clicked.
    const ctPopup = document.getElementById('call-text-popup') as HTMLDialogElement | null;
    if (ctPopup) {
      document.querySelectorAll<HTMLElement>('[data-call-text]').forEach((trigger) => {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          if (typeof ctPopup.showModal === 'function') {
            ctPopup.showModal();
          } else {
            // Fallback for ancient browsers: jump straight to tel:
            window.location.href = 'tel:7406176488';
          }
        });
      });
      // Click outside the dialog content (on the backdrop) closes it.
      ctPopup.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target === ctPopup || target.closest('[data-popup-close]')) {
          ctPopup.close();
        }
      });
    }

    // Smooth-scroll for any in-page anchor link
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href');
        if (!id || id === '#') return;
        const el = document.querySelector(id);
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', id);
        }
      });
    });

    // Sticky mobile CTA — show only when the hero CTA has scrolled out
    // of view AND the apply form section is not yet visible. Keeps one
    // major orange filled CTA on screen at a time.
    const heroCta = document.querySelector<HTMLElement>('[data-hero-cta]');
    const stickyCta = document.querySelector<HTMLElement>('[data-sticky-cta]');
    const applyFormSection = document.querySelector<HTMLElement>('#apply');
    // The embedded quote wizard (#quote). When it's on screen the sticky bar
    // must hide — otherwise it's redundant and the fixed bottom bar overlaps the
    // wizard's own Continue/Send buttons (the taps that complete the conversion).
    const quoteSection = document.querySelector<HTMLElement>('#quote');

    if (heroCta && stickyCta) {
      let heroVisible = true;
      let formVisible = false;
      let quoteVisible = false;

      const update = () => {
        const show = !heroVisible && !formVisible && !quoteVisible;
        stickyCta.classList.toggle('translate-y-full', !show);
        stickyCta.classList.toggle('opacity-0', !show);
        stickyCta.classList.toggle('pointer-events-none', !show);
      };

      new IntersectionObserver(
        (entries) => {
          heroVisible = entries[0].isIntersecting;
          update();
        },
        { threshold: 0 }
      ).observe(heroCta);

      if (applyFormSection) {
        new IntersectionObserver(
          (entries) => {
            formVisible = entries[0].isIntersecting;
            update();
          },
          { threshold: 0.15 }
        ).observe(applyFormSection);
      }

      if (quoteSection) {
        // Low threshold: the wizard is tall, so hide the bar the instant its
        // top edge enters the viewport (0.15 might never fire on a tall section).
        new IntersectionObserver(
          (entries) => {
            quoteVisible = entries[0].isIntersecting;
            update();
          },
          { threshold: 0.01 }
        ).observe(quoteSection);
      }
    }

    // Audit form → Web3Forms.
    // FormData preserves multi-value `help[]` checkboxes natively;
    // Web3Forms parses them as an array and aggregates them in the email.
    // Add Google Ads conversion tracking inside the success branch when ready.
    const form = document.querySelector<HTMLFormElement>('[data-audit-form]');
    const status = document.querySelector<HTMLElement>('[data-audit-status]');
    if (form && status) {
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const originalBtnHTML = submitBtn?.innerHTML ?? '';

      const showStatus = (msg: string, isError: boolean) => {
        status.textContent = msg;
        status.classList.remove('hidden');
        status.classList.add('flex');
        status.style.color = isError ? '#F87171' : '';
      };

      const setDisabled = (disabled: boolean) => {
        form.querySelectorAll('input, textarea, select, button').forEach((el) => {
          (el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | HTMLButtonElement).disabled = disabled;
        });
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Snapshot the form data BEFORE disabling controls — `disabled`
        // inputs are excluded from FormData per spec, which would strip
        // access_key and every other field from the payload.
        const formData = new FormData(form);

        setDisabled(true);
        if (submitBtn) submitBtn.innerHTML = 'Sending…';
        showStatus('Sending your request…', false);

        try {
          // multipart/form-data — bit-for-bit what a native HTML form POST
          // would send. Multi-value help[] checkboxes preserved as repeats.
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: formData,
          });
          const result = await response
            .json()
            .catch(() => ({} as { success?: boolean; message?: string }));

          if (response.ok && result.success) {
            // Dispatch a page-level event so per-page scripts (e.g. /upgrade
            // analytics) can react without re-implementing the fetch.
            document.dispatchEvent(new CustomEvent('audit-form:success', {
              detail: { source: (formData.get('source') as string) || form.getAttribute('action') || '' },
            }));

            // Opt-in redirect: forms with [data-redirect="/path"] navigate
            // to a thank-you page after a successful submit. Forms without
            // the attribute keep the existing inline-confirmation flow.
            const redirectTo = form.getAttribute('data-redirect');
            if (redirectTo) {
              if (submitBtn) submitBtn.innerHTML = 'Sent ✓';
              window.location.assign(redirectTo);
              return;
            }

            if (submitBtn) submitBtn.innerHTML = 'Sent ✓';
            showStatus(
              "Thanks! Bill will reach out within 24 hours. If you'd like to talk now, call or text (740) 617-6488.",
              false
            );
          } else {
            throw new Error(result.message || `HTTP ${response.status}`);
          }
        } catch (err) {
          setDisabled(false);
          if (submitBtn) submitBtn.innerHTML = originalBtnHTML;
          const detail = err instanceof Error ? err.message : 'Unknown error';
          document.dispatchEvent(new CustomEvent('audit-form:error', {
            detail: { message: detail },
          }));
          showStatus(
            `Couldn't send your request (${detail}). Please call or text Bill at (740) 617-6488 and we'll handle it directly.`,
            true
          );
        }
      });
    }
  </script>
</body>
</html>
