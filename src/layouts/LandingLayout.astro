---
import '../styles/landing.css';

interface Props {
  title: string;
  description: string;
  pathname: string;
  noindex?: boolean;
}

const { title, description, pathname, noindex = false } = Astro.props;
const SITE_URL = 'https://designedtoelevate.co';
const canonicalUrl = `${SITE_URL}/${pathname}`;
const shareImage = `${SITE_URL}/og-image.png`;
---
<!doctype html>
<html lang="en" class="landing">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0E1014" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="format-detection" content="telephone=no" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo-mark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Designed to Elevate" />
    <meta property="og:site_name" content="Designed to Elevate" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="twitter:image:alt" content="Designed to Elevate" />
  </head>
  <body>
    <slot />

    <script>
      const stickyCTA = document.querySelector('[data-sticky-cta]');
      const heroCTA = document.querySelector('[data-hero-cta]');
      const applySection = document.querySelector('#apply');

      if (stickyCTA && heroCTA && applySection && 'IntersectionObserver' in window) {
        let heroVisible = true;
        let applyVisible = false;

        const updateSticky = () => {
          const shouldShow = !heroVisible && !applyVisible;
          stickyCTA.classList.toggle('translate-y-full', !shouldShow);
          stickyCTA.classList.toggle('opacity-0', !shouldShow);
          stickyCTA.classList.toggle('pointer-events-none', !shouldShow);
        };

        new IntersectionObserver(
          ([entry]) => {
            heroVisible = entry.isIntersecting;
            updateSticky();
          },
          { threshold: 0.1 },
        ).observe(heroCTA);

        new IntersectionObserver(
          ([entry]) => {
            applyVisible = entry.isIntersecting;
            updateSticky();
          },
          { threshold: 0.2 },
        ).observe(applySection);
      }
    </script>
  </body>
</html>
