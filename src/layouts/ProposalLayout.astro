---
import '../styles/proposal.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  client: string;
  slug: string;
  noindex?: boolean;
}

const { client, slug, noindex = true } = Astro.props;
const title = `Proposal · ${client} · Designed to Elevate`;
const description = `A custom-coded website proposal from Designed to Elevate.`;
const SITE_URL = 'https://designedtoelevate.co';
const canonicalUrl = `${SITE_URL}/p/${slug}/`;
const shareImage = `${SITE_URL}/og-image.png`;
---
<!doctype html>
<html lang="en" class="proposal">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#181614" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="format-detection" content="telephone=no" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo-mark.png" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={shareImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Designed to Elevate" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Designed to Elevate" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={shareImage} />
  <meta name="twitter:image:alt" content="Designed to Elevate" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&display=swap"
  />
</head>
<body data-slug={slug}>
  <slot />
  <Analytics />

  <script>
    import { track } from '@vercel/analytics';

    // Sticky mobile pay bar — appears once the user scrolls past the
    // hero CTA, hides when the closing CTA enters view so we don't show
    // the pay button twice on screen at once.
    const stickyEl = document.querySelector('[data-sticky-pay]');
    const heroSentinel = document.querySelector('[data-hero-end]');
    const closingSentinel = document.querySelector('[data-closing-cta]');

    if (stickyEl && heroSentinel && closingSentinel) {
      let pastHero = false;
      let closingVisible = false;

      const update = () => {
        const shouldShow = pastHero && !closingVisible;
        stickyEl.classList.toggle('visible', shouldShow);
      };

      new IntersectionObserver(
        ([entry]) => {
          pastHero = !entry.isIntersecting && entry.boundingClientRect.top < 0;
          update();
        },
        { threshold: 0 },
      ).observe(heroSentinel);

      new IntersectionObserver(
        ([entry]) => {
          closingVisible = entry.isIntersecting;
          update();
        },
        { threshold: 0.1 },
      ).observe(closingSentinel);
    }

    // Vercel Analytics custom events. Any element with [data-event]
    // fires a track() call on click. Per-event extra properties come
    // from data-* attributes on the element itself; slug is read once
    // from <body data-slug>.
    const slug = document.body.dataset.slug ?? '';

    document.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement | null)?.closest('[data-event]');
      if (!target) return;
      const event = target.getAttribute('data-event');
      if (!event) return;

      const props: Record<string, string | number> = { slug };
      const business = target.getAttribute('data-business');
      const amount = target.getAttribute('data-amount');
      if (business) props.business = business;
      if (amount) props.amount = Number(amount);

      track(event, props);
    });
  </script>
</body>
</html>
