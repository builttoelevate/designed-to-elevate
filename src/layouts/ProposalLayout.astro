---
import '../styles/proposal.css';

interface Props {
  client: string;
  noindex?: boolean;
}

const { client, noindex = true } = Astro.props;
const title = `Proposal · ${client} · Designed to Elevate`;
---
<!doctype html>
<html lang="en" class="proposal">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#181614" />
  <title>{title}</title>
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <meta name="format-detection" content="telephone=no" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo-mark.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&display=swap"
  />
</head>
<body>
  <slot />

  <script>
    // Sticky mobile pay bar — appears once the user scrolls past the
    // hero CTA, hides when the closing CTA enters view so we don't show
    // the pay button twice on screen at once.
    const stickyEl = document.querySelector('[data-sticky-pay]');
    const heroSentinel = document.querySelector('[data-hero-end]');
    const closingSentinel = document.querySelector('[data-closing-cta]');

    if (stickyEl && heroSentinel && closingSentinel) {
      let pastHero = false;
      let closingVisible = false;

      const update = () => {
        const shouldShow = pastHero && !closingVisible;
        stickyEl.classList.toggle('visible', shouldShow);
      };

      // pastHero = user has scrolled past the hero CTA
      new IntersectionObserver(
        ([entry]) => {
          pastHero = !entry.isIntersecting && entry.boundingClientRect.top < 0;
          update();
        },
        { threshold: 0 },
      ).observe(heroSentinel);

      // closingVisible = the actual closing CTA is on screen
      new IntersectionObserver(
        ([entry]) => {
          closingVisible = entry.isIntersecting;
          update();
        },
        { threshold: 0.1 },
      ).observe(closingSentinel);
    }
  </script>
</body>
</html>
